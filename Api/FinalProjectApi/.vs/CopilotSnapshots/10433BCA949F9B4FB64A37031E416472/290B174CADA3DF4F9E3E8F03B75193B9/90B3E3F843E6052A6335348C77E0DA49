@using FinalProjectMVC.ViewModels.AboutUs
@model List<AboutUsGetVM>

@{
    ViewData["Title"] = "About Us Management";
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">ABOUT US MANAGEMENT</p>
        <h1>About Us List</h1>
    </div>
    <a asp-area="Admin" asp-controller="AboutUs" asp-action="Create" class="admin-btn admin-btn--primary">+ Add New</a>
</div>

@if (!Model.Any())
{
    <p style="color:rgba(255,255,255,0.5); margin-top:24px;">No about us entries found.</p>
}
else
{
    <div class="workers-grid">
        @foreach (var item in Model)
        {
            <div class="worker-card">
                @if (!string.IsNullOrWhiteSpace(item.Image))
                {
                    <img src="@("http://localhost:5147/" + item.Image)" alt="@item.Title" class="worker-card__img" />
                }
                <div class="worker-card__body">
                    <span class="worker-card__kicker">@item.SubTitle</span>
                    <h3 class="worker-card__name">@item.Title</h3>
                    <p class="worker-card__position">@item.Description</p>
                    @if (item.Achievements.Any())
                    {
                        <div class="worker-card__achievements">
                            <span class="worker-card__ach-label">Achievements: @item.Achievements.Count</span>
                        </div>
                    }
                    <div class="admin-actions" style="margin-top:16px;">
                        <a asp-area="Admin" asp-controller="AboutUs" asp-action="Detail" asp-route-id="@item.Id" class="admin-btn admin-btn--sm">Detail</a>
                        <a asp-area="Admin" asp-controller="AboutUs" asp-action="Edit" asp-route-id="@item.Id" class="admin-btn admin-btn--sm">Edit</a>
                        <button type="button"
                                class="admin-btn admin-btn--sm admin-btn--danger open-delete-modal"
                                data-id="@item.Id"
                                data-name="@item.Title"
                                data-subtitle="@item.SubTitle"
                                data-image="@(string.IsNullOrWhiteSpace(item.Image) ? "" : "http://localhost:5147/" + item.Image)">
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Delete Confirmation Modal -->
<div class="delete-modal" id="deleteModal">
    <div class="delete-modal__overlay" id="deleteModalOverlay"></div>
    <div class="delete-modal__content">
        <button type="button" class="delete-modal__close" id="deleteModalClose">&times;</button>
        <div class="delete-modal__top">
            <p class="delete-modal__subtitle">DELETE CONFIRMATION</p>
            <h2>Are you sure?</h2>
            <p class="delete-modal__text">This entry will be permanently deleted.</p>
        </div>
        <div class="delete-modal__worker">
            <img id="deleteItemImage" src="" alt="Image" class="delete-modal__image" />
            <div class="delete-modal__info">
                <h3 id="deleteItemName"></h3>
                <p><strong>Subtitle:</strong> <span id="deleteItemSubtitle"></span></p>
            </div>
        </div>
        <form method="post"
              asp-area="Admin"
              asp-controller="AboutUs"
              asp-action="Delete"
              id="deleteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteItemId" />
            <div class="delete-modal__actions">
                <button type="button" class="admin-btn" id="cancelDelete">Cancel</button>
                <button type="submit" class="admin-btn admin-btn--danger-fill">Yes, Delete</button>
            </div>
        </form>
    </div>
</div>

<style>
    .admin-content__header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
    .admin-content__subtitle { color: #bfa888; letter-spacing: 2px; font-size: 12px; margin-bottom: 8px; }
    .admin-content h1, h1 { font-family: 'Cormorant Garamond', serif; font-size: 40px; margin: 0; }

    .workers-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 24px; }
    .worker-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(191,168,136,0.15); transition: border-color 0.3s ease; overflow: hidden; }
    .worker-card:hover { border-color: rgba(191,168,136,0.4); }
    .worker-card__img { width: 100%; height: 180px; object-fit: cover; display: block; border-bottom: 1px solid rgba(191,168,136,0.12); }
    .worker-card__body { padding: 24px; }
    .worker-card__kicker { display: block; color: #bfa888; font-size: 11px; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 8px; }
    .worker-card__name { font-family: 'Cormorant Garamond', serif; font-size: 22px; margin: 0 0 6px; color: #fff; }
    .worker-card__position { color: rgba(255,255,255,0.55); font-size: 13px; margin: 0 0 12px; line-height: 1.5; }
    .worker-card__ach-label { display: inline-block; background: rgba(191,168,136,0.12); color: #bfa888; font-size: 11px; letter-spacing: 1px; padding: 4px 10px; text-transform: uppercase; }

    .admin-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .admin-btn { display: inline-block; text-decoration: none; background: transparent; color: #fff; border: 1px solid rgba(191,168,136,0.5); padding: 10px 18px; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; transition: all 0.3s ease; font-family: inherit; }
    .admin-btn:hover { color: #bfa888; border-color: #bfa888; }
    .admin-btn--primary { background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%); color: #021527; border-color: transparent; font-weight: 600; }
    .admin-btn--primary:hover { color: #021527; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(191,168,136,0.35); }
    .admin-btn--sm { padding: 7px 12px; font-size: 11px; }
    .admin-btn--danger { border-color: rgba(220,53,69,0.5); color: #ff6b6b; }
    .admin-btn--danger:hover { border-color: #dc3545; background: rgba(220,53,69,0.15); }
    .admin-btn--danger-fill { background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%); color: #fff; border-color: transparent; font-weight: 600; }
    .admin-btn--danger-fill:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(220,53,69,0.35); }

    /* DELETE MODAL */
    .delete-modal { position: fixed; inset: 0; display: none; z-index: 9999; }
    .delete-modal.show { display: flex; align-items: center; justify-content: center; }
    .delete-modal__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(5px); }
    .delete-modal__content { position: relative; width: min(92%, 520px); background: rgba(2,21,39,0.96); border: 1px solid rgba(191,168,136,0.3); padding: 28px; color: #fff; z-index: 2; }
    .delete-modal__close { position: absolute; top: 12px; right: 16px; background: transparent; border: none; color: #bfa888; font-size: 28px; cursor: pointer; transition: all 0.3s ease; }
    .delete-modal__close:hover { color: #fff; transform: rotate(90deg); }
    .delete-modal__subtitle { color: #bfa888; letter-spacing: 2px; font-size: 12px; margin-bottom: 6px; }
    .delete-modal__top h2 { margin: 0 0 10px; font-family: 'Cormorant Garamond', serif; font-size: 34px; }
    .delete-modal__text { color: rgba(255,255,255,0.75); margin-bottom: 20px; }
    .delete-modal__worker { display: flex; gap: 18px; align-items: center; padding: 16px; border: 1px solid rgba(191,168,136,0.2); background: rgba(255,255,255,0.04); margin-bottom: 22px; }
    .delete-modal__image { width: 90px; height: 90px; object-fit: cover; border: 1px solid rgba(191,168,136,0.4); }
    .delete-modal__info h3 { margin: 0 0 10px; font-size: 20px; }
    .delete-modal__info p { margin: 6px 0; color: rgba(255,255,255,0.82); font-size: 14px; }
    .delete-modal__actions { display: flex; justify-content: flex-end; gap: 10px; }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteModal = document.getElementById("deleteModal");
        const deleteModalOverlay = document.getElementById("deleteModalOverlay");
        const deleteModalClose = document.getElementById("deleteModalClose");
        const cancelDelete = document.getElementById("cancelDelete");

        function openDeleteModal(button) {
            document.getElementById("deleteItemId").value = button.getAttribute("data-id");
            document.getElementById("deleteItemName").textContent = button.getAttribute("data-name") || "";
            document.getElementById("deleteItemSubtitle").textContent = button.getAttribute("data-subtitle") || "";
            const img = button.getAttribute("data-image") || "";
            const imgEl = document.getElementById("deleteItemImage");
            imgEl.src = img;
            imgEl.style.display = img ? "block" : "none";
            deleteModal.classList.add("show");
            document.body.style.overflow = "hidden";
        }

        function closeDeleteModal() {
            deleteModal.classList.remove("show");
            document.body.style.overflow = "";
        }

        document.addEventListener("click", function (e) {
            const btn = e.target.closest(".open-delete-modal");
            if (btn) openDeleteModal(btn);
        });

        if (deleteModalClose) deleteModalClose.addEventListener("click", closeDeleteModal);
        if (cancelDelete) cancelDelete.addEventListener("click", closeDeleteModal);
        if (deleteModalOverlay) deleteModalOverlay.addEventListener("click", closeDeleteModal);

        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") closeDeleteModal();
        });
    });
</script>

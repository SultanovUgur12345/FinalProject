document.addEventListener("DOMContentLoaded", function () {

    var tableBody = document.getElementById("workersTableBody");
    var apiBaseUrl = tableBody ? (tableBody.dataset.apiBase || "") : "";
    var searchInput = document.getElementById("workerSearchInput");
    var paginationContainer = document.getElementById("paginationContainer");
    var currentPage = paginationContainer ? parseInt(paginationContainer.dataset.currentPage || "1") : 1;
    var searchTimeout = null;

    function buildRow(item) {
        var imgSrc = item.image ? apiBaseUrl + item.image : "";
        return "<tr class='worker-row'>" +
            "<td><img class='admin-avatar' src='" + imgSrc + "' alt='" + item.fullName + "' /></td>" +
            "<td>" + item.fullName + "</td>" +
            "<td>" + (item.position || "") + "</td>" +
            "<td>" + item.experienceYears + " year</td>" +
            "<td><div class='admin-actions'>" +
                "<a href='/Admin/Workers/Detail/" + item.id + "' class='admin-btn admin-btn--sm'>Get</a>" +
                "<a href='/Admin/Workers/Edit/" + item.id + "' class='admin-btn admin-btn--sm'>Edit</a>" +
                "<button type='button' class='admin-btn admin-btn--sm admin-btn--danger open-delete-modal'" +
                " data-id='" + item.id + "'" +
                " data-name='" + item.fullName + "'" +
                " data-position='" + (item.position || "") + "'" +
                " data-experience='" + item.experienceYears + "'" +
                " data-image='" + imgSrc + "'>Delete</button>" +
            "</div></td>" +
        "</tr>";
    }

    function updatePagination(page, totalPages) {
        var prevBtn = document.getElementById("prevPageBtn");
        var nextBtn = document.getElementById("nextPageBtn");
        var numbersEl = document.getElementById("paginationNumbers");

        prevBtn.disabled = page <= 1;
        prevBtn.dataset.page = page - 1;
        nextBtn.disabled = page >= totalPages;
        nextBtn.dataset.page = page + 1;

        numbersEl.innerHTML = "";
        for (var i = 1; i <= totalPages; i++) {
            var btn = document.createElement("button");
            btn.className = "admin-pagination__number" + (i === page ? " active" : "");
            btn.textContent = i;
            btn.dataset.page = i;
            (function (p) {
                btn.addEventListener("click", function () { loadPage(p); });
            })(i);
            numbersEl.appendChild(btn);
        }

        paginationContainer.style.display = totalPages > 1 ? "flex" : "none";
    }

    function loadPage(page) {
        fetch("/Admin/Workers/GetPage?page=" + page + "&pageSize=5")
            .then(function (res) {
                if (!res.ok) throw new Error("HTTP " + res.status);
                return res.json();
            })
            .then(function (result) {
                tableBody.innerHTML = "";

                if (!result.items || result.items.length === 0) {
                    tableBody.innerHTML = "<tr><td colspan='5' class='admin-table__empty'>No workers found</td></tr>";
                    paginationContainer.style.display = "none";
                    return;
                }

                result.items.forEach(function (item) {
                    tableBody.innerHTML += buildRow(item);
                });

                currentPage = result.page;
                updatePagination(result.page, result.totalPages);
            })
            .catch(function (e) {
                console.error("Pagination error:", e);
            });
    }

    if (searchInput) {
        searchInput.addEventListener("input", function () {
            clearTimeout(searchTimeout);
            var name = searchInput.value.trim();
            searchTimeout = setTimeout(function () {
                if (!name) {
                    paginationContainer.style.display = "";
                    loadPage(currentPage);
                    return;
                }

                paginationContainer.style.display = "none";

                fetch("/Admin/Workers/Search?name=" + encodeURIComponent(name))
                    .then(function (res) {
                        if (!res.ok) throw new Error("HTTP " + res.status);
                        return res.json();
                    })
                    .then(function (workers) {
                        tableBody.innerHTML = "";
                        if (workers.length === 0) {
                            tableBody.innerHTML = "<tr><td colspan='5' class='admin-table__empty'>No workers found</td></tr>";
                            return;
                        }
                        workers.forEach(function (item) {
                            tableBody.innerHTML += buildRow(item);
                        });
                    })
                    .catch(function (e) {
                        console.error("Search error:", e);
                    });
            }, 350);
        });
    }

    var prevBtn = document.getElementById("prevPageBtn");
    var nextBtn = document.getElementById("nextPageBtn");

    if (prevBtn) {
        prevBtn.addEventListener("click", function () {
            if (!this.disabled) loadPage(parseInt(this.dataset.page));
        });
    }
    if (nextBtn) {
        nextBtn.addEventListener("click", function () {
            if (!this.disabled) loadPage(parseInt(this.dataset.page));
        });
    }
    document.querySelectorAll("#paginationNumbers .admin-pagination__number").forEach(function (btn) {
        btn.addEventListener("click", function () { loadPage(parseInt(this.dataset.page)); });
    });

    initDeleteModal({
        modalId: "deleteModal",
        overlayId: "deleteModalOverlay",
        closeId: "deleteModalClose",
        cancelId: "cancelDelete",
        triggerClass: "open-delete-modal",
        activeClass: "show",
        onOpen: function (btn) {
            document.getElementById("deleteWorkerId").value = btn.getAttribute("data-id") || "";
            document.getElementById("deleteWorkerName").textContent = btn.getAttribute("data-name") || "";
            document.getElementById("deleteWorkerPosition").textContent = btn.getAttribute("data-position") || "";
            document.getElementById("deleteWorkerExperience").textContent = btn.getAttribute("data-experience") || "";
            document.getElementById("deleteWorkerImage").src = btn.getAttribute("data-image") || "";
        }
    });
});

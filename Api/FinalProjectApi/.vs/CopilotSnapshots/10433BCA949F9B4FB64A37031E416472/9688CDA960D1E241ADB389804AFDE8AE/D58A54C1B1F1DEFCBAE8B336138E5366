@using FinalProjectMVC.ViewModels.AboutUs
@model List<AboutUsGetVM>

@{
    ViewData["Title"] = "About Us Management";
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">ABOUT US MANAGEMENT</p>
        <h1>About Us List</h1>
    </div>
    <a asp-area="Admin" asp-controller="AboutUs" asp-action="Create" class="admin-btn admin-btn--primary" style="margin-top: 30px;">+ Add New</a>
</div>

@if (!Model.Any())
{
    <p style="color:rgba(255,255,255,0.5); margin-top:24px;">No about us entries found.</p>
}
else
{
    <div class="workers-grid">
        @foreach (var item in Model)
        {
            <div class="worker-card">
                @if (!string.IsNullOrWhiteSpace(item.Image))
                {
                    <img src="@("http://localhost:5147/" + item.Image)" alt="@item.Title" class="worker-card__img" />
                }
                <div class="worker-card__body">
                    <span class="worker-card__kicker">@item.SubTitle</span>
                    <h3 class="worker-card__name">@item.Title</h3>
                    <p class="worker-card__position">@item.Description</p>
                    @if (item.Achievements.Any())
                    {
                        <div class="worker-card__achievements">
                            <span class="worker-card__ach-label">Achievements: @item.Achievements.Count</span>
                        </div>
                    }
                    <div class="admin-actions" style="margin-top:16px;">
                        <a asp-area="Admin" asp-controller="AboutUs" asp-action="Detail" asp-route-id="@item.Id" class="admin-btn admin-btn--sm">Detail</a>
                        <a asp-area="Admin" asp-controller="AboutUs" asp-action="Edit" asp-route-id="@item.Id" class="admin-btn admin-btn--sm">Edit</a>
                        <button type="button"
                                class="admin-btn admin-btn--sm admin-btn--danger open-delete-modal"
                                data-id="@item.Id"
                                data-name="@item.Title"
                                data-subtitle="@item.SubTitle"
                                data-image="@(string.IsNullOrWhiteSpace(item.Image) ? "" : "http://localhost:5147/" + item.Image)">
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="delete-modal" id="deleteModal">
    <div class="delete-modal__overlay" id="deleteModalOverlay"></div>
    <div class="delete-modal__content">
        <button type="button" class="delete-modal__close" id="deleteModalClose">&times;</button>
        <div class="delete-modal__top">
            <p class="delete-modal__subtitle">DELETE CONFIRMATION</p>
            <h2>Are you sure?</h2>
            <p class="delete-modal__text">This entry will be permanently deleted.</p>
        </div>
        <div class="delete-modal__worker">
            <img id="deleteItemImage" src="" alt="Image" class="delete-modal__image" style="display:none;" />
            <div class="delete-modal__info">
                <h3 id="deleteItemName"></h3>
                <p><strong>Subtitle:</strong> <span id="deleteItemSubtitle"></span></p>
            </div>
        </div>
        <form method="post" asp-area="Admin" asp-controller="AboutUs" asp-action="Delete" id="deleteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteItemId" />
            <div class="delete-modal__actions">
                <button type="button" class="admin-btn" id="cancelDelete">Cancel</button>
                <button type="submit" class="admin-btn admin-btn--danger-fill">Yes, Delete</button>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/about-us.css" />
}

@section Scripts {
    <script src="~/admin/assets/js/about-us-index.js"></script>
}
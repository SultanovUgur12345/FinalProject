@{
    ViewData["Title"] = "Ship Detail";
}

<style>
    /* ─── RESET & BASE ─────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
        --navy:   #0a1628;
        --deep:   #0d2242;
        --ocean:  #0e3460;
        --accent: #1e7fcb;
        --gold:   #c9a84c;
        --light:  #e8f0f8;
        --white:  #ffffff;
        --text:   #cdd8e8;
        --radius: 16px;
        --shadow: 0 24px 64px rgba(0,0,0,.45);
        --transition: all .4s cubic-bezier(.25,.8,.25,1);
    }

    body {
        background: var(--navy);
        color: var(--text);
        font-family: 'Segoe UI', system-ui, sans-serif;
        overflow-x: hidden;
    }

    /* ─── HERO ─────────────────────────────────────────────── */
    .sd-hero {
        position: relative;
        height: 92vh;
        min-height: 600px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
    }

    .sd-hero__bg {
        position: absolute;
        inset: 0;
        background:
            url('https://images.unsplash.com/photo-1605745341112-85968b19335b?auto=format&fit=crop&w=2000&q=90')
            center/cover no-repeat;
        transform: scale(1.06);
        transition: transform 8s ease;
        animation: heroZoom 10s ease forwards;
    }

    @@keyframes heroZoom {
        from { transform: scale(1.06); }
        to   { transform: scale(1.00); }
    }

    .sd-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(10,22,40,.98) 0%,
            rgba(10,22,40,.55) 45%,
            rgba(10,22,40,.10) 100%
        );
    }

    .sd-hero__content {
        position: relative;
        z-index: 2;
        width: 100%;
        padding: 0 6vw 72px;
    }

    .sd-hero__kicker {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        text-transform: uppercase;
        letter-spacing: .18em;
        font-size: .78rem;
        color: var(--gold);
        margin-bottom: 18px;
    }

    .sd-hero__kicker::before {
        content: '';
        display: inline-block;
        width: 36px;
        height: 2px;
        background: var(--gold);
    }

    .sd-hero__title {
        font-size: clamp(2.6rem, 6vw, 5.5rem);
        font-weight: 800;
        color: var(--white);
        line-height: 1.08;
        letter-spacing: -.01em;
        max-width: 800px;
    }

    .sd-hero__title span { color: var(--accent); }

    .sd-hero__sub {
        margin-top: 18px;
        font-size: 1.05rem;
        color: var(--text);
        max-width: 560px;
        line-height: 1.7;
    }

    .sd-hero__badges {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 32px;
    }

    .sd-hero__badge {
        padding: 8px 22px;
        border: 1.5px solid rgba(200,220,255,.25);
        border-radius: 40px;
        font-size: .82rem;
        letter-spacing: .08em;
        color: var(--light);
        backdrop-filter: blur(6px);
        background: rgba(255,255,255,.06);
        transition: var(--transition);
    }

    .sd-hero__badge:hover {
        border-color: var(--accent);
        color: var(--white);
        background: rgba(30,127,203,.18);
    }

    /* ─── SCROLL INDICATOR ─────────────────────────────────── */
    .sd-scroll {
        position: absolute;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 3;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        color: rgba(255,255,255,.45);
        font-size: .7rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        animation: bounce 2s infinite;
    }

    .sd-scroll i { font-size: 1rem; }

    @@keyframes bounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50%       { transform: translateX(-50%) translateY(8px); }
    }

    /* ─── SECTION WRAPPER ──────────────────────────────────── */
    .sd-section {
        max-width: 1320px;
        margin: 0 auto;
        padding: 100px 5vw;
    }

    .sd-section-title {
        text-align: center;
        margin-bottom: 64px;
    }

    .sd-section-title .kicker {
        display: inline-block;
        font-size: .75rem;
        letter-spacing: .2em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 14px;
    }

    .sd-section-title h2 {
        font-size: clamp(1.8rem, 3.5vw, 3rem);
        font-weight: 800;
        color: var(--white);
    }

    .sd-section-title h2 span { color: var(--accent); }

    .sd-section-title p {
        margin-top: 16px;
        font-size: 1rem;
        line-height: 1.75;
        color: var(--text);
        max-width: 620px;
        margin-left: auto;
        margin-right: auto;
    }

    /* ─── OVERVIEW SPLIT ───────────────────────────────────── */
    .sd-overview {
        background: var(--deep);
    }

    .sd-split {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: center;
    }

    .sd-split__img-wrap {
        position: relative;
        border-radius: var(--radius);
        overflow: hidden;
    }

    .sd-split__img-wrap img {
        width: 100%;
        height: 480px;
        object-fit: cover;
        display: block;
        transition: transform .6s ease;
    }

    .sd-split__img-wrap:hover img { transform: scale(1.04); }

    .sd-split__img-badge {
        position: absolute;
        bottom: 22px;
        left: 22px;
        background: var(--accent);
        color: var(--white);
        padding: 10px 20px;
        border-radius: 30px;
        font-size: .8rem;
        font-weight: 700;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .sd-split__content h2 {
        font-size: clamp(1.6rem, 2.8vw, 2.4rem);
        font-weight: 800;
        color: var(--white);
        line-height: 1.2;
        margin-bottom: 20px;
    }

    .sd-split__content h2 span { color: var(--accent); }

    .sd-split__content p {
        font-size: .98rem;
        line-height: 1.8;
        color: var(--text);
        margin-bottom: 16px;
    }

    .sd-split__content p:last-of-type { margin-bottom: 0; }

    /* ─── STATS ROW ────────────────────────────────────────── */
    .sd-stats {
        background: linear-gradient(135deg, var(--ocean), var(--deep));
        border-top: 1px solid rgba(255,255,255,.06);
        border-bottom: 1px solid rgba(255,255,255,.06);
    }

    .sd-stats__grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 0;
    }

    .sd-stat {
        padding: 52px 24px;
        text-align: center;
        border-right: 1px solid rgba(255,255,255,.07);
        transition: var(--transition);
    }

    .sd-stat:last-child { border-right: none; }

    .sd-stat:hover { background: rgba(255,255,255,.04); }

    .sd-stat__icon {
        font-size: 2.2rem;
        color: var(--accent);
        margin-bottom: 14px;
    }

    .sd-stat__number {
        font-size: 2.6rem;
        font-weight: 900;
        color: var(--white);
        line-height: 1;
    }

    .sd-stat__number sup {
        font-size: 1rem;
        color: var(--gold);
    }

    .sd-stat__label {
        margin-top: 8px;
        font-size: .78rem;
        letter-spacing: .12em;
        text-transform: uppercase;
        color: var(--text);
    }

    /* ─── GALLERY GRID ─────────────────────────────────────── */
    .sd-gallery-bg {
        background: var(--navy);
    }

    .sd-gallery {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        grid-template-rows: repeat(3, 280px);
        gap: 14px;
    }

    .sd-gallery__item {
        overflow: hidden;
        border-radius: 12px;
        position: relative;
        cursor: pointer;
    }

    .sd-gallery__item:nth-child(1) { grid-column: 1 / 6; grid-row: 1 / 3; }
    .sd-gallery__item:nth-child(2) { grid-column: 6 / 9; grid-row: 1 / 2; }
    .sd-gallery__item:nth-child(3) { grid-column: 9 / 13; grid-row: 1 / 2; }
    .sd-gallery__item:nth-child(4) { grid-column: 6 / 10; grid-row: 2 / 3; }
    .sd-gallery__item:nth-child(5) { grid-column: 10 / 13; grid-row: 2 / 3; }
    .sd-gallery__item:nth-child(6) { grid-column: 1 / 5; grid-row: 3 / 4; }
    .sd-gallery__item:nth-child(7) { grid-column: 5 / 9; grid-row: 3 / 4; }
    .sd-gallery__item:nth-child(8) { grid-column: 9 / 13; grid-row: 3 / 4; }

    .sd-gallery__item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform .55s ease;
    }

    .sd-gallery__item:hover img { transform: scale(1.07); }

    .sd-gallery__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(10,22,40,.75) 0%, transparent 60%);
        opacity: 0;
        transition: opacity .35s;
        display: flex;
        align-items: flex-end;
        padding: 18px;
    }

    .sd-gallery__item:hover .sd-gallery__overlay { opacity: 1; }

    .sd-gallery__overlay span {
        color: var(--white);
        font-size: .82rem;
        font-weight: 600;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    /* ─── FEATURES ─────────────────────────────────────────── */
    .sd-features-bg {
        background: var(--deep);
    }

    .sd-features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 28px;
    }

    .sd-feature {
        background: linear-gradient(145deg, rgba(255,255,255,.04), rgba(255,255,255,.01));
        border: 1px solid rgba(255,255,255,.08);
        border-radius: var(--radius);
        padding: 40px 32px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
    }

    .sd-feature::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        background: linear-gradient(to bottom, var(--accent), var(--gold));
        transform: scaleY(0);
        transform-origin: top;
        transition: transform .4s ease;
    }

    .sd-feature:hover { transform: translateY(-6px); box-shadow: var(--shadow); }
    .sd-feature:hover::before { transform: scaleY(1); }

    .sd-feature__icon {
        width: 56px;
        height: 56px;
        background: rgba(30,127,203,.15);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: var(--accent);
        margin-bottom: 22px;
        transition: var(--transition);
    }

    .sd-feature:hover .sd-feature__icon {
        background: var(--accent);
        color: var(--white);
    }

    .sd-feature h3 {
        font-size: 1.12rem;
        font-weight: 700;
        color: var(--white);
        margin-bottom: 12px;
    }

    .sd-feature p {
        font-size: .92rem;
        line-height: 1.75;
        color: var(--text);
    }

    /* ─── SPECS TABLE ──────────────────────────────────────── */
    .sd-specs-bg {
        background: var(--navy);
    }

    .sd-specs-wrap {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: start;
    }

    .sd-specs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 10px;
    }

    .sd-specs-table tr td {
        padding: 16px 20px;
        font-size: .92rem;
    }

    .sd-specs-table tr td:first-child {
        color: var(--text);
        width: 50%;
        background: rgba(255,255,255,.04);
        border-radius: 8px 0 0 8px;
        letter-spacing: .04em;
    }

    .sd-specs-table tr td:last-child {
        color: var(--white);
        font-weight: 700;
        background: rgba(255,255,255,.06);
        border-radius: 0 8px 8px 0;
    }

    .sd-specs-img {
        border-radius: var(--radius);
        overflow: hidden;
        position: relative;
    }

    .sd-specs-img img {
        width: 100%;
        height: 100%;
        min-height: 400px;
        object-fit: cover;
        display: block;
    }

    .sd-specs-img__label {
        position: absolute;
        top: 22px;
        right: 22px;
        background: rgba(10,22,40,.8);
        border: 1px solid rgba(255,255,255,.12);
        backdrop-filter: blur(10px);
        padding: 10px 18px;
        border-radius: 30px;
        color: var(--gold);
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
    }

    /* ─── TIMELINE ─────────────────────────────────────────── */
    .sd-timeline-bg {
        background: linear-gradient(180deg, var(--deep) 0%, var(--ocean) 100%);
    }

    .sd-timeline {
        position: relative;
        max-width: 780px;
        margin: 0 auto;
        padding-left: 40px;
    }

    .sd-timeline::before {
        content: '';
        position: absolute;
        left: 18px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: linear-gradient(to bottom, var(--accent), var(--gold), transparent);
    }

    .sd-tl-item {
        position: relative;
        margin-bottom: 48px;
        padding-left: 28px;
        opacity: 0;
        transform: translateX(-24px);
        transition: opacity .5s ease, transform .5s ease;
    }

    .sd-tl-item.visible {
        opacity: 1;
        transform: translateX(0);
    }

    .sd-tl-item::before {
        content: '';
        position: absolute;
        left: -14px;
        top: 6px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--accent);
        border: 3px solid var(--deep);
        box-shadow: 0 0 0 4px rgba(30,127,203,.25);
    }

    .sd-tl-item__year {
        font-size: .72rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 6px;
    }

    .sd-tl-item h3 {
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--white);
        margin-bottom: 8px;
    }

    .sd-tl-item p {
        font-size: .9rem;
        line-height: 1.75;
        color: var(--text);
    }

    /* ─── CTA BANNER ───────────────────────────────────────── */
    .sd-cta {
        background:
            linear-gradient(rgba(10,22,40,.82), rgba(10,22,40,.82)),
            url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=2000&q=80')
            center/cover no-repeat fixed;
        padding: 120px 5vw;
        text-align: center;
    }

    .sd-cta h2 {
        font-size: clamp(1.8rem, 3.5vw, 3.2rem);
        font-weight: 900;
        color: var(--white);
        margin-bottom: 20px;
    }

    .sd-cta h2 span { color: var(--accent); }

    .sd-cta p {
        font-size: 1rem;
        color: var(--text);
        max-width: 560px;
        margin: 0 auto 40px;
        line-height: 1.75;
    }

    .sd-btn-group {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 16px;
    }

    .sd-btn {
        padding: 15px 40px;
        border-radius: 40px;
        font-size: .88rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        text-decoration: none;
        transition: var(--transition);
        cursor: pointer;
        border: none;
    }

    .sd-btn--primary {
        background: var(--accent);
        color: var(--white);
        box-shadow: 0 8px 28px rgba(30,127,203,.4);
    }

    .sd-btn--primary:hover {
        background: #1568a8;
        transform: translateY(-3px);
        box-shadow: 0 14px 36px rgba(30,127,203,.55);
    }

    .sd-btn--outline {
        background: transparent;
        color: var(--white);
        border: 2px solid rgba(255,255,255,.3);
    }

    .sd-btn--outline:hover {
        border-color: var(--gold);
        color: var(--gold);
        transform: translateY(-3px);
    }

    /* ─── LIGHTBOX ─────────────────────────────────────────── */
    .sd-lightbox {
        position: fixed;
        inset: 0;
        background: rgba(5,12,25,.96);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity .3s;
    }

    .sd-lightbox.active {
        opacity: 1;
        pointer-events: all;
    }

    .sd-lightbox img {
        max-width: 90vw;
        max-height: 88vh;
        border-radius: 10px;
        box-shadow: 0 32px 80px rgba(0,0,0,.7);
        object-fit: contain;
    }

    .sd-lightbox__close {
        position: absolute;
        top: 24px;
        right: 30px;
        background: none;
        border: none;
        color: var(--white);
        font-size: 1.8rem;
        cursor: pointer;
        opacity: .7;
        transition: opacity .2s;
    }

    .sd-lightbox__close:hover { opacity: 1; }

    /* ─── RESPONSIVE ────────────────────────────────────────── */
    @@media (max-width: 1024px) {
        .sd-split { grid-template-columns: 1fr; gap: 40px; }
        .sd-specs-wrap { grid-template-columns: 1fr; }
        .sd-gallery {
            grid-template-columns: repeat(2, 1fr);
            grid-template-rows: auto;
        }
        .sd-gallery__item { grid-column: auto !important; grid-row: auto !important; }
    }

    @@media (max-width: 640px) {
        .sd-gallery { grid-template-columns: 1fr; }
        .sd-hero__content { padding: 0 5vw 52px; }
        .sd-stat { padding: 36px 16px; }
    }
</style>

<!-- ═══════════════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════════════ -->
<section class="sd-hero">
    <div class="sd-hero__bg"></div>
    <div class="sd-hero__overlay"></div>
    <div class="sd-hero__content">
        <div class="sd-hero__kicker">Maritime Excellence</div>
        <h1 class="sd-hero__title">MV Ocean<span> Sovereign</span></h1>
        <p class="sd-hero__sub">
            A state-of-the-art bulk carrier engineered for endurance, efficiency,
            and unmatched performance across the world's most demanding ocean routes.
        </p>
        <div class="sd-hero__badges">
            <span class="sd-hero__badge">Bulk Carrier</span>
            <span class="sd-hero__badge">IMO Certified</span>
            <span class="sd-hero__badge">ECO Class</span>
            <span class="sd-hero__badge">Built 2019</span>
            <span class="sd-hero__badge">Panama Flag</span>
        </div>
    </div>
    <div class="sd-scroll">
        <i class="fas fa-chevron-down"></i>
        <span>Scroll</span>
    </div>
</section>


<!-- ══ LIGHTBOX ═══════════════════════════════════════════════ -->
<div class="lb" id="lb">
    <button class="lb__close" id="lbClose"><i class="fas fa-times"></i></button>
    <img src="" alt="" id="lbImg" />
</div>

<script>
    // Gallery lightbox
    const lb      = document.getElementById('lb');
    const lbImg   = document.getElementById('lbImg');
    const lbClose = document.getElementById('lbClose');

    document.querySelectorAll('.gallery-cell img').forEach(img => {
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', () => {
            lbImg.src = img.src;
            lb.classList.add('is-open');
            document.body.style.overflow = 'hidden';
        });
    });

    lbClose.addEventListener('click', closeLb);
    lb.addEventListener('click', e => { if (e.target === lb) closeLb(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLb(); });

    function closeLb() {
        lb.classList.remove('is-open');
        document.body.style.overflow = '';
    }

    // Hover tabs
    const tabBtns   = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    function activateTab(i) {
        tabBtns.forEach(b => b.classList.remove('is-active'));
        tabPanels.forEach(p => p.classList.remove('is-active'));
        tabBtns[i].classList.add('is-active');
        tabPanels[i].classList.add('is-active');
    }

    tabBtns.forEach((btn, i) => {
        btn.addEventListener('mouseenter', () => activateTab(i));
        btn.addEventListener('click',      () => activateTab(i));
    });
</script>

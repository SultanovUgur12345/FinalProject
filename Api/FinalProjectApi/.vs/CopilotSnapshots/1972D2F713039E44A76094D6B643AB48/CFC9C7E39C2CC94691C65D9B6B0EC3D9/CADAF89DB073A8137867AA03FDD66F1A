<script>
    // Hover Tab Gallery
    const tabBtns   = document.querySelectorAll('.sh-tab-btn');
    const tabPanels = document.querySelectorAll('.sh-tab-panel');

    function activateTab(index) {
        tabBtns.forEach(b => b.classList.remove('active'));
        tabPanels.forEach(p => p.classList.remove('active'));
        tabBtns[index].classList.add('active');
        tabPanels[index].classList.add('active');
    }

    tabBtns.forEach((btn, i) => {
        btn.addEventListener('mouseenter', () => activateTab(i));
        btn.addEventListener('click',      () => activateTab(i));
    });

    // Stats Counter
    const statNumbers = document.querySelectorAll('.sh-stat__number');

    const counterObs = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            if (entry.isIntersecting && !entry.target.dataset.done) {
                entry.target.dataset.done = '1';
                const sup     = entry.target.querySelector('sup');
                const supHTML = sup ? sup.outerHTML : '';
                const raw     = entry.target.textContent.replace(sup ? sup.textContent : '', '').trim();
                const target  = parseFloat(raw);
                if (isNaN(target)) return;
                const isFloat = raw.includes('.');
                let cur = 0;
                const step = target / 60;
                const t = setInterval(() => {
                    cur += step;
                    if (cur >= target) { cur = target; clearInterval(t); }
                    entry.target.innerHTML = (isFloat ? cur.toFixed(1) : Math.floor(cur)) + supHTML;
                }, 20);
            }
        });
    }, { threshold: 0.5 });

    statNumbers.forEach(n => counterObs.observe(n));
</script>

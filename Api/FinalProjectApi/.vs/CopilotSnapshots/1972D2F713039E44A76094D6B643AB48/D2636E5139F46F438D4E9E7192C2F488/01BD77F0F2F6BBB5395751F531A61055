@using FinalProjectMVC.ViewModels.Setting
@model List<SettingGetVM>

@{
    ViewData["Title"] = "Settings";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">SITE MANAGEMENT</p>
        <h1>Tənzimləmələr</h1>
        <div class="admin-topbar">
            <span class="admin-stat">Total: <strong>@Model?.Count</strong></span>
        </div>
    </div>
</div>

@if (TempData["SettingSuccess"] is string msg)
{
    <div class="admin-alert admin-alert--success">✔ @msg</div>
}

<div class="admin-table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Key</th>
                <th>Value</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Key</td>
                        <td style="max-width:480px;word-break:break-word">@item.Value</td>
                        <td>
                            <div class="admin-actions">
                                <a asp-area="Admin" asp-controller="Setting" asp-action="Edit" asp-route-id="@item.Id"
                                   class="admin-btn admin-btn--sm">Edit</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="admin-table__empty">No settings found.</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .admin-content__header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .admin-content__subtitle {
        color: #bfa888;
        letter-spacing: 2px;
        font-size: 12px;
        margin-bottom: 8px;
    }

    h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 40px;
        margin: 0;
    }

    .admin-topbar {
        margin-top: 10px;
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
    }

    .admin-stat {
        font-size: 14px;
        color: #fff;
        padding: 8px 16px;
        background: rgba(191, 168, 136, 0.1);
        border: 1px solid rgba(191, 168, 136, 0.25);
    }

    .admin-stat strong {
        color: #bfa888;
        margin-left: 6px;
    }

    .admin-alert--success {
        background: rgba(40, 167, 69, 0.15);
        border: 1px solid rgba(40, 167, 69, 0.4);
        color: #6fcf97;
        padding: 12px 16px;
        margin-bottom: 20px;
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .admin-table-container {
        overflow-x: auto;
        margin-bottom: 24px;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

    .admin-table thead tr {
        border-bottom: 2px solid rgba(191, 168, 136, 0.3);
    }

    .admin-table th {
        text-align: left;
        padding: 14px 12px;
        font-size: 12px;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #bfa888;
        font-weight: 600;
    }

    .admin-table td {
        padding: 14px 12px;
        border-bottom: 1px solid rgba(191, 168, 136, 0.15);
        font-size: 14px;
        vertical-align: middle;
        color: rgba(255,255,255,0.85);
    }

    .admin-table tbody tr {
        transition: background 0.2s ease;
    }

    .admin-table tbody tr:hover {
        background: rgba(191, 168, 136, 0.05);
    }

    .admin-table__empty {
        text-align: center;
        color: #bfa888;
        padding: 40px 12px !important;
        font-style: italic;
    }

    .admin-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .admin-btn {
        display: inline-block;
        text-decoration: none;
        background: transparent;
        color: #fff;
        border: 1px solid rgba(191, 168, 136, 0.5);
        padding: 10px 16px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .admin-btn:hover {
        color: #bfa888;
        border-color: #bfa888;
    }

    .admin-btn--sm {
        padding: 6px 12px;
        font-size: 11px;
    }
</style>

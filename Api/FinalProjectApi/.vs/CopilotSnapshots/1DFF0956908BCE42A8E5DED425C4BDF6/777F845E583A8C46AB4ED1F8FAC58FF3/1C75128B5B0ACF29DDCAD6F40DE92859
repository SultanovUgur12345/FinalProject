using FinalProjectMVC.ViewModels.Account;

namespace FinalProjectMVC.Services.Interfaces
{
    public interface IAccountService
    {
        Task<(bool success, string message)> RegisterAsync(RegisterVM model);
        Task<(bool success, string message, string token, string userName)> LoginAsync(LoginVM model);
        Task<(bool success, string message)> ForgotPasswordAsync(ForgotPasswordVM model);
        Task<(bool success, string message)> ResetPasswordAsync(ResetPasswordVM model);




        Task<GetProfileVM> GetProfileAsync(string token);
        Task<(bool success, string message, string? userName, string? profileImageUrl)> UpdateProfileAsync(UpdateProfileVM model, IFormFile? file, string token);
        Task<List<UserListVM>> GetAllUsersAsync(string token, string callerRole);
        Task<List<UserListVM>> SearchUsersByEmailAsync(string email, string token, string callerRole);
        Task<(bool success, string message)> AssignRoleAsync(AssignRoleVM model, string token);

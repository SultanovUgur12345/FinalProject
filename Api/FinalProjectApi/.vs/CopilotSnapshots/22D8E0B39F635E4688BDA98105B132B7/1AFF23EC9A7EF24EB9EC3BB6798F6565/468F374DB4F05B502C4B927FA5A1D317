@using FinalProjectMVC.ViewModels.Worker
@model WorkerCreateVM

@{
    ViewData["Title"] = "Workers - Create";
}

<section class="admin-layout">
    <aside class="admin-sidebar">
        <div class="admin-sidebar__brand">ADMIN PANEL</div>
        <nav class="admin-sidebar__nav">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="admin-sidebar__link">Dashboard</a>
            <a asp-area="Admin" asp-controller="Workers" asp-action="Index" class="admin-sidebar__link active">Workers</a>
            <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="admin-sidebar__link">Users</a>
        </nav>
    </aside>

    <div class="admin-content">
        <div class="admin-content__header">
            <div>
                <p class="admin-content__subtitle">WORKER MANAGEMENT</p>
                <h1>Create Worker</h1>
            </div>
            <a asp-area="Admin" asp-controller="Workers" asp-action="Index" class="admin-btn">← Back to List</a>
        </div>

        <form method="post"
              enctype="multipart/form-data"
              asp-area="Admin"
              asp-controller="Workers"
              asp-action="Create"
              class="admin-form">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="admin-validation"></div>

            <div class="admin-form-group">
                <label asp-for="FullName">Full Name</label>
                <input asp-for="FullName" class="admin-input" />
                <span asp-validation-for="FullName" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Position">Role</label>
                <input asp-for="Position" class="admin-input" />
                <span asp-validation-for="Position" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="ExperienceYears">Experience Years</label>
                <input asp-for="ExperienceYears" class="admin-input" type="number" step="0.1" />
                <span asp-validation-for="ExperienceYears" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Image">Worker Image</label>
                <input asp-for="Image" class="admin-input admin-input--file" type="file" />
                <span asp-validation-for="Image" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Languages">Languages</label>
                <input asp-for="Languages" class="admin-input" placeholder="English, Russian, Turkish" />
                <span asp-validation-for="Languages" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Certificates">Certificates</label>
                <input asp-for="Certificates" class="admin-input" placeholder="AWS, IELTS, PMP" />
                <span asp-validation-for="Certificates" class="admin-validation"></span>
            </div>

            <div class="admin-form-group admin-form-group--full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="admin-input admin-input--area"></textarea>
                <span asp-validation-for="Description" class="admin-validation"></span>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--primary">Save Worker</button>
            </div>
        </form>
    </div>
</section>

<style>
    .admin-workers {
        width: 80%;
        margin: 150px auto 70px;
        color: #fff;
    }

    .admin-workers__container {
        background: rgba(2, 21, 39, 0.86);
        border: 1px solid rgba(191, 168, 136, 0.3);
        padding: 30px;
        backdrop-filter: blur(10px);
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    }

    .admin-workers__container--form {
        max-width: 860px;
        margin: 0 auto;
    }

    .admin-workers__head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        margin-bottom: 25px;
    }

    .admin-workers__subtitle {
        color: #bfa888;
        letter-spacing: 2px;
        font-size: 12px;
        margin-bottom: 6px;
    }

    .admin-workers__head h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 38px;
        margin: 0;
    }

    .admin-form {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .admin-form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .admin-form-group--full {
        grid-column: 1 / -1;
    }

    .admin-form-group label {
        color: #bfa888;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    .admin-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.16);
        color: #fff;
        padding: 12px 14px;
        outline: none;
        border-radius: 8px;
        transition: 0.3s ease;
        font-size: 14px;
    }

        .admin-input:focus {
            border-color: #bfa888;
            box-shadow: 0 0 0 3px rgba(191, 168, 136, 0.15);
        }

        .admin-input::placeholder {
            color: rgba(255, 255, 255, 0.45);
        }

    .admin-input--area {
        min-height: 120px;
        resize: vertical;
    }

    .admin-input--file {
        padding: 10px;
        cursor: pointer;
    }

        .admin-input--file::file-selector-button {
            background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
            color: #021527;
            border: none;
            padding: 8px 14px;
            margin-right: 12px;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 600;
            transition: 0.3s ease;
        }

            .admin-input--file::file-selector-button:hover {
                opacity: 0.9;
            }

    .admin-actions {
        grid-column: 1 / -1;
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }

    .admin-btn {
        display: inline-block;
        text-decoration: none;
        background: transparent;
        color: #fff;
        border: 1px solid rgba(191, 168, 136, 0.5);
        padding: 10px 16px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
        border-radius: 8px;
    }

        .admin-btn:hover {
            color: #bfa888;
            border-color: #bfa888;
        }

    .admin-btn--primary {
        background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
        color: #021527;
        border-color: transparent;
        font-weight: 700;
    }

        .admin-btn--primary:hover {
            color: #021527;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(191, 168, 136, 0.35);
        }

    .admin-validation {
        color: #ffb3bd;
        font-size: 12px;
    }

    @@media (max-width: 768px) {
        .admin-workers {
            width: 92%;
            margin-top: 165px;
        }

        .admin-workers__head {
            flex-direction: column;
            align-items: flex-start;
        }

        .admin-form {
            grid-template-columns: 1fr;
        }
    }
</style>
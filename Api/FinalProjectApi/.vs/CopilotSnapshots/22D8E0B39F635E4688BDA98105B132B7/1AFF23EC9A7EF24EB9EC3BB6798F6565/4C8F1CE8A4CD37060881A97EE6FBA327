@using FinalProjectMVC.ViewModels.Worker
@inject IConfiguration Configuration
@model WorkerEditVM

@{
    ViewData["Title"] = "Workers - Edit";
    string apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<section class="admin-workers">
    <div class="admin-workers__container admin-workers__container--form">
        <div class="admin-workers__head">
            <div>
                <p class="admin-workers__subtitle">ADMIN PANEL</p>
                <h1>Edit Worker</h1>
            </div>

            <a asp-area="Admin" asp-controller="Workers" asp-action="Index" class="admin-btn">Back to List</a>
        </div>

        <form method="post"
              asp-area="Admin"
              asp-controller="Workers"
              asp-action="Edit"
              asp-route-id="@Model.Id"
              class="admin-form"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />
            <input asp-for="CurrentImage" type="hidden" />

            <div class="admin-form-group">
                <label asp-for="FullName">Full Name</label>
                <input asp-for="FullName" class="admin-input" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Position">Role</label>
                <input asp-for="Position" class="admin-input" />
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="ExperienceYears">Experience Years</label>
                <input asp-for="ExperienceYears" class="admin-input" type="number" step="0.1" />
                <span asp-validation-for="ExperienceYears" class="text-danger"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Languages">Languages</label>
                <input asp-for="Languages" class="admin-input" />
                <span asp-validation-for="Languages" class="text-danger"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Certificates">Certificates</label>
                <input asp-for="Certificates" class="admin-input" />
                <span asp-validation-for="Certificates" class="text-danger"></span>
            </div>

            <div class="admin-form-group admin-form-group--full">
                <label>Current Image</label>
                @if (!string.IsNullOrWhiteSpace(Model.CurrentImage))
                {
                    <img src="@($"{apiBaseUrl}{Model.CurrentImage}")" alt="Worker Image" class="admin-worker-image" />
                }
            </div>

            <div class="admin-form-group admin-form-group--full">
                <label asp-for="Image">New Image</label>
                <input asp-for="Image" type="file" class="admin-input" />
                <span asp-validation-for="Image" class="text-danger"></span>
            </div>

            <div class="admin-form-group admin-form-group--full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="admin-input admin-input--area"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="admin-actions">
                <button type="submit" class="admin-btn admin-btn--primary">Update Worker</button>
            </div>
        </form>
    </div>
</section>

<style>
    .admin-workers {
        width: 80%;
        margin: 150px auto 70px;
        color: #fff;
    }

    .admin-workers__container {
        background: rgba(2, 21, 39, 0.86);
        border: 1px solid rgba(191, 168, 136, 0.3);
        padding: 30px;
        backdrop-filter: blur(10px);
    }

    .admin-workers__container--form {
        max-width: 860px;
        margin: 0 auto;
    }

    .admin-workers__head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        margin-bottom: 25px;
    }

    .admin-workers__subtitle {
        color: #bfa888;
        letter-spacing: 2px;
        font-size: 12px;
        margin-bottom: 6px;
    }

    .admin-workers__head h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 38px;
        margin: 0;
    }

    .admin-form {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
    }

    .admin-form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .admin-form-group--full {
        grid-column: 1 / -1;
    }

    .admin-form-group label {
        color: #bfa888;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .admin-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.16);
        color: #fff;
        padding: 12px;
        outline: none;
    }

        .admin-input:focus {
            border-color: #bfa888;
        }

    .admin-input--area {
        min-height: 120px;
        resize: vertical;
    }

    .admin-worker-image {
        width: 140px;
        height: 140px;
        object-fit: cover;
        border: 1px solid rgba(191, 168, 136, 0.4);
        padding: 4px;
        background: rgba(255, 255, 255, 0.04);
    }

    .text-danger {
        color: #ff6b6b;
        font-size: 13px;
    }

    .admin-actions {
        grid-column: 1 / -1;
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }

    .admin-btn {
        display: inline-block;
        text-decoration: none;
        background: transparent;
        color: #fff;
        border: 1px solid rgba(191, 168, 136, 0.5);
        padding: 10px 16px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .admin-btn:hover {
            color: #bfa888;
            border-color: #bfa888;
        }

    .admin-btn--primary {
        background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
        color: #021527;
        border-color: transparent;
        font-weight: 600;
    }

        .admin-btn--primary:hover {
            color: #021527;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(191, 168, 136, 0.35);
        }

    @@media (max-width: 768px) {
        .admin-workers {
            width: 92%;
            margin-top: 165px;
        }

        .admin-workers__head {
            flex-direction: column;
            align-items: flex-start;
        }

        .admin-form {
            grid-template-columns: 1fr;
        }
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
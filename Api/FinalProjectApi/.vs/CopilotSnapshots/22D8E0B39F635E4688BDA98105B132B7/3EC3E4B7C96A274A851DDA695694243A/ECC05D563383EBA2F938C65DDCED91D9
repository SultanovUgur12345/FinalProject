@using FinalProjectMVC.ViewModels.Account
@model List<UserListVM>

@{
    ViewData["Title"] = "Users";
    string callerRole = ViewBag.CallerRole ?? "Admin";
    bool isSuperAdmin = callerRole == "SuperAdmin";
}

<section class="admin-workers">
    <div class="admin-workers__container">
        <div class="admin-workers__head">
            <div>
                <p class="admin-workers__subtitle">ADMIN PANEL</p>
                <h1>Users List</h1>
            </div>
        </div>

        @if (TempData["UserError"] is string errorMsg)
        {
            <div class="admin-error">@errorMsg</div>
        }

        @if (TempData["UserSuccess"] is string successMsg)
        {
            <div class="admin-success">@successMsg</div>
        }

        <div class="admin-workers__topbar">
            <div class="admin-workers__count">
                Total: <span id="totalUsersCount">0</span>
            </div>
        </div>

        <div class="admin-workers__table-wrap">
            <table class="admin-workers__table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        @if (isSuperAdmin)
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    @if (Model != null && Model.Any())
                    {
                        int i = 1;
                        foreach (var item in Model)
                        {
                            <tr class="user-row">
                                <td>@(i++)</td>
                                <td>@item.FullName</td>
                                <td>@item.UserName</td>
                                <td>@item.Email</td>
                                <td>
                                    <span class="admin-badge admin-badge--@(item.Role.ToLower())">
                                        @item.Role
                                    </span>
                                </td>
                                @if (isSuperAdmin)
                                {
                                    <td>
                                        <div class="admin-actions">
                                            @if (item.CanChangeRole)
                                            {
                                                <button type="button"
                                                        class="admin-btn open-role-modal"
                                                        data-id="@item.Id"
                                                        data-name="@item.FullName"
                                                        data-role="@item.Role">
                                                    Change Role
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="admin-badge">—</span>
                                            }
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr id="noUsersRow">
                            <td colspan="6" style="text-align:center; color:#bfa888;">No users found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-pagination" id="paginationContainer">
            <button class="admin-pagination__btn" id="prevPageBtn">Previous</button>
            <div class="admin-pagination__numbers" id="paginationNumbers"></div>
            <button class="admin-pagination__btn" id="nextPageBtn">Next</button>
        </div>

        <div class="admin-pagination__info" id="paginationInfo"></div>
    </div>
</section>

@if (isSuperAdmin)
{
    <!-- Role Modal -->
    <div class="delete-modal" id="roleModal">
        <div class="delete-modal__overlay" id="roleModalOverlay"></div>
        <div class="delete-modal__box">
            <h3 class="delete-modal__title">Change Role</h3>
            <p class="delete-modal__text">
                User: <strong id="modalUserName"></strong>
            </p>
            <p class="delete-modal__text">
                Current Role: <strong id="modalCurrentRole"></strong>
            </p>

            <form asp-area="Admin" asp-controller="Users" asp-action="AssignRole" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="UserId" id="modalUserId" />
                <input type="hidden" name="UserName" id="modalUserNameInput" />

                <div style="margin: 16px 0;">
                    <label style="display:block; margin-bottom:6px; font-weight:600;">New Role</label>
                    <select name="Role" id="modalRoleSelect" class="admin-input">
                        <option value="Admin">Admin</option>
                        <option value="Member">Member</option>
                    </select>
                </div>

                <div class="delete-modal__actions">
                    <button type="submit" class="admin-btn admin-btn--primary">Save</button>
                    <button type="button" class="admin-btn" id="roleModalClose">Cancel</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            // PAGINATION
            const rows = Array.from(document.querySelectorAll(".user-row"));
            const paginationNumbers = document.getElementById("paginationNumbers");
            const prevPageBtn = document.getElementById("prevPageBtn");
            const nextPageBtn = document.getElementById("nextPageBtn");
            const paginationInfo = document.getElementById("paginationInfo");
            const totalUsersCount = document.getElementById("totalUsersCount");
            const paginationContainer = document.getElementById("paginationContainer");
            const noUsersRow = document.getElementById("noUsersRow");

            let currentPage = 1;
            const rowsPerPage = 10;

            totalUsersCount.textContent = rows.length;

            function showPage(page) {
                const totalPages = Math.ceil(rows.length / rowsPerPage) || 1;
                if (page < 1) page = 1;
                if (page > totalPages) page = totalPages;
                currentPage = page;

                const start = (currentPage - 1) * rowsPerPage;
                const end = start + rowsPerPage;

                rows.forEach((row, index) => {
                    row.style.display = (index >= start && index < end) ? "" : "none";
                });

                renderPaginationNumbers();
                updateButtons();
            }

            function renderPaginationNumbers() {
                paginationNumbers.innerHTML = "";
                const totalPages = Math.ceil(rows.length / rowsPerPage) || 1;
                for (let i = 1; i <= totalPages; i++) {
                    const btn = document.createElement("button");
                    btn.type = "button";
                    btn.className = "admin-pagination__number" + (i === currentPage ? " active" : "");
                    btn.textContent = i;
                    btn.addEventListener("click", function () { showPage(i); });
                    paginationNumbers.appendChild(btn);
                }
            }

            function updateButtons() {
                const totalPages = Math.ceil(rows.length / rowsPerPage) || 1;
                prevPageBtn.disabled = currentPage === 1;
                nextPageBtn.disabled = currentPage === totalPages || rows.length === 0;
            }

            if (rows.length > 0) {
                showPage(1);
            } else {
                if (paginationContainer) paginationContainer.style.display = "none";
                if (paginationInfo) paginationInfo.textContent = "No users found";
                if (noUsersRow) noUsersRow.style.display = "";
            }

            prevPageBtn?.addEventListener("click", function () {
                if (currentPage > 1) showPage(currentPage - 1);
            });

            nextPageBtn?.addEventListener("click", function () {
                const totalPages = Math.ceil(rows.length / rowsPerPage);
                if (currentPage < totalPages) showPage(currentPage + 1);
            });

            // ROLE MODAL
            const roleModal = document.getElementById("roleModal");
            const roleModalOverlay = document.getElementById("roleModalOverlay");
            const roleModalClose = document.getElementById("roleModalClose");

            if (roleModal) {
                document.querySelectorAll(".open-role-modal").forEach(btn => {
                    btn.addEventListener("click", function () {
                        const userId = this.dataset.id;
                        const userName = this.dataset.name;
                        const currentRole = this.dataset.role;

                        document.getElementById("modalUserId").value = userId;
                        document.getElementById("modalUserNameInput").value = userName;
                        document.getElementById("modalUserName").textContent = userName;
                        document.getElementById("modalCurrentRole").textContent = currentRole;

                        const select = document.getElementById("modalRoleSelect");
                        // Cari rolu secili et
                        Array.from(select.options).forEach(opt => {
                            opt.selected = opt.value === currentRole;
                        });

                        roleModal.classList.add("active");
                    });
                });

                function closeRoleModal() {
                    roleModal.classList.remove("active");
                }

                roleModalClose?.addEventListener("click", closeRoleModal);
                roleModalOverlay?.addEventListener("click", closeRoleModal);
            }
        });
    </script>
}

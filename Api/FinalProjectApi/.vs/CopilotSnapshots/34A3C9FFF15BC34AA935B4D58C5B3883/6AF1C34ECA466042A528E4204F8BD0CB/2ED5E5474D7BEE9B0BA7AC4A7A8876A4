            line-height: 1.45;
            position: relative;
            z-index: 2;
        }

        .pricing-card p:last-of-type {
            margin-bottom: 0;
        }

        .pricing-card .view-more {
            color: #fff;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: auto;
            padding-top: 42px;
            transition: all 0.3s;
            position: relative;
            z-index: 2;
            justify-content: center;
            letter-spacing: 4px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .pricing-card .view-more:hover {
            color: #bfa888;
        }

        @media (max-width: 1024px) {
            .pricing-grid {
                grid-template-columns: 1fr;
                max-width: 650px;
            }

            #pricing-section .section-main-title {
                font-size: 52px;
            }

            #pricing-section .section-title::before {
                font-size: 92px;
                top: -40px;
            }
        }

        @media (max-width: 680px) {
            #pricing-section {
                padding: 75px 20px 70px;
            }

            #pricing-section .section-main-title {
                font-size: 38px;
            }

            #pricing-section .section-description {
                width: 100%;
                font-size: 15px;
            }

            #pricing-section .section-title::before {
                font-size: 62px;
                top: -28px;
            }

            .pricing-card {
                min-height: 560px;
                padding: 54px 28px 46px;
            }
        }

/* ========== RESET & BASE ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Roboto', sans-serif;
            background-color: #021527;
            color: #021527;
            overflow-x: hidden;
            background-image: url('https://seafarer.qodeinteractive.com/wp-content/uploads/2021/07/home-1-parallax-1.jpg');

        }

        /* ========== FIXED HEADER WRAPPER ========== */
        #qodef-fixed-header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1100;
        }

        /* ========== TOP AREA ========== */
        #qodef-top-area {
            background-color: transparent;
            border-bottom: none;
            font-size: 13px;
            transition: all 0.3s ease;
        }

        #qodef-top-area-inner {
            width: 80%;
            margin: 0 auto;
            padding: 10px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .qodef-widget-holder {
            display: flex;
            align-items: center;
            gap: 30px;
        }

        .qodef-widget-holder a {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

        .qodef-widget-holder a:hover {
            color: #bfa888;
        }

        .qodef-widget-holder p {
            color: rgba(255, 255, 255, 0.8);
            font-size: 13px;
            margin: 0;
        }

        /* ========== MAIN HEADER ========== */
        #qodef-page-header {
            position: relative;
            background-color: transparent;
            backdrop-filter: none;
            box-shadow: none;
            transition: all 0.4s cubic-bezier(0.2, 0.95, 0.4, 1);
            z-index: 1000;
        }

        /* Sticky Header */
        #qodef-page-header.qodef-header--sticky {
            background-color: rgba(2, 21, 39, 0.96);
            backdrop-filter: blur(10px);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
            animation: slideDown 0.4s ease;
        }

        @keyframes slideDown {
            from {
                transform: translateY(-100%);
            }

            to {
                transform: translateY(0);
            }
        }

        #qodef-page-header-inner {
            width: 80%;
            margin: 0 auto;
            padding: 15px 30px;
            display: grid;
            grid-template-columns: 240px minmax(0, 1fr) 240px;
            align-items: center;
            gap: 20px;
        }

        .qodef-header-tools-left,
        .qodef-header-tools-right {
            display: flex;
            align-items: center;
            min-width: 240px;
        }

        .qodef-header-tools-left {
            justify-content: flex-start;
        }

        .qodef-header-tools-right {
            justify-content: flex-end;
            gap: 14px;
        }

        .qodef-header-user {
            position: relative;
            z-index: 20;
        }

        .qodef-user-opener {
            width: 36px;
            height: 36px;
            border: 1px solid rgba(191, 168, 136, 0.45);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .qodef-user-opener:hover {
            color: #bfa888;
            border-color: #bfa888;
            background: rgba(191, 168, 136, 0.08);
        }

        .qodef-user-dropdown {
            position: absolute;
            top: calc(100% + 12px);
            right: 0;
            min-width: 145px;
            background: #fff;
            border-radius: 4px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
            padding: 8px 0;
            opacity: 0;
            visibility: hidden;
            transform: translateY(8px);
            transition: all 0.25s ease;
        }

        .qodef-user-dropdown a {
            display: block;
            padding: 10px 16px;
            color: #2c3a47;
            font-size: 13px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .qodef-user-dropdown a:hover {
            background: #f7f7f7;
            color: #bfa888;
            padding-left: 20px;
        }

        .qodef-header-user:hover .qodef-user-dropdown,
        .qodef-header-user:focus-within .qodef-user-dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .qodef-header-center-wrap {
            width: 100%;
            display: flex;
            justify-content: center;
            min-width: 0;
        }

        .qodef-header-center-wrap .qodef-header-navigation>ul {
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
        }

        .qodef-header-menu-logo {
            margin: 0 8px;
        }

        .qodef-header-menu-logo .qodef-header-logo-link {
            display: inline-flex;
            align-items: center;
            padding: 0 8px;
        }

        .qodef-header-menu-logo .qodef-header-logo-link img {
            max-height: 62px;
        }

        /* ========== LOGO ========== */
        .qodef-header-logo-link {
            display: inline-block;
            flex-shrink: 0;
            transition: opacity 0.3s ease;
        }

        .qodef-header-logo-link:hover {
            opacity: 0.85;
        }

        .qodef-header-logo-link img {
            max-height: 70px;
            width: auto;
            transition: all 0.3s ease;
        }

        .qodef-header--sticky .qodef-header-logo-link img {
            max-height: 55px;
        }

        /* ========== SEARCH FORM ========== */
        .qodef-search-form {
            position: relative;
        }

        .qodef-search-form-inner {
            display: flex;
            align-items: center;
            border-bottom: 1px solid transparent;
            transition: all 0.3s ease;
        }

        .qodef-search-form-inner:hover,
        .qodef-search-form-inner:focus-within {
            border-bottom-color: #bfa888;
        }

        .qodef-search-form-field {
            background: transparent;
            border: none;
            padding: 8px 0;
            font-size: 14px;
            font-weight: 400;
            color: #fff;
            outline: none;
            width: 0;
            opacity: 0;
            pointer-events: none;
            transition: width 0.35s ease, opacity 0.2s ease;
        }

        .qodef-search-form-field::-webkit-search-cancel-button,
        .qodef-search-form-field::-webkit-search-decoration,
        .qodef-search-form-field::-webkit-search-results-button,
        .qodef-search-form-field::-webkit-search-results-decoration {
            -webkit-appearance: none;
            appearance: none;
            display: none;
        }

        .qodef-search-form.is-open .qodef-search-form-field,
        .qodef-search-form:focus-within .qodef-search-form-field {
            width: 220px;
            opacity: 1;
            pointer-events: auto;
        }

        .qodef-search-form-field::placeholder {
            color: rgba(255, 255, 255, 0.6);
            font-size: 13px;
            font-weight: 300;
        }

        .qodef-search-form-button {
            background: transparent;
            border: none;
            cursor: pointer;
            padding: 5px 0 5px 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.3s ease;
        }

        .qodef-search-form-button:hover {
            opacity: 0.7;
        }

        .qodef-search-form-button svg {
            fill: #fff;
            width: 18px;
            height: 18px;
            transition: fill 0.3s ease;
        }

        .qodef-search-form-inner:hover .qodef-search-form-button svg {
            fill: #bfa888;
        }

        /* ========== NAVIGATION ========== */
        .qodef-header-navigation ul {
            list-style: none;
            display: flex;
            margin: 0;
            padding: 0;
        }

        .qodef-header-navigation>ul>li {
            position: relative;
        }

        .qodef-header-navigation>ul>li>a {
            display: flex;
            align-items: center;
            gap: 5px;
            position: relative;
            padding: 10px 18px;
            font-size: 14px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #fff;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .qodef-header-navigation>ul>li>a::before,
        .qodef-header-navigation>ul>li>a::after {
            content: '';
            position: absolute;
            left: 18px;
            bottom: 4px;
            height: 2px;
            width: calc(100% - 36px);
            pointer-events: none;
        }

        .qodef-header-navigation>ul>li>a::before {
            background: rgba(191, 168, 136, 0.22);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.28s ease;
        }

        .qodef-header-navigation>ul>li>a::after {
            background: #bfa888;
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.35s ease;
        }

        .qodef-header-navigation>ul>li>a:hover {
            color: #bfa888;
        }

        /* ========== ACTIVE STATE - NO HOVER REQUIRED ========== */
        .qodef-header-navigation>ul>li.active>a {
            color: #d6c09b;
        }

        .qodef-header-navigation>ul>li.active>a::before,
        .qodef-header-navigation>ul>li.active>a::after {
            transform: scaleX(1);
        }

        .qodef-header-navigation>ul>li.active>a::after {
            background: #d6c09b;
        }

        /* ========== HOVER STATE ========== */
        .qodef-header-navigation>ul>li:hover>a::before,
        .qodef-header-navigation>ul>li:hover>a::after,
        .qodef-header-navigation>ul>li>a:hover::before,
        .qodef-header-navigation>ul>li>a:hover::after,
        .qodef-header-navigation>ul>li>a:focus-visible::before,
        .qodef-header-navigation>ul>li>a:focus-visible::after {
            transform: scaleX(1);
        }

        /* ========== ACTIVE NAVIGATION LINK ========== */
        .qodef-header-navigation>ul>li>a.active {
            color: #d6c09b;
        }

        .qodef-header-navigation>ul>li>a.active::after {
            background: #d6c09b;
            transform: scaleX(1);
        }

        .qodef-menu-item-arrow {
            width: 10px;
            height: auto;
            fill: currentColor;
            transition: transform 0.3s ease;
        }

        .qodef-header-navigation>ul>li:hover>a .qodef-menu-item-arrow {
            transform: rotate(180deg);
        }

        /* ========== BOOK BUTTON STYLING ========== */
        .qodef-header-navigation .qodef-book-btn>a {
            background: #d6c09b;
            color: #021527;
            border-radius: 999px;
            padding: 10px 24px;
            font-weight: 700;
            box-shadow: 0 8px 18px rgba(214, 192, 155, 0.3);
            transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .qodef-header-navigation .qodef-book-btn>a::before,
        .qodef-header-navigation .qodef-book-btn>a::after {
            display: none !important;
        }

        .qodef-header-navigation .qodef-book-btn>a:hover,
        .qodef-header-navigation .qodef-book-btn>a:focus-visible {
            background: #c4a86f;
            color: #021527;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 12px 24px rgba(214, 192, 155, 0.45);
        }

        .qodef-drop-down-second {
            position: absolute;
            top: 100%;
            left: 0;
            width: 240px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .qodef-header-navigation li:hover>.qodef-drop-down-second {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .qodef-drop-down-second-inner {
            background: #fff;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            border-radius: 4px;
            padding: 15px 0;
        }

        .sub-menu {
            flex-direction: column !important;
        }

        .sub-menu li a {
            display: block;
            padding: 8px 25px;
            color: #333;
            text-decoration: none;
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0.3px;
            transition: all 0.3s ease;
        }

        .sub-menu li a:hover {
            color: #bfa888;
            background-color: #f8f8f8;
            padding-left: 30px;
        }

        /* ========== SIDE AREA OPENER ========== */
        .qodef-side-area-opener {
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.3s ease;
        }

        .qodef-side-area-opener:hover {
            opacity: 0.7;
        }

        .qodef-m-lines {
            display: flex;
            flex-direction: column;
            gap: 5px;
            width: 26px;
        }

        .qodef-m-line {
            height: 2px;
            width: 100%;
            background-color: #fff;
            transition: all 0.3s ease;
            border-radius: 2px;
        }

        .qodef-side-area-opener:hover .qodef-m-line:nth-child(1) {
            width: 70%;
        }

        .qodef-side-area-opener:hover .qodef-m-line:nth-child(3) {
            width: 70%;
        }

        /* ========== RESPONSIVE HEADER ========== */
        @media (max-width: 1100px) {
            #qodef-page-header-inner {
                padding: 15px 20px;
                grid-template-columns: 200px minmax(0, 1fr) 200px;
                gap: 20px;
            }

            .qodef-header-tools-left,
            .qodef-header-tools-right {
                min-width: 200px;
            }

            .qodef-header-navigation>ul>li>a {
                padding: 8px 12px;
                font-size: 12px;
            }
        }

        @media (max-width: 900px) {
            #qodef-page-header-inner {
                grid-template-columns: 1fr;
                padding: 15px 20px;
            }

            .qodef-header-tools-left,
            .qodef-header-tools-right {
                justify-content: center;
            }

            .qodef-header-menu-logo .qodef-header-logo-link img {
                max-height: 50px;
            }

            .qodef-header-navigation>ul {
                flex-wrap: wrap;
                justify-content: center;
            }
        }

        @media (max-width: 768px) {
            #qodef-top-area-inner {
                flex-direction: column;
                text-align: center;
                padding: 10px 15px;
            }

            .qodef-widget-holder {
                justify-content: center;
                flex-wrap: wrap;
                gap: 15px;
            }

            .qodef-header-navigation>ul>li>a {
                padding: 6px 10px;
                font-size: 11px;
            }

            .qodef-drop-down-second {
                position: static;
                width: 100%;
                opacity: 0;
                transform: none;
                display: none;
            }

            .qodef-header-navigation li:hover>.qodef-drop-down-second {
                display: block;
                opacity: 1;
            }

            .sub-menu {
                background: rgba(0, 0, 0, 0.1);
                padding-left: 20px;
            }

            .sub-menu li a {
                color: #fff;
            }
        }

        @media (max-width: 480px) {
            .qodef-header-logo-link img {
                max-height: 50px;
            }

            .qodef-search-form-field {
                width: 120px;
                font-size: 12px;
            }

            .qodef-search-form-field:focus {
                width: 150px;
            }
        }

        /* ========== HERO SWIPER ========== */
        #hero {
            width: 100%;
            height: 100vh;
            min-height: 700px;
            position: relative;
            overflow: hidden;
        }

        .hero-swiper {
            width: 100%;
            height: 100%;
            position: relative;
        }

        .hero-swiper .swiper-wrapper {
            height: 100%;
        }

        .hero-slide {
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            position: relative;
        }

        .hero-slide::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.3);
        }

        .hero-content {
            width: 500px;
            margin-left: 10%;
            color: #fff;
            position: relative;
            z-index: 2;
        }

        .hero-content .pre-title {
            font-family: 'Inconsolata', monospace;
            font-size: 13px;
            letter-spacing: 4px;
            opacity: 0;
            transform: translateX(50px);
            transition: opacity 0.6s ease, transform 0.6s ease;
        }

        .hero-content h1 {
            font-family: 'Cormorant Garamond', serif;
            font-size: 80px;
            font-weight: 700;
            text-transform: uppercase;
            opacity: 0;
            transform: translateX(50px);
            transition: opacity 0.6s ease 0.1s, transform 0.6s ease 0.1s;
        }

        .hero-content p {
            font-size: 17px;
            line-height: 28px;
            margin-bottom: 20px;
            opacity: 0;
            transform: translateX(50px);
            transition: opacity 0.6s ease 0.2s, transform 0.6s ease 0.2s;
        }

        .hero-content .btn-group {
            opacity: 0;
            transform: translateX(50px);
            transition: opacity 0.6s ease 0.3s, transform 0.6s ease 0.3s;
        }

        .swiper-slide-active .hero-content .pre-title,
        .swiper-slide-active .hero-content h1,
        .swiper-slide-active .hero-content p,
        .swiper-slide-active .hero-content .btn-group {
            opacity: 1;
            transform: translateX(0);
        }

        .btn-group {
            display: flex;
            gap: 20px;
        }

        .btn {
            padding: 12px 30px;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.3s;
            display: inline-block;
        }

        .btn-outline {
            border: 1px solid #fff;
            color: #fff;
            background: transparent;
        }

        .btn-outline:hover {
            background: #fff;
            color: #031C33;
        }

        .btn-filled {
            background: #bfa888;
            border: 1px solid #bfa888;
            color: #fff;
        }

        .btn-filled:hover {
            background: #998363;
            border-color: #998363;
        }

        .swiper-button-prev-custom,
        .swiper-button-next-custom {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 50px;
            height: 50px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 20;
            transition: all 0.3s;
            color: #fff;
            font-size: 20px;
        }

        .swiper-button-prev-custom {
            left: 30px;
        }

        .swiper-button-next-custom {
            right: 30px;
        }

        .swiper-button-prev-custom:hover,
        .swiper-button-next-custom:hover {
            background: #bfa888;
        }

        .hero-swiper-pagination {
            position: absolute;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 20;
        }

        .hero-swiper-pagination .swiper-pagination-bullet {
            width: 10px;
            height: 10px;
            background: rgba(255, 255, 255, 0.5);
            opacity: 1;
            transition: background 0.3s;
        }

        .hero-swiper-pagination .swiper-pagination-bullet-active {
            background: #bfa888;
        }






 /* Clients Section */
        #clients-section {
            padding: 60px 40px;
        }
        .clients-grid {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 30px;
            width: 80%;
            margin: 0 auto;
            align-items: center;
            justify-items: center;
        }
        .client-item {
            transition: all 0.3s;
        }
        .client-item img {
            filter: grayscale(100%) brightness(0.78);
            transition: transform 0.32s ease, filter 0.32s ease;
            width: 140px;
            height: 60px;
            object-fit: contain;
            cursor: pointer;
        }
        .client-item:hover img {
            filter: sepia(1) saturate(2.2) hue-rotate(350deg) brightness(0.92);
            transform: translateY(-8px);
        }


        /* ========== PROGRESS SECTION ========== */
        #progress {
            display: flex;
            min-height: 80vh;
        }

        .progress-left {
            flex: 1;
            background-image: url('https://seafarer.qodeinteractive.com/wp-content/uploads/2021/07/home-1-parallax-1.jpg');
            background-size: cover;
            background-position: center;
            position: relative;
        }

     

        .progress-right {
            flex: 1;
            background: #f9f9f7;
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .section-subtitle {
            font-size: 13px;
            letter-spacing: 3px;
            color: #bfa888;
            text-transform: uppercase;
            margin-bottom: 10px;
        }

        .section-title {
            font-size: 42px;
            font-weight: 600;
            font-family: 'Cormorant Garamond', serif;
            color: #021527;
            margin-bottom: 20px;
        }

        .section-description {
            font-size: 16px;
            line-height: 28px;
            color: #666;
            margin-bottom: 40px;
            width: 80%;
        }

        .progress-item {
            margin-bottom: 35px;
        }

        .progress-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
        }

        .progress-title {
            font-size: 16px;
            font-weight: 600;
            color: #021527;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .progress-percent {
            font-size: 16px;
            font-weight: 600;
            color: #bfa888;
        }

        .progress-bar-wrapper {
            width: 100%;
            height: 4px;
            background: #e0dcd3;
            border-radius: 2px;
            overflow: hidden;
        }

        .progress-bar-fill {
            height: 100%;
            background: #bfa888;
            width: 0;
            border-radius: 2px;
            transition: width 1.5s ease-in-out;
        }

        #progress.visible .progress-bar-fill {
            width: var(--target-width);
        }

        @media (max-width: 1024px) {
            #progress {
                flex-direction: column;
            }

            .progress-left {
                min-height: 300px;
            }

            .progress-right {
                padding: 50px 30px;
            }

            .section-title {
                font-size: 32px;
            }

            .section-description {
                width: 100%;
            }
        }

        @media (max-width: 768px) {
            .progress-right {
                padding: 40px 20px;
            }

            .section-title {
                font-size: 28px;
            }
        }

        /* ========== DISCOVER SECTION ========== */
        #discover {
            width: 100%;
            height: 100vh;
            min-height: 600px;

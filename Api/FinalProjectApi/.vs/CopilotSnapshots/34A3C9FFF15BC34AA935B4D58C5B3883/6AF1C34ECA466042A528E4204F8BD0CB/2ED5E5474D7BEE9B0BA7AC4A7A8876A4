            border-color: rgba(191, 168, 136, 0.5);
            background: rgba(10, 26, 42, 0.8);
            transform: translateY(-5px);
        }

        /* Hover Border Animation - Soldan ve Sağdan */
        .feature-card::before,
        .feature-card::after {
            content: '';
            position: absolute;
            background: #bfa888;
            transition: transform 0.4s ease;
            z-index: 1;
        }

        .feature-card::before {
            top: 0;
            left: 0;
            width: 2px;
            height: 100%;
            transform: scaleY(0);
            transform-origin: top;
        }

        .feature-card::after {
            top: 0;
            right: 0;
            width: 2px;
            height: 100%;
            transform: scaleY(0);
            transform-origin: bottom;
        }

        .feature-card .border-top,
        .feature-card .border-bottom {
            position: absolute;
            background: #bfa888;
            transition: transform 0.4s ease 0.1s;
            z-index: 1;
        }

        .feature-card .border-top {
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            transform: scaleX(0);
            transform-origin: left;
        }

        .feature-card .border-bottom {
            bottom: 0;
            left: 0;
            width: 100%;
            height: 2px;
            transform: scaleX(0);
            transform-origin: right;
        }

        .feature-card:hover::before,
        .feature-card:hover::after {
            transform: scaleY(1);
        }

        .feature-card:hover .border-top,
        .feature-card:hover .border-bottom {
            transform: scaleX(1);
        }

        .feature-icon {
            width: 80px;
            height: 80px;
            border: 1px solid #bfa888;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .feature-icon svg {
            width: 50px;
            height: 50px;
            fill: #bfa888;
            transition: all 0.3s;
        }

        .feature-icon img {
            width: 50px;
            height: 50px;
            object-fit: contain;
            filter: invert(1) sepia(1) saturate(2) hue-rotate(5deg) brightness(0.9);
            transition: all 0.3s;
        }

        .feature-card:hover .feature-icon svg {
            fill: #d4b898;
            transform: scale(1.05);
        }

        .feature-card:hover .feature-icon img {
            transform: scale(1.05);
        }

        .feature-content {
            flex: 1;
        }


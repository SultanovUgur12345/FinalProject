@using FinalProjectMVC.ViewModels.Partner
@model List<PartnerGetVM>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    var apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<section id="clients-section">
    <div class="clients-grid">
        @if (Model != null && Model.Any())
        {
            foreach (var partner in Model)
            {
                <div class="client-item">
                    <img src="@(string.IsNullOrWhiteSpace(partner.Image) ? "" : $"{apiBaseUrl}{partner.Image}")" alt="Partner" />
                </div>
            }
        }
    </div>
</section>
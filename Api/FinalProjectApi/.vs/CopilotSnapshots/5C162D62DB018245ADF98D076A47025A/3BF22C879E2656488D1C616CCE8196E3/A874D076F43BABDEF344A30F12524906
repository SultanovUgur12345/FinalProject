using Microsoft.AspNetCore.Mvc;

namespace FinalProjectMVC.ViewComponents.Home
{
    public class ShipSliderViewComponent : ViewComponent
    {
        private readonly IShipSliderApiService _service;

        public ShipSliderViewComponent(IShipSliderApiService service)
        {
            _service = service;
        }

        public async Task<IViewComponentResult> InvokeAsync()
        {
            var sliders = await _service.GetAllAsync();
            return View(sliders);
        }
    }
}

<section id="contactTop">
    <article class="panel contact-info">
        <div class="contact-kicker">Contact Us</div>
        <h2 class="contact-title">Get In Touch With Us</h2>
        <p class="contact-text">Whether you have questions, need support, or want to discuss a private cruise, our team is ready to assist with fast, premium service.</p>

        <div class="info-grid">
            <div class="contact-chip">
                <i class="fas fa-phone"></i>
                <h4>Phone Number</h4>
                <a href="tel:@ViewBag.Phone">@ViewBag.Phone</a>
            </div>
            <div class="contact-chip">
                <i class="fas fa-envelope"></i>
                <h4>Email Address</h4>
                <a href="mailto:@ViewBag.Email">@ViewBag.Email</a>
            </div>
            <div class="contact-chip" style="grid-column: 1 / -1;">
                <i class="fas fa-location-dot"></i>
                <h4>Address</h4>
                <p>Roadtown Street 9, The Yacht Building, British Virgin Islands</p>
            </div>
        </div>

        <div class="social-row">
            @if (!string.IsNullOrEmpty(ViewBag.WhatsApp as string))
            {
                <a class="social-chip" href="https://wa.me/@ViewBag.WhatsApp" target="_blank" rel="noopener noreferrer"><i class="fab fa-whatsapp"></i> WhatsApp</a>
            }
            @if (!string.IsNullOrEmpty(ViewBag.Instagram as string))
            {
                <a class="social-chip" href="@ViewBag.Instagram" target="_blank" rel="noopener noreferrer"><i class="fab fa-instagram"></i> Instagram</a>
            }
            @if (!string.IsNullOrEmpty(ViewBag.Twitter as string))
            {
                <a class="social-chip" href="@ViewBag.Twitter" target="_blank" rel="noopener noreferrer"><i class="fab fa-twitter"></i> Twitter</a>
            }
            @if (!string.IsNullOrEmpty(ViewBag.Youtube as string))
            {
                <a class="social-chip" href="@ViewBag.Youtube" target="_blank" rel="noopener noreferrer"><i class="fab fa-youtube"></i> Youtube</a>
            }
        </div>
    </article>

    <article class="panel contact-form-card">
        <h3 class="contact-form-title">Send A Message</h3>
        <p class="contact-form-sub">Unlock your potential with expert guidance. Schedule a free consultation for personalized business success.</p>
        <form class="contact-form-grid" action="#" method="post">
            <input type="text" placeholder="First Name" required>
            <input type="text" placeholder="Last Name" required>
            <input type="email" placeholder="Email Address" required>
            <input type="tel" placeholder="Phone Number" required>
            <textarea placeholder="Message" required></textarea>
        </form>
        <button class="btn-gold" type="button">Submit Message</button>
    </article>
</section>
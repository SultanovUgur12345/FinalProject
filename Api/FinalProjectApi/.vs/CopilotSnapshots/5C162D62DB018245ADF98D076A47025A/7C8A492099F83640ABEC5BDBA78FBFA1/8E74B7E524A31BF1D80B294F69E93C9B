using FinalProjectMVC.Services.Interfaces;
using Microsoft.AspNetCore.Mvc;

namespace FinalProjectMVC.ViewComponents.Header
{
    public class HeaderViewComponent : ViewComponent
    {
        private readonly ISettingApiService _settingService;

        public HeaderViewComponent(ISettingApiService settingService)
        {
            _settingService = settingService;
        }

        public async Task<IViewComponentResult> InvokeAsync()
        {
            var settings = await _settingService.GetAllAsync();
            var phone = settings?.FirstOrDefault(s => s.Key == "Number")?.Value ?? "";
            var email = settings?.FirstOrDefault(s => s.Key == "Email")?.Value ?? "";
            ViewBag.Phone = phone;
            ViewBag.Email = email;
            return View();
        }
    }
}
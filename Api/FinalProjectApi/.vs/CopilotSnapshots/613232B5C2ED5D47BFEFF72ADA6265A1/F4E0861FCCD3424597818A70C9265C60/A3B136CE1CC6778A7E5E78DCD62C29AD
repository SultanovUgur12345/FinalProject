@using FinalProjectMVC.ViewModels.ShipHeroVideo
@inject IConfiguration Configuration
@model ShipHeroVideoGetVM

@{
    string apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
    string videoSrc = (Model != null && !string.IsNullOrWhiteSpace(Model.Video))
        ? $"{apiBaseUrl}{Model.Video}"
        : "https://seafarer.qodeinteractive.com/wp-content/uploads/2021/08/video-boat.mp4";
    string preTitle = Model?.SubTitle ?? "EXPLORE THE OCEAN";
    string title = Model?.Title ?? "RENT A YACHT";
}

<section id="video">
    <video class="video-bg" autoplay loop muted playsinline>
        <source src="@videoSrc" type="video/mp4">
    </video>
    <div class="video-caption">
        <div class="pre-title">@preTitle</div>
        <h2>@title</h2>
    </div>
</section>

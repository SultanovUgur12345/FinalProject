@{
    ViewData["Title"] = "Book Your Trip";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ── PAGE WRAPPER ── */
    .book-page {
        min-height: 100vh;
        background-color: #021527;
        background-image: url('https://seafarer.qodeinteractive.com/wp-content/uploads/2021/07/home-1-parallax-1.jpg');
        background-size: cover;
        background-attachment: fixed;
        background-position: center;
        padding-top: 160px;
        padding-bottom: 80px;
    }

    .book-page-inner {
        width: 82%;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* ── TOP BAR ── */
    .bk-bar {
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.18);
        display: flex;
        align-items: stretch;
        justify-content: space-between;
        padding: 0;
        margin-bottom: 14px;
        overflow: hidden;
    }

    .bk-bar-fields {
        display: flex;
        align-items: stretch;
        flex: 1;
    }

    .bk-field {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 18px 28px;
        cursor: pointer;
        position: relative;
        min-width: 160px;
        transition: background 0.15s;
        border: 2px solid transparent;
        border-radius: 6px;
    }

    .bk-field:hover {
        background: #f4f6fb;
    }

    .bk-field.bk-field--active {
        border-color: #1a3a6b;
        background: #f0f4fb;
    }

    .bk-field-label {
        font-family: 'Roboto', sans-serif;
        font-size: 11px;
        color: #8a97a8;
        text-transform: none;
        letter-spacing: 0.2px;
        margin-bottom: 3px;
    }

    .bk-field-value {
        font-family: 'Roboto', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: #0a1628;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .bk-field-value i {
        font-size: 11px;
        color: #8a97a8;
    }

    .bk-divider {
        width: 1px;
        background: #e2e8f0;
        margin: 14px 0;
        flex-shrink: 0;
    }

    /* ── PRICE + BUTTON ── */
    .bk-bar-right {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 16px 24px;
        flex-shrink: 0;
    }

    .bk-price-block {
        text-align: right;
    }

    .bk-price-label {
        font-family: 'Roboto', sans-serif;
        font-size: 11px;
        color: #8a97a8;
        display: block;
        margin-bottom: 2px;
    }

    .bk-price-main {
        font-family: 'Roboto', sans-serif;
        font-size: 20px;
        font-weight: 800;
        color: #0a1628;
        line-height: 1.1;
    }

    .bk-price-main span {
        font-size: 13px;
        font-weight: 400;
        color: #0a1628;
    }

    .bk-price-total {
        font-size: 12px;
        color: #0a1628;
        margin-top: 1px;
    }

    .bk-price-note {
        font-size: 11px;
        color: #8a97a8;
    }

    .bk-btn {
        background: #f5a623;
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 15px 30px;
        font-family: 'Roboto', sans-serif;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
        white-space: nowrap;
        letter-spacing: 0.3px;
    }

    .bk-btn:hover { background: #d48a0e; }

    /* ── DROPDOWN PANELS ── */
    .bk-panel {
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.15);
        display: none;
        position: relative;
        margin-bottom: 14px;
    }

    .bk-panel.bk-panel--open { display: block; }

    .bk-panel-close {
        position: absolute;
        top: 18px;
        right: 20px;
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: 1.5px solid #c8d0dc;
        background: transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        color: #5a6a7a;
        transition: all 0.15s;
    }

    .bk-panel-close:hover { background: #f0f4fb; }

    /* GUESTS PANEL */
    .bk-guests-panel { padding: 36px 40px 32px; }

    .bk-guests-panel h2 {
        font-family: 'Roboto', sans-serif;
        font-size: 22px;
        font-weight: 700;
        color: #0a1628;
        margin: 0 0 28px;
    }

    .bk-guests-row {
        display: flex;
        align-items: flex-start;
        gap: 32px;
        flex-wrap: wrap;
        margin-bottom: 24px;
    }

    .bk-guest-item { display: flex; align-items: center; gap: 0; }

    .bk-guest-info { margin-right: 20px; }

    .bk-guest-info strong {
        font-family: 'Roboto', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: #0a1628;
        display: block;
    }

    .bk-guest-info small {
        font-size: 12px;
        color: #8a97a8;
    }

    .bk-counter {
        display: flex;
        align-items: center;
        background: #f0f4fb;
        border-radius: 8px;
        overflow: hidden;
    }

    .bk-counter-btn {
        width: 40px;
        height: 44px;
        border: none;
        background: transparent;
        font-size: 18px;
        font-weight: 400;
        color: #4a6080;
        cursor: pointer;
        transition: background 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .bk-counter-btn:hover { background: #dde4f0; }

    .bk-counter-val {
        font-family: 'Roboto', sans-serif;
        font-size: 17px;
        font-weight: 600;
        color: #0a1628;
        min-width: 36px;
        text-align: center;
    }

    .bk-guests-note {
        font-family: 'Roboto', sans-serif;
        font-size: 13px;
        color: #4a80c4;
        font-style: italic;
        border-top: 1px solid #e8edf4;
        padding-top: 18px;
        margin-top: 8px;
    }

    /* DATE LIST PANEL */
    .bk-date-panel { padding: 36px 40px 28px; }

    .bk-date-panel-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 4px;
    }

    .bk-date-panel-title-block h2 {
        font-family: 'Roboto', sans-serif;
        font-size: 24px;
        font-weight: 700;
        color: #0a1628;
        margin: 0 0 4px;
    }

    .bk-date-panel-title-block p {
        font-size: 13px;
        color: #8a97a8;
        margin: 0;
    }

    .bk-view-tabs {
        display: flex;
        align-items: center;
        gap: 28px;
        margin-top: 4px;
    }

    .bk-view-tab {
        font-family: 'Roboto', sans-serif;
        font-size: 14px;
        color: #8a97a8;
        cursor: pointer;
        padding-bottom: 6px;
        border-bottom: 2px solid transparent;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: color 0.15s;
    }

    .bk-view-tab.bk-view-tab--active {
        color: #1a3a9e;
        border-bottom-color: #1a3a9e;
        font-weight: 600;
    }

    .bk-view-tab:hover { color: #1a3a9e; }

    /* DATE ROWS */
    .bk-date-list { margin-top: 28px; max-height: 360px; overflow-y: auto; }

    .bk-month-label {
        font-family: 'Roboto', sans-serif;
        font-size: 16px;
        font-weight: 700;
        color: #0a1628;
        margin: 0 0 8px;
        padding-bottom: 6px;
    }

    .bk-date-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 18px;
        border-radius: 5px;
        margin-bottom: 4px;
        cursor: pointer;
        background: #f4f7fb;
        border: 1.5px solid transparent;
        transition: all 0.15s;
    }

    .bk-date-row:hover { background: #eaeff8; }

    .bk-date-row--selected {
        background: #dde6f5;
        border-color: #1a3a9e;
    }

    .bk-date-range {
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: 'Roboto', sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #0a1628;
    }

    .bk-date-row--disabled .bk-date-range { color: #aab3c0; }
    .bk-date-row--disabled { cursor: default; }

    .bk-date-arrow { color: #8a97a8; font-size: 15px; }

    .bk-date-price {
        font-family: 'Roboto', sans-serif;
        font-size: 15px;
        font-weight: 700;
        color: #0a1628;
    }

    .bk-date-row--disabled .bk-date-price { color: #aab3c0; }

    .bk-month-sep { margin-bottom: 18px; }

    .bk-date-footer-note {
        font-family: 'Roboto', sans-serif;
        font-size: 13px;
        color: #4a80c4;
        font-style: italic;
        margin-top: 18px;
        padding-top: 16px;
        border-top: 1px solid #e8edf4;
    }

    /* SCROLLBAR */
    .bk-date-list::-webkit-scrollbar { width: 6px; }
    .bk-date-list::-webkit-scrollbar-track { background: #f0f4fb; border-radius: 3px; }
    .bk-date-list::-webkit-scrollbar-thumb { background: #c0ccd8; border-radius: 3px; }

    @@media (max-width: 900px) {
        .book-page-inner { width: 94%; }
        .bk-bar { flex-direction: column; }
        .bk-bar-fields { flex-direction: column; }
        .bk-divider { width: 100%; height: 1px; margin: 0; }
        .bk-bar-right { justify-content: space-between; }
        .bk-guests-panel, .bk-date-panel { padding: 24px 18px; }
    }
</style>
    /* =============================================
       BOOK PAGE STYLES
       ============================================= */

    .book-hero {
        position: relative;
        height: 420px;
        background: url('https://seafarer.qodeinteractive.com/wp-content/uploads/2021/10/h1-rev-img-1.jpg') center center / cover no-repeat;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .book-hero-overlay {
        position: absolute;
        inset: 0;
        background: rgba(10, 20, 40, 0.55);
    }

    .book-hero-content {
        position: relative;
        z-index: 1;
        color: #fff;
    }

    .book-hero-subtitle {
        display: block;
        font-family: 'Inconsolata', monospace;
        font-size: 13px;
        letter-spacing: 3px;
        color: #bfa888;
        margin-bottom: 14px;
    }

    .book-hero-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 58px;
        font-weight: 600;
        margin: 0 0 14px;
        line-height: 1.1;
    }

    .book-hero-desc {
        font-family: 'Roboto', sans-serif;
        font-size: 15px;
        color: rgba(255,255,255,0.75);
        margin: 0;
    }

    .book-section {
        background: #f7f5f2;
        padding: 60px 0 80px;
    }

    .book-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 24px;
    }

    /* TOP BAR */
    .book-topbar {
        background: #fff;
        border-radius: 4px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.08);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 28px;
        margin-bottom: 48px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .book-topbar-left {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
    }

    .book-select-box {
        position: relative;
        display: flex;
        flex-direction: column;
        padding: 0 28px;
    }

    .book-select-box:first-child {
        padding-left: 0;
    }

    .book-select-box label {
        font-family: 'Roboto', sans-serif;
        font-size: 11px;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 4px;
    }

    .book-select-box select {
        border: none;
        outline: none;
        background: transparent;
        font-family: 'Cormorant Garamond', serif;
        font-size: 17px;
        font-weight: 600;
        color: #1a2535;
        cursor: pointer;
        appearance: none;
        padding-right: 24px;
    }

    .book-select-icon {
        position: absolute;
        right: 12px;
        bottom: 4px;
        font-size: 11px;
        color: #888;
        pointer-events: none;
    }

    .book-divider-v {
        width: 1px;
        height: 44px;
        background: #e8e3db;
        flex-shrink: 0;
    }

    .book-topbar-right {
        display: flex;
        align-items: center;
        gap: 28px;
    }

    .book-price-info {
        text-align: right;
    }

    .book-starting-from {
        font-family: 'Roboto', sans-serif;
        font-size: 11px;
        color: #888;
        display: block;
    }

    .book-price-main {
        font-family: 'Cormorant Garamond', serif;
        font-size: 22px;
        font-weight: 700;
        color: #1a2535;
        line-height: 1.2;
    }

    .book-per-person {
        font-size: 14px;
        font-weight: 400;
    }

    .book-price-total {
        font-size: 13px;
        color: #555;
    }

    .book-price-note {
        font-size: 11px;
        color: #999;
    }

    .book-now-btn {
        background: #e8a020;
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: 14px 32px;
        font-family: 'Roboto', sans-serif;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        white-space: nowrap;
    }

    .book-now-btn:hover {
        background: #cf8c10;
    }

    /* LIST */
    .book-list-wrapper {
        background: #fff;
        border-radius: 4px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.07);
        padding: 36px 36px 28px;
    }

    .book-list-header {
        margin-bottom: 28px;
    }

    .book-list-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 30px;
        font-weight: 600;
        color: #1a2535;
        margin: 0 0 6px;
    }

    .book-list-subtitle {
        font-family: 'Roboto', sans-serif;
        font-size: 14px;
        color: #888;
        margin: 0;
    }

    .book-month-group {
        margin-bottom: 32px;
    }

    .book-month-label {
        font-family: 'Cormorant Garamond', serif;
        font-size: 20px;
        font-weight: 600;
        color: #1a2535;
        margin: 0 0 12px;
        padding-bottom: 8px;
        border-bottom: 1px solid #eee;
    }

    .book-date-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 18px 20px;
        border-radius: 4px;
        margin-bottom: 6px;
        cursor: pointer;
        transition: background 0.15s;
        border: 1.5px solid transparent;
    }

    .book-date-row:hover {
        background: #f0ede8;
    }

    .book-date-row--selected {
        background: #e8e4f0;
        border-color: #7b6fa0;
    }

    .book-date-range {
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: 'Roboto', sans-serif;
        font-size: 15px;
        color: #1a2535;
        font-weight: 500;
    }

    .book-arrow {
        color: #bfa888;
        font-size: 18px;
    }

    .book-date-price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 20px;
        font-weight: 700;
        color: #1a2535;
    }

    .book-footer-note {
        font-family: 'Roboto', sans-serif;
        font-size: 13px;
        color: #7b9fc7;
        margin-top: 24px;
        padding-top: 16px;
        border-top: 1px solid #eee;
    }

    @@media (max-width: 768px) {
        .book-hero-title { font-size: 36px; }
        .book-topbar { flex-direction: column; align-items: flex-start; }
        .book-topbar-right { flex-direction: column; align-items: flex-start; gap: 12px; }
        .book-price-info { text-align: left; }
        .book-select-box { padding: 8px 0; }
        .book-divider-v { display: none; }
        .book-list-wrapper { padding: 20px 16px; }
    }
</style>

<!-- BOOK PAGE -->
<div class="book-page">
    <div class="book-page-inner">

        <!-- ═══ TOP BAR ═══ -->
        <div class="bk-bar">
            <div class="bk-bar-fields">

                <!-- Departure Date -->
                <div class="bk-field bk-field--active" id="field-date" onclick="togglePanel('panel-date', 'field-date')">
                    <div class="bk-field-label">Departure date</div>
                    <div class="bk-field-value">
                        <span id="selected-date-display">May 18, 2026</span>
                        <i class="fas fa-chevron-down" id="icon-date"></i>
                    </div>
                </div>

                <div class="bk-divider"></div>

                <!-- Number of Guests -->
                <div class="bk-field" id="field-guests" onclick="togglePanel('panel-guests', 'field-guests')">
                    <div class="bk-field-label">Number of guests</div>
                    <div class="bk-field-value">
                        <span id="guest-display">1 Guest</span>
                        <i class="fas fa-chevron-down" id="icon-guests"></i>
                    </div>
                </div>

                <div class="bk-divider"></div>

                <!-- Room Type -->
                <div class="bk-field" id="field-room" onclick="togglePanel('panel-room', 'field-room')">
                    <div class="bk-field-label">Room type</div>
                    <div class="bk-field-value">
                        <span id="room-display">Interior</span>
                        <i class="fas fa-chevron-down" id="icon-room"></i>
                    </div>
                </div>

            </div>

            <!-- Price + Book Now -->
            <div class="bk-bar-right">
                <div class="bk-price-block">
                    <span class="bk-price-label">Starting from:</span>
                    <div class="bk-price-main">$2,749 USD <span>/person*</span></div>
                    <div class="bk-price-total">$2,749 Total/Room</div>
                    <div class="bk-price-note">*Taxes &amp; fees included</div>
                </div>
                <button class="bk-btn">Book now</button>
            </div>
        </div>

        <!-- ═══ GUESTS PANEL ═══ -->
        <div class="bk-panel" id="panel-guests">
            <div class="bk-guests-panel">
                <button class="bk-panel-close" onclick="closePanel('panel-guests','field-guests')">
                    <i class="fas fa-times"></i>
                </button>
                <h2>Select Number of Guests</h2>
                <div class="bk-guests-row">
                    <!-- Adults -->
                    <div class="bk-guest-item">
                        <div class="bk-guest-info">
                            <strong>Adults</strong>
                        </div>
                        <div class="bk-counter">
                            <button class="bk-counter-btn" onclick="changeCount('adults',-1)">−</button>
                            <span class="bk-counter-val" id="adults-val">1</span>
                            <button class="bk-counter-btn" onclick="changeCount('adults',1)">+</button>
                        </div>
                    </div>
                    <!-- Children -->
                    <div class="bk-guest-item">
                        <div class="bk-guest-info">
                            <strong>Children</strong>
                            <small>Ages 12 and under</small>
                        </div>
                        <div class="bk-counter">
                            <button class="bk-counter-btn" onclick="changeCount('children',-1)">−</button>
                            <span class="bk-counter-val" id="children-val">0</span>
                            <button class="bk-counter-btn" onclick="changeCount('children',1)">+</button>
                        </div>
                    </div>
                </div>
                <p class="bk-guests-note">If you have more than 4 guests, you can book multiple staterooms during the booking process.</p>
            </div>
        </div>

        <!-- ═══ DATE LIST PANEL ═══ -->
        <div class="bk-panel bk-panel--open" id="panel-date">
            <div class="bk-date-panel">
                <button class="bk-panel-close" onclick="closePanel('panel-date','field-date')">
                    <i class="fas fa-times"></i>
                </button>

                <div class="bk-date-panel-top">
                    <div class="bk-date-panel-title-block">
                        <h2>Select Departure Date</h2>
                        <p>Pricing shown is per person.</p>
                    </div>
                    <div class="bk-view-tabs">
                        <div class="bk-view-tab bk-view-tab--active">
                            <i class="fas fa-list"></i> List View
                        </div>
                        <div class="bk-view-tab">
                            <i class="fas fa-calendar"></i> Calendar View
                        </div>
                    </div>
                </div>

                <div class="bk-date-list">
                    <!-- MAY 2026 -->
                    <div class="bk-month-sep">
                        <div class="bk-month-label">May 2026</div>

                        <div class="bk-date-row" onclick="selectDate(this, 'May 11, 2026', '$1,608')">
                            <div class="bk-date-range">
                                <span>Monday, May 11</span>
                                <span class="bk-date-arrow">→</span>
                                <span>Friday, May 15</span>
                            </div>
                            <div class="bk-date-price">$1,608</div>
                        </div>

                        <div class="bk-date-row bk-date-row--selected" onclick="selectDate(this, 'May 18, 2026', '$2,749')">
                            <div class="bk-date-range">
                                <span>Monday, May 18</span>
                                <span class="bk-date-arrow">→</span>
                                <span>Friday, May 22</span>
                            </div>
                            <div class="bk-date-price">$2,749</div>
                        </div>

                        <div class="bk-date-row" onclick="selectDate(this, 'May 25, 2026', '$2,073')">
                            <div class="bk-date-range">
                                <span>Monday, May 25</span>
                                <span class="bk-date-arrow">→</span>
                                <span>Friday, May 29</span>
                            </div>
                            <div class="bk-date-price">$2,073</div>
                        </div>
                    </div>

                    <!-- JUNE 2026 -->
                    <div class="bk-month-sep">
                        <div class="bk-month-label">June 2026</div>

                        <div class="bk-date-row" onclick="selectDate(this, 'June 1, 2026', '$2,426')">
                            <div class="bk-date-range">
                                <span>Monday, June 1</span>
                                <span class="bk-date-arrow">→</span>
                                <span>Friday, June 5</span>
                            </div>
                            <div class="bk-date-price">$2,426</div>
                        </div>

                        <div class="bk-date-row bk-date-row--disabled" onclick="return">
                            <div class="bk-date-range">
                                <span>Monday, June 8</span>
                                <span class="bk-date-arrow">→</span>
                                <span>Friday, June 12</span>
                            </div>
                            <div class="bk-date-price">$2,368</div>
                        </div>
                    </div>
                </div>

                <p class="bk-date-footer-note">Departure date may affect your destination sequence.</p>
            </div>
        </div>

    </div>
</div>

<script>
    var adults = 1, children = 0;

    function togglePanel(panelId, fieldId) {
        var allPanels = ['panel-date', 'panel-guests', 'panel-room'];
        var allFields = ['field-date', 'field-guests', 'field-room'];

        allPanels.forEach(function (p) {
            if (p !== panelId) {
                document.getElementById(p).classList.remove('bk-panel--open');
            }
        });
        allFields.forEach(function (f) {
            if (f !== fieldId) {
                document.getElementById(f).classList.remove('bk-field--active');
            }
        });

        var panel = document.getElementById(panelId);
        var field = document.getElementById(fieldId);
        var isOpen = panel.classList.contains('bk-panel--open');

        if (isOpen) {
            panel.classList.remove('bk-panel--open');
            field.classList.remove('bk-field--active');
        } else {
            panel.classList.add('bk-panel--open');
            field.classList.add('bk-field--active');
        }
    }

    function closePanel(panelId, fieldId) {
        event.stopPropagation();
        document.getElementById(panelId).classList.remove('bk-panel--open');
        document.getElementById(fieldId).classList.remove('bk-field--active');
    }

    function selectDate(row, dateStr, price) {
        if (row.classList.contains('bk-date-row--disabled')) return;
        document.querySelectorAll('.bk-date-row').forEach(function (r) {
            r.classList.remove('bk-date-row--selected');
        });
        row.classList.add('bk-date-row--selected');
        document.getElementById('selected-date-display').textContent = dateStr;
    }

    function changeCount(type, delta) {
        event.stopPropagation();
        if (type === 'adults') {
            adults = Math.max(1, adults + delta);
            document.getElementById('adults-val').textContent = adults;
        } else {
            children = Math.max(0, children + delta);
            document.getElementById('children-val').textContent = children;
        }
        var total = adults + children;
        document.getElementById('guest-display').textContent = total === 1 ? '1 Guest' : total + ' Guests';
    }
</script>

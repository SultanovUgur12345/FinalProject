@{
    ViewData["Title"] = "Book Your Trip";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ── PAGE ── */
    .bk-page {
        min-height: 100vh;
        background-color: #021527;
        background-image: url('https://seafarer.qodeinteractive.com/wp-content/uploads/2021/07/home-1-parallax-1.jpg');
        background-size: cover;
        background-attachment: fixed;
        background-position: center;
        padding-top: 170px;
        padding-bottom: 100px;
    }
    .bk-wrap {
        width: 80%;
        max-width: 1160px;
        margin: 0 auto;
    }

    /* ── TOP BAR ── */
    .bk-topbar {
        background: rgba(2,21,39,0.72);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(191,168,136,0.18);
        border-radius: 6px;
        display: flex;
        align-items: stretch;
        margin-bottom: 10px;
        overflow: visible;
        position: relative;
    }
    .bk-fields {
        display: flex;
        align-items: stretch;
        flex: 1;
    }
    .bk-field {
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 20px 30px;
        cursor: pointer;
        position: relative;
        border: 2px solid transparent;
        border-radius: 6px;
        transition: border-color 0.2s, background 0.2s;
        min-width: 170px;
    }
    .bk-field:hover { background: rgba(191,168,136,0.06); }
    .bk-field.is-active { border-color: #bfa888; background: rgba(191,168,136,0.10); }

    .bk-field-label {
        font-family: 'Roboto', sans-serif;
        font-size: 11px;
        color: rgba(191,168,136,0.75);
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }
    .bk-field-val {
        font-family: 'Cormorant Garamond', serif;
        font-size: 17px;
        font-weight: 600;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .bk-field-val i { font-size: 11px; color: rgba(191,168,136,0.7); }

    .bk-sep {
        width: 1px;
        background: rgba(191,168,136,0.18);
        margin: 16px 0;
        flex-shrink: 0;
    }

    /* price + btn */
    .bk-right {
        display: flex;
        align-items: center;
        gap: 22px;
        padding: 16px 24px;
        flex-shrink: 0;
    }
    .bk-price-block { text-align: right; }
    .bk-price-from {
        font-family: 'Roboto', sans-serif;
        font-size: 11px;
        color: rgba(255,255,255,0.55);
        display: block;
        margin-bottom: 2px;
    }
    .bk-price-usd {
        font-family: 'Roboto', sans-serif;
        font-size: 20px;
        font-weight: 800;
        color: #fff;
        line-height: 1.1;
    }
    .bk-price-usd em { font-size: 13px; font-weight: 400; font-style: normal; }
    .bk-price-total { font-size: 12px; color: rgba(255,255,255,0.7); margin-top: 1px; }
    .bk-price-note  { font-size: 11px; color: rgba(255,255,255,0.4); }
    .bk-book-btn {
        background: #d6c09b;
        color: #021527;
        border: none;
        border-radius: 999px;
        padding: 14px 30px;
        font-family: 'Roboto', sans-serif;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        cursor: pointer;
        white-space: nowrap;
        transition: background 0.2s, transform 0.2s;
    }
    .bk-book-btn:hover { background: #c4a86f; transform: translateY(-1px); }

    /* ── PANELS ── */
    .bk-panel {
        background: rgba(2,21,39,0.88);
        backdrop-filter: blur(18px);
        border: 1px solid rgba(191,168,136,0.18);
        border-radius: 6px;
        display: none;
        position: relative;
        margin-bottom: 10px;
    }
    .bk-panel.is-open { display: block; }

    .bk-panel-x {
        position: absolute;
        top: 16px; right: 18px;
        width: 32px; height: 32px;
        border-radius: 50%;
        border: 1.5px solid rgba(191,168,136,0.35);
        background: transparent;
        color: rgba(255,255,255,0.7);
        font-size: 14px;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: border-color 0.15s, color 0.15s;
    }
    .bk-panel-x:hover { border-color: #bfa888; color: #bfa888; }

    /* GUESTS PANEL */
    .bk-gp { padding: 38px 40px 30px; }
    .bk-gp h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 26px;
        font-weight: 600;
        color: #fff;
        margin: 0 0 30px;
    }
    .bk-gp-row {
        display: flex;
        align-items: center;
        gap: 40px;
        flex-wrap: wrap;
        margin-bottom: 28px;
    }
    .bk-gp-item { display: flex; align-items: center; gap: 20px; }
    .bk-gp-info strong {
        font-family: 'Roboto', sans-serif;
        font-size: 15px;
        font-weight: 600;
        color: #fff;
        display: block;
    }
    .bk-gp-info small { font-size: 12px; color: rgba(191,168,136,0.7); }
    .bk-counter {
        display: flex; align-items: center;
        background: rgba(191,168,136,0.12);
        border: 1px solid rgba(191,168,136,0.25);
        border-radius: 8px; overflow: hidden;
    }
    .bk-cnt-btn {
        width: 40px; height: 44px;
        border: none; background: transparent;
        font-size: 20px; font-weight: 300;
        color: #bfa888;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.15s;
    }
    .bk-cnt-btn:hover { background: rgba(191,168,136,0.18); }
    .bk-cnt-val {
        font-family: 'Cormorant Garamond', serif;
        font-size: 20px; font-weight: 600;
        color: #fff;
        min-width: 40px;
        text-align: center;
    }
    .bk-gp-note {
        font-family: 'Roboto', sans-serif;
        font-size: 13px;
        color: rgba(191,168,136,0.8);
        font-style: italic;
        border-top: 1px solid rgba(191,168,136,0.15);
        padding-top: 16px;
    }

    /* DATE LIST PANEL */
    .bk-dp { padding: 38px 40px 28px; }
    .bk-dp-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 6px;
    }
    .bk-dp-head h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 26px; font-weight: 600;
        color: #fff; margin: 0 0 4px;
    }
    .bk-dp-head p { font-size: 13px; color: rgba(191,168,136,0.7); margin: 0; }

    /* LIST VIEW tab only — calendar view hissəsi yoxdur */
    .bk-tab-active {
        font-family: 'Roboto', sans-serif;
        font-size: 14px;
        font-weight: 600;
        color: #bfa888;
        border-bottom: 2px solid #bfa888;
        padding-bottom: 4px;
        display: flex; align-items: center; gap: 7px;
        margin-top: 6px;
        padding-right: 4px;
    }

    .bk-date-list {
        margin-top: 24px;
        max-height: 360px;
        overflow-y: auto;
        padding-right: 4px;
    }
    .bk-date-list::-webkit-scrollbar { width: 4px; }
    .bk-date-list::-webkit-scrollbar-track { background: rgba(191,168,136,0.07); border-radius: 2px; }
    .bk-date-list::-webkit-scrollbar-thumb { background: rgba(191,168,136,0.35); border-radius: 2px; }

    .bk-month-grp { margin-bottom: 24px; }
    .bk-month-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 18px; font-weight: 600;
        color: #fff;
        margin: 0 0 10px;
        padding-bottom: 8px;
        border-bottom: 1px solid rgba(191,168,136,0.15);
    }

    .bk-drow {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 18px;
        border-radius: 4px;
        margin-bottom: 4px;
        cursor: pointer;
        background: rgba(255,255,255,0.04);
        border: 1.5px solid transparent;
        transition: all 0.15s;
    }
    .bk-drow:hover { background: rgba(191,168,136,0.10); }
    .bk-drow.is-sel {
        background: rgba(191,168,136,0.15);
        border-color: #bfa888;
    }
    .bk-drow.is-dis { cursor: default; opacity: 0.4; }
    .bk-drow-range {
        display: flex; align-items: center; gap: 12px;
        font-family: 'Roboto', sans-serif;
        font-size: 14px; font-weight: 500; color: #fff;
    }
    .bk-drow-arr { color: rgba(191,168,136,0.7); font-size: 15px; }
    .bk-drow-price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 18px; font-weight: 700; color: #d6c09b;
    }
    .bk-drow.is-dis .bk-drow-price { color: rgba(191,168,136,0.4); }

    .bk-dp-note {
        font-family: 'Roboto', sans-serif;
        font-size: 13px;
        color: rgba(191,168,136,0.7);
        font-style: italic;
        margin-top: 16px;
        padding-top: 14px;
        border-top: 1px solid rgba(191,168,136,0.15);
    }

    /* ROOM PANEL */
    .bk-rp { padding: 38px 40px 30px; }
    .bk-rp h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 26px; font-weight: 600;
        color: #fff; margin: 0 0 24px;
    }
    .bk-room-list { display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px; }
    .bk-room-item {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px;
        border-radius: 4px;
        background: rgba(255,255,255,0.04);
        border: 1.5px solid transparent;
        cursor: pointer;
        transition: all 0.15s;
    }
    .bk-room-item:hover { background: rgba(191,168,136,0.10); }
    .bk-room-item.is-sel { background: rgba(191,168,136,0.15); border-color: #bfa888; }
    .bk-room-name {
        font-family: 'Roboto', sans-serif;
        font-size: 15px; font-weight: 600; color: #fff;
    }
    .bk-room-price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 18px; font-weight: 700; color: #d6c09b;
    }

    @@media (max-width: 900px) {
        .bk-wrap { width: 94%; }
        .bk-topbar { flex-direction: column; }
        .bk-fields { flex-direction: column; }
        .bk-sep { width: 100%; height: 1px; margin: 0; }
        .bk-right { justify-content: space-between; }
        .bk-gp, .bk-dp, .bk-rp { padding: 24px 18px; }
    }
</style>

<div class="bk-page">
    <div class="bk-wrap">

        <!-- ═══ TOP BAR ═══ -->
        <div class="bk-topbar">
            <div class="bk-fields">

                <div class="bk-field is-active" id="f-date" onclick="openPanel('p-date','f-date')">
                    <div class="bk-field-label">Departure date</div>
                    <div class="bk-field-val">
                        <span id="disp-date">May 18, 2026</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                </div>

                <div class="bk-sep"></div>

                <div class="bk-field" id="f-guests" onclick="openPanel('p-guests','f-guests')">
                    <div class="bk-field-label">Number of guests</div>
                    <div class="bk-field-val">
                        <span id="disp-guests">1 Guest</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                </div>

                <div class="bk-sep"></div>

                <div class="bk-field" id="f-room" onclick="openPanel('p-room','f-room')">
                    <div class="bk-field-label">Room type</div>
                    <div class="bk-field-val">
                        <span id="disp-room">Interior</span>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                </div>

            </div>
            <div class="bk-right">
                <div class="bk-price-block">
                    <span class="bk-price-from">Starting from:</span>
                    <div class="bk-price-usd">$2,749 USD <em>/person*</em></div>
                    <div class="bk-price-total">$2,749 Total/Room</div>
                    <div class="bk-price-note">*Taxes &amp; fees included</div>
                </div>
                <button class="bk-book-btn">Book now</button>
            </div>
        </div>

        <!-- ═══ DATE PANEL ═══ -->
        <div class="bk-panel is-open" id="p-date">
            <div class="bk-dp">
                <button class="bk-panel-x" onclick="closePanel('p-date','f-date')"><i class="fas fa-times"></i></button>
                <div class="bk-dp-head">
                    <div>
                        <h2>Select Departure Date</h2>
                        <p>Pricing shown is per person.</p>
                    </div>
                    <div class="bk-tab-active"><i class="fas fa-list"></i> List View</div>
                </div>
                <div class="bk-date-list">
                    <div class="bk-month-grp">
                        <div class="bk-month-title">May 2026</div>
                        <div class="bk-drow" onclick="selDate(this,'May 11, 2026','$1,608')">
                            <div class="bk-drow-range"><span>Monday, May 11</span><span class="bk-drow-arr">→</span><span>Friday, May 15</span></div>
                            <div class="bk-drow-price">$1,608</div>
                        </div>
                        <div class="bk-drow is-sel" onclick="selDate(this,'May 18, 2026','$2,749')">
                            <div class="bk-drow-range"><span>Monday, May 18</span><span class="bk-drow-arr">→</span><span>Friday, May 22</span></div>
                            <div class="bk-drow-price">$2,749</div>
                        </div>
                        <div class="bk-drow" onclick="selDate(this,'May 25, 2026','$2,073')">
                            <div class="bk-drow-range"><span>Monday, May 25</span><span class="bk-drow-arr">→</span><span>Friday, May 29</span></div>
                            <div class="bk-drow-price">$2,073</div>
                        </div>
                    </div>
                    <div class="bk-month-grp">
                        <div class="bk-month-title">June 2026</div>
                        <div class="bk-drow" onclick="selDate(this,'June 1, 2026','$2,426')">
                            <div class="bk-drow-range"><span>Monday, June 1</span><span class="bk-drow-arr">→</span><span>Friday, June 5</span></div>
                            <div class="bk-drow-price">$2,426</div>
                        </div>
                        <div class="bk-drow is-dis">
                            <div class="bk-drow-range"><span>Monday, June 8</span><span class="bk-drow-arr">→</span><span>Friday, June 12</span></div>
                            <div class="bk-drow-price">$2,368</div>
                        </div>
                    </div>
                </div>
                <p class="bk-dp-note">Departure date may affect your destination sequence.</p>
            </div>
        </div>

        <!-- ═══ GUESTS PANEL ═══ -->
        <div class="bk-panel" id="p-guests">
            <div class="bk-gp">
                <button class="bk-panel-x" onclick="closePanel('p-guests','f-guests')"><i class="fas fa-times"></i></button>
                <h2>Select Number of Guests</h2>
                <div class="bk-gp-row">
                    <div class="bk-gp-item">
                        <div class="bk-gp-info"><strong>Adults</strong></div>
                        <div class="bk-counter">
                            <button class="bk-cnt-btn" onclick="chg('adults',-1)">−</button>
                            <span class="bk-cnt-val" id="v-adults">1</span>
                            <button class="bk-cnt-btn" onclick="chg('adults',1)">+</button>
                        </div>
                    </div>
                    <div class="bk-gp-item">
                        <div class="bk-gp-info"><strong>Children</strong><small>Ages 12 and under</small></div>
                        <div class="bk-counter">
                            <button class="bk-cnt-btn" onclick="chg('children',-1)">−</button>
                            <span class="bk-cnt-val" id="v-children">0</span>
                            <button class="bk-cnt-btn" onclick="chg('children',1)">+</button>
                        </div>
                    </div>
                </div>
                <p class="bk-gp-note">If you have more than 4 guests, you can book multiple staterooms during the booking process.</p>
            </div>
        </div>

        <!-- ═══ ROOM PANEL ═══ -->
        <div class="bk-panel" id="p-room">
            <div class="bk-rp">
                <button class="bk-panel-x" onclick="closePanel('p-room','f-room')"><i class="fas fa-times"></i></button>
                <h2>Select Room Type</h2>
                <div class="bk-room-list">
                    <div class="bk-room-item is-sel" onclick="selRoom(this,'Interior','$2,749')">
                        <span class="bk-room-name">Interior</span>
                        <span class="bk-room-price">$2,749</span>
                    </div>
                    <div class="bk-room-item" onclick="selRoom(this,'Ocean View','$3,120')">
                        <span class="bk-room-name">Ocean View</span>
                        <span class="bk-room-price">$3,120</span>
                    </div>
                    <div class="bk-room-item" onclick="selRoom(this,'Balcony','$3,850')">
                        <span class="bk-room-name">Balcony</span>
                        <span class="bk-room-price">$3,850</span>
                    </div>
                    <div class="bk-room-item" onclick="selRoom(this,'Suite','$5,200')">
                        <span class="bk-room-name">Suite</span>
                        <span class="bk-room-price">$5,200</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
    var adults = 1, children = 0;

    function openPanel(pid, fid) {
        ['p-date','p-guests','p-room'].forEach(function(p){ document.getElementById(p).classList.remove('is-open'); });
        ['f-date','f-guests','f-room'].forEach(function(f){ document.getElementById(f).classList.remove('is-active'); });
        var panel = document.getElementById(pid);
        var field = document.getElementById(fid);
        panel.classList.add('is-open');
        field.classList.add('is-active');
    }

    function closePanel(pid, fid) {
        event.stopPropagation();
        document.getElementById(pid).classList.remove('is-open');
        document.getElementById(fid).classList.remove('is-active');
    }

    function selDate(row, d, p) {
        if (row.classList.contains('is-dis')) return;
        document.querySelectorAll('.bk-drow').forEach(function(r){ r.classList.remove('is-sel'); });
        row.classList.add('is-sel');
        document.getElementById('disp-date').textContent = d;
    }

    function chg(type, delta) {
        event.stopPropagation();
        if (type === 'adults') { adults = Math.max(1, adults + delta); document.getElementById('v-adults').textContent = adults; }
        else { children = Math.max(0, children + delta); document.getElementById('v-children').textContent = children; }
        var t = adults + children;
        document.getElementById('disp-guests').textContent = t === 1 ? '1 Guest' : t + ' Guests';
    }

    function selRoom(item, name, price) {
        document.querySelectorAll('.bk-room-item').forEach(function(i){ i.classList.remove('is-sel'); });
        item.classList.add('is-sel');
        document.getElementById('disp-room').textContent = name;
    }
</script>

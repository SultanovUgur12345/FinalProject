@{
    ViewData["Title"] = "Cruises";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Roboto:wght@300;400;500&family=Inconsolata:wght@400;500&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    .tk-page {
        min-height: 100vh;
        background-color: #021527;
        padding-top: 140px;
        padding-bottom: 80px;
        font-family: 'Roboto', sans-serif;
        color: #fff;
    }

    /* Hero */
    .tk-hero {
        position: relative;
        width: 100%; height: 320px;
        margin-bottom: 60px; overflow: hidden;
    }
    .tk-hero img {
        width: 100%; height: 100%;
        object-fit: cover; opacity: 0.35;
    }
    .tk-hero-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to bottom, rgba(2,21,39,0.3) 0%, rgba(2,21,39,0.85) 100%);
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center; padding: 20px;
    }
    .tk-hero-label {
        font-family: 'Inconsolata', monospace;
        font-size: 12px; letter-spacing: 4px;
        text-transform: uppercase; color: #bfa888; margin-bottom: 14px;
    }
    .tk-hero-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(38px, 6vw, 64px);
        font-weight: 300; color: #fff;
        letter-spacing: 2px; line-height: 1.1;
    }
    .tk-hero-title span { color: #bfa888; font-style: italic; }

    /* Grid */
    .tk-grid {
        max-width: 1160px; margin: 0 auto;
        padding: 0 24px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
        gap: 32px;
    }

    /* Card */
    .tk-card {
        position: relative;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(191,168,136,0.15);
        overflow: hidden; cursor: pointer;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        text-decoration: none; display: block; color: inherit;
    }
    .tk-card:hover {
        transform: translateY(-6px);
        border-color: rgba(191,168,136,0.5);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        text-decoration: none; color: inherit;
    }

    /* Sold Out */
    .tk-card.sold-out { opacity: 0.78; }
    .tk-card.sold-out:hover {
        transform: translateY(-5px);
        border-color: rgba(255,100,100,0.4);
        box-shadow: 0 16px 40px rgba(0,0,0,0.45);
    }

    .tk-card-img {
        position: relative; width: 100%; height: 220px; overflow: hidden;
    }
    .tk-card-img img {
        width: 100%; height: 100%;
        object-fit: cover; transition: transform 0.6s ease;
    }
    .tk-card:hover .tk-card-img img { transform: scale(1.07); }

    /* Sold out overlay on image */
    .tk-sold-overlay {
        position: absolute; inset: 0;
        background: rgba(2,21,39,0.45);
        display: flex; align-items: center; justify-content: center;
    }
    .tk-sold-stamp {
        border: 2px solid rgba(255,100,100,0.75);
        color: #ff8a8a;
        font-family: 'Inconsolata', monospace;
        font-size: 13px; letter-spacing: 4px;
        text-transform: uppercase;
        padding: 8px 22px;
        backdrop-filter: blur(4px);
        background: rgba(180,40,40,0.2);
        transform: rotate(-12deg);
    }

    /* Badges */
    .tk-card-badge {
        position: absolute; top: 16px; left: 16px;
        background: rgba(2,21,39,0.85);
        border: 1px solid rgba(191,168,136,0.5);
        padding: 4px 12px;
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 2px;
        text-transform: uppercase; color: #bfa888;
        backdrop-filter: blur(6px);
    }

    /* Card body */
    .tk-card-body { padding: 24px 22px 20px; }
    .tk-card-route {
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 3px;
        text-transform: uppercase; color: #bfa888; margin-bottom: 10px;
    }
    .tk-card-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 24px; font-weight: 500;
        color: #fff; line-height: 1.2; margin-bottom: 14px;
    }
    .tk-card-meta {
        display: flex; gap: 20px; margin-bottom: 18px; flex-wrap: wrap;
    }
    .tk-card-meta-item {
        display: flex; align-items: center; gap: 6px;
        font-size: 12px; color: rgba(255,255,255,0.55);
    }
    .tk-card-meta-item i { color: #bfa888; font-size: 11px; }
    .tk-card-divider {
        width: 100%; height: 1px;
        background: rgba(191,168,136,0.15); margin-bottom: 18px;
    }
    .tk-card-footer {
        display: flex; align-items: flex-end; justify-content: space-between;
    }
    .tk-card-price-label {
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 2px;
        text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 4px;
    }
    .tk-card-price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 28px; font-weight: 600;
        color: #d6c09b; line-height: 1;
    }
    .tk-card-price sup { font-size: 14px; font-weight: 400; vertical-align: super; }

    /* Sold out price */
    .tk-card-price.sold-price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 14px; color: rgba(255,138,138,0.7);
        letter-spacing: 1px; text-decoration: line-through;
        font-weight: 400;
    }
    .tk-sold-note {
        font-family: 'Inconsolata', monospace;
        font-size: 10px; color: #ff8a8a;
        letter-spacing: 2px; text-transform: uppercase;
        margin-top: 3px;
    }

    .tk-card-btn {
        padding: 10px 20px; background: transparent;
        border: 1px solid rgba(191,168,136,0.45);
        color: #bfa888;
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 2px;
        text-transform: uppercase;
        transition: all 0.25s ease;
        display: flex; align-items: center; gap: 8px;
        white-space: nowrap;
    }
    .tk-card:hover .tk-card-btn {
        background: rgba(191,168,136,0.15);
        border-color: #bfa888; color: #fff;
    }
    .tk-card-btn i { font-size: 10px; transition: transform 0.25s ease; }
    .tk-card:hover .tk-card-btn i { transform: translateX(4px); }

    .tk-card-btn.btn-soldout {
        border-color: rgba(255,100,100,0.35);
        color: rgba(255,138,138,0.8);
    }
    .tk-card.sold-out:hover .tk-card-btn.btn-soldout {
        background: rgba(180,40,40,0.12);
        border-color: rgba(255,100,100,0.6);
        color: #ffb3b3;
    }

    /* ── Search Bar ── */
    .tk-search-wrap {
        max-width: 1060px;
        margin: 0 auto 56px;
        padding: 0 24px;
    }
    .tk-search-bar {
        display: flex;
        align-items: stretch;
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.35);
        overflow: hidden;
    }
    .tk-sf {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 14px 24px;
        border-right: 1px solid #e0e0e0;
        cursor: pointer;
        background: #fff;
        transition: background 0.2s;
        user-select: none;
    }
    .tk-sf:hover { background: #f5f8ff; }
    .tk-sf-label {
        font-size: 11px; font-weight: 500; color: #555;
        margin-bottom: 4px; font-family: 'Roboto', sans-serif; letter-spacing: 0.3px;
    }
    .tk-sf-val {
        display: flex; align-items: center; justify-content: space-between;
        font-size: 15px; font-weight: 600; color: #1a3e8c;
        font-family: 'Roboto', sans-serif; gap: 8px;
    }
    .tk-sf-val i { font-size: 13px; color: #1a3e8c; }
    .tk-search-btn {
        background: #1a3e8c; color: #fff; border: none;
        padding: 0 32px; font-size: 15px; font-weight: 600;
        font-family: 'Roboto', sans-serif; cursor: pointer;
        transition: background 0.2s; white-space: nowrap;
    }
    .tk-search-btn:hover { background: #0f2860; }

    /* ── Modals ── */
    .tk-modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(0,0,0,0.45); z-index: 1000;
        align-items: center; justify-content: center;
    }
    .tk-modal-overlay.open { display: flex; }
    .tk-modal {
        background: #fff; border-radius: 8px;
        width: 860px; max-width: 96vw;
        box-shadow: 0 16px 60px rgba(0,0,0,0.3);
        display: flex; flex-direction: column;
        max-height: 90vh; overflow: hidden;
        font-family: 'Roboto', sans-serif;
    }
    .tk-modal-head {
        display: flex; align-items: center; justify-content: space-between;
        padding: 20px 28px 0; border-bottom: 1px solid #e8e8e8; padding-bottom: 0;
    }
    .tk-modal-head h2 {
        font-size: 20px; font-weight: 600; color: #111;
        font-family: 'Roboto', sans-serif; padding-bottom: 16px;
    }
    .tk-modal-close {
        background: none; border: none; font-size: 22px;
        color: #1a73e8; cursor: pointer; padding: 0 0 16px; line-height: 1;
    }
    /* Tabs */
    .tk-modal-tabs {
        display: flex; border-bottom: 2px solid #e8e8e8;
        padding: 0 28px; margin-bottom: 0;
    }
    .tk-modal-tab {
        padding: 14px 0; margin-right: 28px;
        font-size: 14px; font-weight: 500; color: #888;
        border-bottom: 2px solid transparent; margin-bottom: -2px;
        cursor: pointer; transition: all 0.2s;
    }
    .tk-modal-tab.active { color: #1a3e8c; border-bottom-color: #1a3e8c; font-weight: 600; }
    /* Tab panels */
    .tk-modal-body { padding: 24px 28px; overflow-y: auto; flex: 1; }
    .tk-tab-panel { display: none; }
    .tk-tab-panel.active { display: block; }
    /* Section headings */
    .tk-modal-section-title {
        font-size: 15px; font-weight: 700; color: #1a3e8c;
        margin-bottom: 14px;
    }
    /* Pills */
    .tk-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 28px; }
    .tk-pill {
        padding: 8px 18px; border-radius: 50px;
        border: 1.5px solid #1a3e8c; color: #1a3e8c;
        font-size: 13px; font-weight: 500; cursor: pointer;
        transition: all 0.2s; background: #fff; white-space: nowrap;
    }
    .tk-pill:hover { background: #eef2fc; }
    .tk-pill.active { background: #1a3e8c; color: #fff; }
    .tk-pill.disabled { opacity: 0.38; pointer-events: none; border-color: #bbb; color: #aaa; }

    /* Month calendar grid */
    .tk-year-block { margin-bottom: 28px; }
    .tk-year-label {
        font-size: 16px; font-weight: 700; color: #1a3e8c;
        text-align: center; margin-bottom: 12px;
    }
    .tk-months-grid {
        display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;
    }
    .tk-month-btn {
        padding: 9px 6px; border-radius: 50px;
        border: 1.5px solid #1a3e8c; color: #1a3e8c;
        font-size: 13px; font-weight: 500; cursor: pointer;
        text-align: center; transition: all 0.2s; background: #fff;
    }
    .tk-month-btn:hover { background: #eef2fc; }
    .tk-month-btn.active { background: #1a3e8c; color: #fff; }
    .tk-month-btn.disabled { opacity: 0.35; pointer-events: none; border-color: #ccc; color: #aaa; }
    .tk-years-row { display: flex; gap: 12px; }
    .tk-years-row .tk-year-block { flex: 1; }

    /* Modal footer */
    .tk-modal-foot {
        background: #f5f5f5; padding: 16px 28px;
        display: flex; align-items: center; justify-content: space-between;
        border-top: 1px solid #e8e8e8;
    }
    .tk-foot-selected { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .tk-foot-label { font-size: 13px; color: #555; margin-right: 4px; }
    .tk-foot-tag {
        display: flex; align-items: center; gap: 6px;
        background: #1a3e8c; color: #fff; border-radius: 50px;
        padding: 5px 14px; font-size: 13px; font-weight: 500;
    }
    .tk-foot-tag button {
        background: none; border: none; color: #fff;
        cursor: pointer; font-size: 14px; padding: 0; line-height: 1;
    }
    .tk-foot-actions { display: flex; gap: 12px; }
    .tk-foot-reset {
        padding: 9px 22px; border: 1.5px solid #1a3e8c;
        background: #fff; color: #1a3e8c; border-radius: 4px;
        font-size: 14px; font-weight: 500; cursor: pointer;
        transition: background 0.2s;
    }
    .tk-foot-reset:hover { background: #eef2fc; }
    .tk-foot-apply {
        padding: 9px 28px; background: #1a3e8c;
        color: #fff; border: none; border-radius: 4px;
        font-size: 14px; font-weight: 600; cursor: pointer;
        transition: background 0.2s;
    }
    .tk-foot-apply:hover { background: #0f2860; }

    @@media (max-width: 768px) {
        .tk-search-bar { flex-direction: column; }
        .tk-sf { border-right: none; border-bottom: 1px solid #e0e0e0; }
        .tk-search-btn { padding: 14px; }
        .tk-grid { grid-template-columns: 1fr; }
        .tk-hero { height: 240px; }
        .tk-modal { width: 98vw; }
        .tk-years-row { flex-direction: column; }
    }
</style>

<div class="tk-page">

    <!-- Hero -->
    <div class="tk-hero">
        <img src="https://images.unsplash.com/photo-1548438294-1ad5d5f4f063?w=1600&q=80" alt="Cruises" />
        <div class="tk-hero-overlay">
            <div class="tk-hero-label">Luxury at Sea</div>
            <h1 class="tk-hero-title">Our <span>Cruise</span> Packages</h1>
        </div>
    </div>

    <!-- Cards -->
    <div class="tk-search-wrap">
        <div class="tk-search-bar">

            <!-- Cruising to -->
            <div class="tk-sf" onclick="toggleDrop('drop-to')">
                <div class="tk-sf-label">Cruising to</div>
                <div class="tk-sf-val">
                    <span id="val-to">Anywhere</span>
                    <i class="fa fa-chevron-down"></i>
                </div>
                <div class="tk-sf-dropdown" id="drop-to">
                    <div class="tk-sf-dropdown-item selected" onclick="pickVal(event,'val-to','Anywhere','drop-to')">Anywhere</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-to','Mediterranean','drop-to')">Mediterranean</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-to','Caribbean','drop-to')">Caribbean</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-to','Atlantic','drop-to')">Atlantic</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-to','Adriatic','drop-to')">Adriatic</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-to','Nordic','drop-to')">Nordic</div>
                </div>
            </div>

            <!-- Leaving from -->
            <div class="tk-sf" onclick="toggleDrop('drop-from')">
                <div class="tk-sf-label">Leaving from</div>
                <div class="tk-sf-val">
                    <span id="val-from">Any port</span>
                    <i class="fa fa-chevron-down"></i>
                </div>
                <div class="tk-sf-dropdown" id="drop-from">
                    <div class="tk-sf-dropdown-item selected" onclick="pickVal(event,'val-from','Any port','drop-from')">Any port</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-from','Barcelona','drop-from')">Barcelona</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-from','Miami','drop-from')">Miami</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-from','Lisbon','drop-from')">Lisbon</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-from','Athens','drop-from')">Athens</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-from','Southampton','drop-from')">Southampton</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-from','Venice','drop-from')">Venice</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-from','Oslo','drop-from')">Oslo</div>
                </div>
            </div>

            <!-- Leaving on (Month) -->
            <div class="tk-sf" onclick="toggleDrop('drop-month')">
                <div class="tk-sf-label">Leaving on</div>
                <div class="tk-sf-val">
                    <span id="val-month">Any date</span>
                    <i class="fa fa-chevron-down"></i>
                </div>
                <div class="tk-sf-dropdown" id="drop-month">
                    <div class="tk-sf-dropdown-item selected" onclick="pickVal(event,'val-month','Any date','drop-month')">Any date</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','January','drop-month')">January</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','February','drop-month')">February</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','March','drop-month')">March</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','April','drop-month')">April</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','May','drop-month')">May</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','June','drop-month')">June</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','July','drop-month')">July</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','August','drop-month')">August</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','September','drop-month')">September</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','October','drop-month')">October</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','November','drop-month')">November</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-month','December','drop-month')">December</div>
                </div>
            </div>

            <!-- Duration -->
            <div class="tk-sf" onclick="toggleDrop('drop-dur')">
                <div class="tk-sf-label">Duration</div>
                <div class="tk-sf-val">
                    <span id="val-dur">Any length</span>
                    <i class="fa fa-chevron-down"></i>
                </div>
                <div class="tk-sf-dropdown" id="drop-dur">
                    <div class="tk-sf-dropdown-item selected" onclick="pickVal(event,'val-dur','Any length','drop-dur')">Any length</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-dur','1 – 5 nights','drop-dur')">1 – 5 nights</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-dur','6 – 9 nights','drop-dur')">6 – 9 nights</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-dur','10 – 14 nights','drop-dur')">10 – 14 nights</div>
                    <div class="tk-sf-dropdown-item" onclick="pickVal(event,'val-dur','15+ nights','drop-dur')">15+ nights</div>
                </div>
            </div>

            <button class="tk-search-btn">Search cruises</button>
        </div>
    </div>

    <!-- Cards -->
    <div class="tk-grid" id="tk-grid">

        <!-- 1. Mediterranean Dream -->
        <a asp-controller="Book" asp-action="Index" class="tk-card" data-region="mediterranean">
            <div class="tk-card-img">
                <img src="https://images.unsplash.com/photo-1507525428034-b723cf961d3e?w=700&q=80" alt="Mediterranean Dream" />
                <div class="tk-card-badge">7 Nights</div>
            </div>
            <div class="tk-card-body">
                <div class="tk-card-route">Barcelona → Rome → Athens</div>
                <div class="tk-card-name">Mediterranean Dream</div>
                <div class="tk-card-meta">
                    <div class="tk-card-meta-item"><i class="fa fa-anchor"></i> 4 Ports</div>
                    <div class="tk-card-meta-item"><i class="fa fa-calendar"></i> Jun – Sep</div>
                    <div class="tk-card-meta-item"><i class="fa fa-star"></i> 5-Star Ship</div>
                </div>
                <div class="tk-card-divider"></div>
                <div class="tk-card-footer">
                    <div>
                        <div class="tk-card-price-label">From / per person</div>
                        <div class="tk-card-price"><sup>$</sup>2,034</div>
                    </div>
                    <div class="tk-card-btn">View Details <i class="fa fa-arrow-right"></i></div>
                </div>
            </div>
        </a>

        <!-- 2. Caribbean Escape -->
        <div class="tk-card" data-region="caribbean">
            <div class="tk-card-img">
                <img src="https://images.unsplash.com/photo-1590523741831-ab7e8b8f9c7f?w=700&q=80" alt="Caribbean Escape" />
                <div class="tk-card-badge">10 Nights</div>
            </div>
            <div class="tk-card-body">
                <div class="tk-card-route">Miami → Jamaica → Bahamas</div>
                <div class="tk-card-name">Caribbean Escape</div>
                <div class="tk-card-meta">
                    <div class="tk-card-meta-item"><i class="fa fa-anchor"></i> 6 Ports</div>
                    <div class="tk-card-meta-item"><i class="fa fa-calendar"></i> Nov – Mar</div>
                    <div class="tk-card-meta-item"><i class="fa fa-star"></i> 5-Star Ship</div>
                </div>
                <div class="tk-card-divider"></div>
                <div class="tk-card-footer">
                    <div>
                        <div class="tk-card-price-label">From / per person</div>
                        <div class="tk-card-price"><sup>$</sup>2,749</div>
                    </div>
                    <div class="tk-card-btn">View Details <i class="fa fa-arrow-right"></i></div>
                </div>
            </div>
        </div>

        <!-- 3. Atlantic Voyage -->
        <div class="tk-card" data-region="atlantic">
            <div class="tk-card-img">
                <img src="https://images.unsplash.com/photo-1519659528534-7fd733a832a0?w=700&q=80" alt="Atlantic Voyage" />
                <div class="tk-card-badge">14 Nights</div>
            </div>
            <div class="tk-card-body">
                <div class="tk-card-route">Lisbon → Madeira → Canary Islands</div>
                <div class="tk-card-name">Atlantic Voyage</div>

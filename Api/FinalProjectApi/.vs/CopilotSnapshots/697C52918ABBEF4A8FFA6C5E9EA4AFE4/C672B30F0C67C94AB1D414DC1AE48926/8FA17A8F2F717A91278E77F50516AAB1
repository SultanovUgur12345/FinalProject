<script>
    function toggleDrop(id) {
        var all = document.querySelectorAll('.tk-sf-dropdown');
        all.forEach(function(d) { if (d.id !== id) d.classList.remove('open'); });
        document.getElementById(id).classList.toggle('open');
        event.stopPropagation();
    }
    function pickVal(e, valId, text, dropId) {
        e.stopPropagation();
        document.getElementById(valId).textContent = text;
        document.querySelectorAll('#' + dropId + ' .tk-sf-dropdown-item').forEach(function(i) { i.classList.remove('selected'); });
        e.target.classList.add('selected');
        document.getElementById(dropId).classList.remove('open');
    }
    document.addEventListener('click', function() {
        document.querySelectorAll('.tk-sf-dropdown').forEach(function(d) { d.classList.remove('open'); });
    });
</script>
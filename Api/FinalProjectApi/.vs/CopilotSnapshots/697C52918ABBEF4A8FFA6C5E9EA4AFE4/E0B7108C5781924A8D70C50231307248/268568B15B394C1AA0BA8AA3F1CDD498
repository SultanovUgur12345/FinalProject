@{
    ViewData["Title"] = "Cruises";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=Roboto:wght@300;400;500&family=Inconsolata:wght@400;500&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    .tk-page {
        min-height: 100vh;
        background-color: #021527;
        padding-top: 140px;
        padding-bottom: 80px;
        font-family: 'Roboto', sans-serif;
        color: #fff;
    }

    /* Hero */
    .tk-hero {
        position: relative;
        width: 100%; height: 320px;
        margin-bottom: 60px; overflow: hidden;
    }
    .tk-hero img {
        width: 100%; height: 100%;
        object-fit: cover; opacity: 0.35;
    }
    .tk-hero-overlay {
        position: absolute; inset: 0;
        background: linear-gradient(to bottom, rgba(2,21,39,0.3) 0%, rgba(2,21,39,0.85) 100%);
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        text-align: center; padding: 20px;
    }
    .tk-hero-label {
        font-family: 'Inconsolata', monospace;
        font-size: 12px; letter-spacing: 4px;
        text-transform: uppercase; color: #bfa888; margin-bottom: 14px;
    }
    .tk-hero-title {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(38px, 6vw, 64px);
        font-weight: 300; color: #fff;
        letter-spacing: 2px; line-height: 1.1;
    }
    .tk-hero-title span { color: #bfa888; font-style: italic; }

    /* Grid */
    .tk-grid {
        max-width: 1160px; margin: 0 auto;
        padding: 0 24px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(330px, 1fr));
        gap: 32px;
    }

    /* Card */
    .tk-card {
        position: relative;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(191,168,136,0.15);
        overflow: hidden; cursor: pointer;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        text-decoration: none; display: block; color: inherit;
    }
    .tk-card:hover {
        transform: translateY(-6px);
        border-color: rgba(191,168,136,0.5);
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        text-decoration: none; color: inherit;
    }

    /* Sold Out */
    .tk-card.sold-out { opacity: 0.78; }
    .tk-card.sold-out:hover {
        transform: translateY(-5px);
        border-color: rgba(255,100,100,0.4);
        box-shadow: 0 16px 40px rgba(0,0,0,0.45);
    }

    .tk-card-img {
        position: relative; width: 100%; height: 220px; overflow: hidden;
    }
    .tk-card-img img {
        width: 100%; height: 100%;
        object-fit: cover; transition: transform 0.6s ease;
    }
    .tk-card:hover .tk-card-img img { transform: scale(1.07); }

    /* Sold out overlay on image */
    .tk-sold-overlay {
        position: absolute; inset: 0;
        background: rgba(2,21,39,0.45);
        display: flex; align-items: center; justify-content: center;
    }
    .tk-sold-stamp {
        border: 2px solid rgba(255,100,100,0.75);
        color: #ff8a8a;
        font-family: 'Inconsolata', monospace;
        font-size: 13px; letter-spacing: 4px;
        text-transform: uppercase;
        padding: 8px 22px;
        backdrop-filter: blur(4px);
        background: rgba(180,40,40,0.2);
        transform: rotate(-12deg);
    }

    /* Badges */
    .tk-card-badge {
        position: absolute; top: 16px; left: 16px;
        background: rgba(2,21,39,0.85);
        border: 1px solid rgba(191,168,136,0.5);
        padding: 4px 12px;
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 2px;
        text-transform: uppercase; color: #bfa888;
        backdrop-filter: blur(6px);
    }

    /* Card body */
    .tk-card-body { padding: 24px 22px 20px; }
    .tk-card-route {
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 3px;
        text-transform: uppercase; color: #bfa888; margin-bottom: 10px;
    }
    .tk-card-name {
        font-family: 'Cormorant Garamond', serif;
        font-size: 24px; font-weight: 500;
        color: #fff; line-height: 1.2; margin-bottom: 14px;
    }
    .tk-card-meta {
        display: flex; gap: 20px; margin-bottom: 18px; flex-wrap: wrap;
    }
    .tk-card-meta-item {
        display: flex; align-items: center; gap: 6px;
        font-size: 12px; color: rgba(255,255,255,0.55);
    }
    .tk-card-meta-item i { color: #bfa888; font-size: 11px; }
    .tk-card-divider {
        width: 100%; height: 1px;
        background: rgba(191,168,136,0.15); margin-bottom: 18px;
    }
    .tk-card-footer {
        display: flex; align-items: flex-end; justify-content: space-between;
    }
    .tk-card-price-label {
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 2px;
        text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 4px;
    }
    .tk-card-price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 28px; font-weight: 600;
        color: #d6c09b; line-height: 1;
    }
    .tk-card-price sup { font-size: 14px; font-weight: 400; vertical-align: super; }

    /* Sold out price */
    .tk-card-price.sold-price {
        font-family: 'Cormorant Garamond', serif;
        font-size: 14px; color: rgba(255,138,138,0.7);
        letter-spacing: 1px; text-decoration: line-through;
        font-weight: 400;
    }
    .tk-sold-note {
        font-family: 'Inconsolata', monospace;
        font-size: 10px; color: #ff8a8a;
        letter-spacing: 2px; text-transform: uppercase;
        margin-top: 3px;
    }

    .tk-card-btn {
        padding: 10px 20px; background: transparent;
        border: 1px solid rgba(191,168,136,0.45);
        color: #bfa888;
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 2px;
        text-transform: uppercase;
        transition: all 0.25s ease;
        display: flex; align-items: center; gap: 8px;
        white-space: nowrap;
    }
    .tk-card:hover .tk-card-btn {
        background: rgba(191,168,136,0.15);
        border-color: #bfa888; color: #fff;
    }
    .tk-card-btn i { font-size: 10px; transition: transform 0.25s ease; }
    .tk-card:hover .tk-card-btn i { transform: translateX(4px); }

    .tk-card-btn.btn-soldout {
        border-color: rgba(255,100,100,0.35);
        color: rgba(255,138,138,0.8);
    }
    .tk-card.sold-out:hover .tk-card-btn.btn-soldout {
        background: rgba(180,40,40,0.12);
        border-color: rgba(255,100,100,0.6);
        color: #ffb3b3;
    }

    /* ── Search Bar ── */
    .tk-search-wrap {
        max-width: 1060px;
        margin: 0 auto 56px;
        padding: 0 24px;
    }
    .tk-search-bar {
        display: flex; align-items: stretch;
        background: rgba(2,21,39,0.82);
        backdrop-filter: blur(14px);
        border: 1px solid rgba(191,168,136,0.25);
        border-radius: 4px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.5);
        overflow: hidden;
    }
    .tk-sf {
        flex: 1; display: flex; flex-direction: column;
        justify-content: center; padding: 16px 26px;
        border-right: 1px solid rgba(191,168,136,0.18);
        cursor: pointer; transition: background 0.2s; user-select: none;
    }
    .tk-sf:last-of-type { border-right: none; }
    .tk-sf:hover { background: rgba(191,168,136,0.07); }
    .tk-sf-label {
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
        color: rgba(191,168,136,0.7); margin-bottom: 5px;
    }
    .tk-sf-val {
        display: flex; align-items: center; justify-content: space-between;
        font-family: 'Cormorant Garamond', serif;
        font-size: 17px; font-weight: 500; color: #fff; gap: 8px;
    }
    .tk-sf-val i { font-size: 11px; color: #bfa888; }
    .tk-search-btn {
        background: #bfa888; color: #021527; border: none;
        padding: 0 32px; font-family: 'Inconsolata', monospace;
        font-size: 11px; font-weight: 700; letter-spacing: 2px;
        text-transform: uppercase; cursor: pointer; transition: background 0.2s;
        white-space: nowrap;
    }
    .tk-search-btn:hover { background: #d6c09b; }

    /* ── Modals ── */
    .tk-modal-overlay {
        display: none; position: fixed; inset: 0;
        background: rgba(2,21,39,0.75);
        backdrop-filter: blur(4px);
        z-index: 2000; align-items: center; justify-content: center;
    }
    .tk-modal-overlay.open { display: flex; }
    .tk-modal {
        background: #021527;
        border: 1px solid rgba(191,168,136,0.25);
        border-radius: 6px;
        width: 880px; max-width: 96vw;
        box-shadow: 0 24px 80px rgba(0,0,0,0.7);
        display: flex; flex-direction: column;
        max-height: 88vh; overflow: hidden;
        font-family: 'Roboto', sans-serif;
    }
    /* Header */
    .tk-modal-head {
        display: flex; align-items: center; justify-content: space-between;
        padding: 22px 30px 18px;
        border-bottom: 1px solid rgba(191,168,136,0.18);
    }
    .tk-modal-head h2 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 26px; font-weight: 400; color: #fff; letter-spacing: 1px;
    }
    .tk-modal-close {
        background: none; border: none; font-size: 20px;
        color: #bfa888; cursor: pointer; line-height: 1;
        transition: color 0.2s;
    }
    .tk-modal-close:hover { color: #fff; }

    /* Nav pills (Regions / Ports / etc.) */
    .tk-modal-nav {
        display: flex; gap: 4px; padding: 0 30px;
        border-bottom: 1px solid rgba(191,168,136,0.15);
    }
    .tk-modal-nav-btn {
        padding: 12px 18px; cursor: pointer;
        font-family: 'Inconsolata', monospace;
        font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
        color: rgba(255,255,255,0.45);
        border-bottom: 2px solid transparent; margin-bottom: -1px;
        transition: all 0.2s; background: none; border-top: none;
        border-left: none; border-right: none;
    }
    .tk-modal-nav-btn:hover { color: rgba(255,255,255,0.8); }
    .tk-modal-nav-btn.active { color: #bfa888; border-bottom-color: #bfa888; }

    /* Body */
    .tk-modal-body { padding: 28px 30px; overflow-y: auto; flex: 1; }
    .tk-tab-panel { display: none; }
    .tk-tab-panel.active { display: block; }
    .tk-modal-section-title {
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
        color: #bfa888; margin-bottom: 16px;
    }

    /* Pills */
    .tk-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 30px; }
    .tk-pill {
        padding: 8px 20px; border-radius: 50px;
        border: 1px solid rgba(191,168,136,0.4);
        color: rgba(255,255,255,0.75);
        font-family: 'Roboto', sans-serif;
        font-size: 13px; cursor: pointer;
        transition: all 0.2s; background: transparent; white-space: nowrap;
    }
    .tk-pill:hover { border-color: #bfa888; color: #fff; background: rgba(191,168,136,0.08); }
    .tk-pill.active { background: #bfa888; border-color: #bfa888; color: #021527; font-weight: 600; }
    .tk-pill.disabled { opacity: 0.3; pointer-events: none; }

    /* Month grid */
    .tk-years-row { display: flex; gap: 24px; }
    .tk-years-row .tk-year-block { flex: 1; }
    .tk-year-block { }
    .tk-year-label {
        font-family: 'Cormorant Garamond', serif;
        font-size: 20px; font-weight: 400; color: #bfa888;
        text-align: center; margin-bottom: 14px;
    }
    .tk-months-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 8px; }
    .tk-month-btn {
        padding: 9px 4px; border-radius: 50px;
        border: 1px solid rgba(191,168,136,0.35);
        color: rgba(255,255,255,0.75);
        font-family: 'Roboto', sans-serif; font-size: 12px;
        text-align: center; cursor: pointer; transition: all 0.2s; background: transparent;
    }
    .tk-month-btn:hover { border-color: #bfa888; color: #fff; }
    .tk-month-btn.active { background: #bfa888; border-color: #bfa888; color: #021527; font-weight: 600; }
    .tk-month-btn.disabled { opacity: 0.28; pointer-events: none; }

    /* Footer */
    .tk-modal-foot {
        background: rgba(255,255,255,0.03);
        border-top: 1px solid rgba(191,168,136,0.15);
        padding: 14px 30px;
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px;
    }
    .tk-foot-selected { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .tk-foot-label {
        font-family: 'Inconsolata', monospace;
        font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
        color: rgba(255,255,255,0.4);
    }
    .tk-foot-tag {
        display: flex; align-items: center; gap: 6px;
        background: rgba(191,168,136,0.15);
        border: 1px solid rgba(191,168,136,0.4);
        color: #d6c09b; border-radius: 50px;
        padding: 4px 12px; font-size: 12px;
    }
    .tk-foot-tag button {
        background: none; border: none; color: #bfa888;
        cursor: pointer; font-size: 13px; padding: 0; line-height: 1;
    }
    .tk-foot-tag button:hover { color: #fff; }
    .tk-foot-actions { display: flex; gap: 10px; }
    .tk-foot-reset {
        padding: 8px 20px; border: 1px solid rgba(191,168,136,0.4);
        background: transparent; color: #bfa888; border-radius: 3px;
        font-family: 'Inconsolata', monospace; font-size: 10px;
        letter-spacing: 2px; text-transform: uppercase; cursor: pointer; transition: all 0.2s;
    }
    .tk-foot-reset:hover { background: rgba(191,168,136,0.1); color: #fff; border-color: #bfa888; }
    .tk-foot-close-btn {
        padding: 8px 24px; background: #bfa888;
        color: #021527; border: none; border-radius: 3px;
        font-family: 'Inconsolata', monospace; font-size: 10px;
        letter-spacing: 2px; text-transform: uppercase; font-weight: 700;
        cursor: pointer; transition: background 0.2s;
    }
    .tk-foot-close-btn:hover { background: #d6c09b; }

    @@media (max-width: 768px) {
        .tk-search-bar { flex-direction: column; }
        .tk-sf { border-right: none; border-bottom: 1px solid rgba(191,168,136,0.15); }
        .tk-search-btn { padding: 16px; }
        .tk-grid { grid-template-columns: 1fr; }
        .tk-hero { height: 240px; }
        .tk-modal { width: 98vw; }
        .tk-years-row { flex-direction: column; }
    }
</style>

<div class="tk-page">

    <!-- Hero -->
    <div class="tk-hero">
        <img src="https://images.unsplash.com/photo-1548438294-1ad5d5f4f063?w=1600&q=80" alt="Cruises" />
        <div class="tk-hero-overlay">
            <div class="tk-hero-label">Luxury at Sea</div>
            <h1 class="tk-hero-title">Our <span>Cruise</span> Packages</h1>
        </div>
    </div>

    <!-- Cards -->
    <div class="tk-search-wrap">
        <div class="tk-search-bar">

            <!-- Cruising to -->
            <div class="tk-sf" onclick="openModal('modal-dest')">
                <div class="tk-sf-label">Cruising to</div>
                <div class="tk-sf-val">
                    <span id="val-to">Anywhere</span>
                    <i class="fa fa-chevron-down"></i>
                </div>
            </div>

            <!-- Leaving from -->
            <div class="tk-sf" onclick="openModal('modal-port')">
                <div class="tk-sf-label">Leaving from</div>
                <div class="tk-sf-val">
                    <span id="val-from">Any port</span>
                    <i class="fa fa-chevron-down"></i>
                </div>
            </div>

            <!-- Leaving on -->
            <div class="tk-sf" onclick="openModal('modal-date')">
                <div class="tk-sf-label">Leaving on</div>
                <div class="tk-sf-val">
                    <span id="val-date">Any date</span>
                    <i class="fa fa-chevron-down"></i>
                </div>
            </div>

            <!-- Duration -->
            <div class="tk-sf" onclick="openModal('modal-dur')">
                <div class="tk-sf-label">Duration</div>
                <div class="tk-sf-val">
                    <span id="val-dur">Any length</span>
                    <i class="fa fa-chevron-down"></i>
                </div>
            </div>

            <button class="tk-search-btn">Search cruises</button>
        </div>
    </div>

    <!-- ══ MODAL: Destinations ══ -->
    <div class="tk-modal-overlay" id="modal-dest">
        <div class="tk-modal">
            <div class="tk-modal-head">
                <h2>Destinations</h2>
                <button class="tk-modal-close" onclick="closeModal('modal-dest')">&#x2715;</button>
            </div>
            <div class="tk-modal-body" style="padding-top:28px;">
                <div class="tk-modal-section-title">Featured destinations</div>
                <div class="tk-pills">
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Mediterranean Coast</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Caribbean Islands</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Greek Isles</div>
                </div>
                <div class="tk-modal-section-title">All destinations</div>
                <div class="tk-pills">
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Adriatic</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Alaska</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Atlantic</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Bahamas</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Canary Islands</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Caribbean</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Europe</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Mediterranean</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Nordic</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">North America</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Pacific</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-to','modal-dest')">Transatlantic</div>
                </div>
            </div>
            <div class="tk-modal-foot">
                <div class="tk-foot-selected">
                    <span class="tk-foot-label">Selected</span>
                    <div id="dest-tags"></div>
                </div>
                <div class="tk-foot-actions">
                    <button class="tk-foot-reset" onclick="resetModal('modal-dest','val-to','Anywhere')">Reset all</button>
                    <button class="tk-foot-close-btn" onclick="closeModal('modal-dest')">Done</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ MODAL: Leaving from ══ -->
    <div class="tk-modal-overlay" id="modal-port">
        <div class="tk-modal" style="width:640px;">
            <div class="tk-modal-head">
                <h2>Departure ports</h2>
                <button class="tk-modal-close" onclick="closeModal('modal-port')">&#x2715;</button>
            </div>
            <div class="tk-modal-body" style="padding-top:28px;">
                <div class="tk-modal-section-title">Popular ports</div>
                <div class="tk-pills">
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Barcelona</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Miami</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Athens</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Southampton</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Venice</div>
                </div>
                <div class="tk-modal-section-title">All departure ports</div>
                <div class="tk-pills">
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Bergen</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Fort Lauderdale</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Flam</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Lisbon</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Oslo</div>
                    <div class="tk-pill" onclick="togglePill(this,'val-from','modal-port')">Rome</div>
                </div>
            </div>
            <div class="tk-modal-foot">
                <div class="tk-foot-selected">
                    <span class="tk-foot-label">Selected</span>
                    <div id="port-tags"></div>
                </div>
                <div class="tk-foot-actions">
                    <button class="tk-foot-reset" onclick="resetModal('modal-port','val-from','Any port')">Reset all</button>
                    <button class="tk-foot-close-btn" onclick="closeModal('modal-port')">Done</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ MODAL: Cruise dates ══ -->
    <div class="tk-modal-overlay" id="modal-date">
        <div class="tk-modal" style="width:960px;">
            <div class="tk-modal-head">
                <h2>Cruise dates</h2>
                <button class="tk-modal-close" onclick="closeModal('modal-date')">&#x2715;</button>
            </div>
            <div class="tk-modal-body">
                <div class="tk-years-row" id="years-row"></div>
            </div>
            <div class="tk-modal-foot">
                <div class="tk-foot-selected">
                    <span class="tk-foot-label">Selected</span>
                    <div id="date-tags"></div>
                </div>
                <div class="tk-foot-actions">
                    <button class="tk-foot-reset" onclick="resetModal('modal-date','val-date','Any date')">Reset all</button>
                    <button class="tk-foot-close-btn" onclick="closeModal('modal-date')">Done</button>
                </div>

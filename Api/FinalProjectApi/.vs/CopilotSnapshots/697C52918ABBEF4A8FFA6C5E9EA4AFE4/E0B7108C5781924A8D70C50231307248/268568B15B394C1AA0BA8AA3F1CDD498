<script>
    // ── Modal open/close ──
    function openModal(id) {
        document.getElementById(id).classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeModal(id) {
        document.getElementById(id).classList.remove('open');
        document.body.style.overflow = '';
    }
    function closeModalOutside(e, id) {
        if (e.target === document.getElementById(id)) closeModal(id);
    }

    // ── Tabs ──
    function switchTab(tabEl, panelId) {
        var modal = tabEl.closest('.tk-modal');
        modal.querySelectorAll('.tk-modal-tab').forEach(function(t){ t.classList.remove('active'); });
        modal.querySelectorAll('.tk-tab-panel').forEach(function(p){ p.classList.remove('active'); });
        tabEl.classList.add('active');
        document.getElementById(panelId).classList.add('active');
    }

    // ── Pill toggle ──
    function togglePill(pill, valId, modalId) {
        pill.classList.toggle('active');
        updateValFromPills(modalId, valId);
        updateTags(modalId);
        event.stopPropagation();
    }

    function updateValFromPills(modalId, valId) {
        var active = document.querySelectorAll('#' + modalId + ' .tk-pill.active');
        var defaults = { 'val-to': 'Anywhere', 'val-from': 'Any port', 'val-date': 'Any date', 'val-dur': 'Any length' };
        document.getElementById(valId).textContent = active.length > 0
            ? (active.length === 1 ? active[0].textContent : active.length + ' selected')
            : defaults[valId];
    }

    function updateTags(modalId) {
        var tagContainers = {
            'modal-dest': 'dest-tags', 'modal-port': 'port-tags',
            'modal-date': 'date-tags', 'modal-dur': 'dur-tags'
        };
        var valIds = {
            'modal-dest': 'val-to', 'modal-port': 'val-from',
            'modal-date': 'val-date', 'modal-dur': 'val-dur'
        };
        var container = document.getElementById(tagContainers[modalId]);
        if (!container) return;
        var active = document.querySelectorAll('#' + modalId + ' .tk-pill.active');
        container.innerHTML = '';
        active.forEach(function(p) {
            var tag = document.createElement('div');
            tag.className = 'tk-foot-tag';
            tag.innerHTML = p.textContent + ' <button onclick="removePill(this,\'' + modalId + '\',\'' + valIds[modalId] + '\')">&#x2715;</button>';
            tag._pill = p;
            container.appendChild(tag);
        });
    }

    function removePill(btn, modalId, valId) {
        var tag = btn.closest('.tk-foot-tag');
        var pills = document.querySelectorAll('#' + modalId + ' .tk-pill');
        pills.forEach(function(p) {
            if (p.textContent.trim() === tag.textContent.replace('✕','').trim()) p.classList.remove('active');
        });
        updateValFromPills(modalId, valId);
        updateTags(modalId);
        event.stopPropagation();
    }

    function resetModal(modalId, valId, defaultText) {
        document.querySelectorAll('#' + modalId + ' .tk-pill').forEach(function(p){ p.classList.remove('active'); });
        document.getElementById(valId).textContent = defaultText;
        updateTags(modalId);
    }

    // ── Build month calendar (3 years) ──
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    var now = new Date();
    var curY = now.getFullYear(), curM = now.getMonth();

    function buildYears() {
        var row = document.getElementById('years-row');
        if (!row || row.children.length > 0) return;
        for (var y = curY; y <= curY + 2; y++) {
            var block = document.createElement('div');
            block.className = 'tk-year-block';
            var label = document.createElement('div');
            label.className = 'tk-year-label';
            label.textContent = y;
            block.appendChild(label);
            var grid = document.createElement('div');
            grid.className = 'tk-months-grid';
            for (var m = 0; m < 12; m++) {
                var btn = document.createElement('div');
                btn.className = 'tk-month-btn';
                btn.textContent = months[m];
                if (y === curY && m < curM) btn.classList.add('disabled');
                btn.dataset.year = y;
                btn.dataset.month = m;
                btn.onclick = function() {
                    this.classList.toggle('active');
                    var activeMons = document.querySelectorAll('#date-months .tk-month-btn.active');
                    document.getElementById('val-date').textContent = activeMons.length === 0 ? 'Any date'
                        : activeMons.length === 1 ? months[this.dataset.month] + ' ' + this.dataset.year
                        : activeMons.length + ' months';
                    updateTags('modal-date');
                };
                grid.appendChild(btn);
            }
            block.appendChild(grid);
            row.appendChild(block);
        }
    }

    document.getElementById('modal-date').addEventListener('click', function() { buildYears(); }, { once: true });
</script>
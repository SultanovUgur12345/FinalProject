<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&family=Cormorant+Garamond:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Roboto', sans-serif;
            background-image: url('https://seafarer.qodeinteractive.com/wp-content/uploads/2021/07/home-1-parallax-1.jpg');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: #fff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── TOPBAR ── */
        .admin-topbar {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1100;
            height: 60px;
            background: rgba(2, 21, 39, 0.85);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(191, 168, 136, 0.25);
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 0 30px 0 270px;
        }

        .admin-topbar__search {
            display: flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(191, 168, 136, 0.25);
            padding: 6px 14px;
            flex: 0 0 220px;
        }

        .admin-topbar__search i { color: rgba(191, 168, 136, 0.6); font-size: 12px; }

        .admin-topbar__search input {
            background: transparent;
            border: none;
            outline: none;
            color: #fff;
            font-size: 12px;
            letter-spacing: 0.5px;
            width: 100%;
        }

        .admin-topbar__search input::placeholder { color: rgba(255,255,255,0.35); }

        .admin-topbar__brand {
            font-family: 'Cormorant Garamond', serif;
            font-size: 20px;
            font-weight: 600;
            color: #bfa888;
            letter-spacing: 2px;
            text-transform: uppercase;
            text-decoration: none;
            flex: 1;
            text-align: center;
        }

        /* ── SIDEBAR ── */
        .admin-sidebar {
            position: fixed;
            top: 0; left: 0;
            width: 240px;
            height: 100vh;
            border-right: 1px solid rgba(191, 168, 136, 0.2);
            display: flex;
            flex-direction: column;
            padding-top: 0;
            z-index: 1200;
        }

        .admin-sidebar__logo {
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-bottom: 1px solid rgba(191, 168, 136, 0.2);
            font-family: 'Cormorant Garamond', serif;
            font-size: 22px;
            font-weight: 700;
            color: #bfa888;
            letter-spacing: 3px;
            text-transform: uppercase;
            text-decoration: none;
        }

        .admin-sidebar__logo i {
            font-size: 16px;
            margin-right: 10px;
            opacity: 0.8;
        }

        /* Profile block */
        .admin-sidebar__profile {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 22px 16px 16px;
            border-bottom: 1px solid rgba(191, 168, 136, 0.15);
            gap: 8px;
        }

        .admin-sidebar__avatar {
            width: 62px;
            height: 62px;
            border-radius: 50%;
            border: 2px solid rgba(191, 168, 136, 0.55);
            object-fit: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            color: #bfa888;
            background: rgba(191, 168, 136, 0.1);
        }

        .admin-sidebar__username {
            font-family: 'Cormorant Garamond', serif;
            font-size: 15px;
            font-weight: 600;
            color: #fff;
            letter-spacing: 0.5px;
        }

        .admin-sidebar__logout {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 10px;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: rgba(191, 168, 136, 0.8);
            border: 1px solid rgba(191, 168, 136, 0.3);
            padding: 5px 14px;
            text-decoration: none;
            transition: all 0.25s ease;
        }

        .admin-sidebar__logout:hover {
            background: rgba(191, 168, 136, 0.12);
            color: #fff;
            border-color: #bfa888;
        }

        .admin-sidebar__nav {
            padding: 16px 0;
            list-style: none;
            flex: 1;
        }

        .admin-sidebar__nav a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 24px;
            font-size: 12px;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.55);
            text-decoration: none;
            border-left: 2px solid transparent;
            transition: all 0.25s ease;
        }

        .admin-sidebar__nav a i {
            width: 16px;
            color: rgba(191, 168, 136, 0.6);
            font-size: 13px;
            transition: color 0.25s ease;
        }

        .admin-sidebar__nav a:hover {
            color: #fff;
            border-left-color: rgba(191, 168, 136, 0.5);
            background: rgba(191, 168, 136, 0.07);
        }

        .admin-sidebar__nav a:hover i { color: #bfa888; }

        .admin-sidebar__nav a.active {
            color: #bfa888;
            border-left-color: #bfa888;
            background: rgba(191, 168, 136, 0.1);
        }

        .admin-sidebar__nav a.active i { color: #bfa888; }

        /* ── MAIN CONTENT ── */
        .admin-main {
            margin-left: 240px;
            margin-top: 60px;
            padding: 40px 36px;
            min-height: calc(100vh - 60px);
            background: rgba(2, 21, 39, 0.55);
            backdrop-filter: blur(4px);
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <a class="admin-sidebar__logo" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <i class="fas fa-anchor"></i> Admin
        </a>

        <!-- User Profile -->
        <div class="admin-sidebar__profile">
            <div class="admin-sidebar__avatar">
                <i class="fas fa-user"></i>
            </div>
            <div class="admin-sidebar__username">@User.Identity?.Name</div>
            <a asp-area="" asp-controller="Account" asp-action="Logout" class="admin-sidebar__logout">
                <i class="fas fa-sign-out-alt"></i> Çıxış et
            </a>
        </div>

        <ul class="admin-sidebar__nav">
            <li>
                <a class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
            </li>
            <li>
                <a class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Workers" ? "active" : "")"
                   asp-area="Admin" asp-controller="Workers" asp-action="Index">
                    <i class="fas fa-users"></i> İşçilər
                </a>
            </li>
            <li>
                <a class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")"
                   asp-area="Admin" asp-controller="Users" asp-action="Index">
                    <i class="fas fa-user-shield"></i> İstifadəçilər
                </a>
            </li>
        </ul>
    </aside>

    <!-- Topbar -->
    <header class="admin-topbar">
        <div class="admin-topbar__search">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Axtar..." />
        </div>
        <a class="admin-topbar__brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            Seafarer — Admin
        </a>
    </header>

    <!-- Content -->
    <main class="admin-main">
        @RenderBody()
    </main>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

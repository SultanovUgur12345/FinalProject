<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin Panel</title>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>
        :root {
            --sidebar-width: 250px;
            --sidebar-bg: #1a1f2e;
            --sidebar-hover: #2a3150;
            --accent: #4f8ef7;
        }

        body {
            background: #f0f2f8;
            font-family: 'Segoe UI', sans-serif;
        }

        /* ── Sidebar ── */
        #adminSidebar {
            position: fixed;
            top: 0; left: 0;
            height: 100vh;
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            display: flex;
            flex-direction: column;
            z-index: 1000;
            transition: width .25s;
        }

        #adminSidebar .brand {
            padding: 22px 20px;
            color: #fff;
            font-size: 1.15rem;
            font-weight: 700;
            letter-spacing: .5px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }

        #adminSidebar .brand span { color: var(--accent); }

        #adminSidebar nav { flex: 1; padding: 12px 0; }

        #adminSidebar nav a {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 22px;
            color: #b0bec5;
            text-decoration: none;
            font-size: .92rem;
            transition: background .2s, color .2s;
        }

        #adminSidebar nav a:hover,
        #adminSidebar nav a.active {
            background: var(--sidebar-hover);
            color: #fff;
        }

        #adminSidebar nav a i { width: 18px; text-align: center; }

        #adminSidebar .sidebar-footer {
            padding: 16px 22px;
            border-top: 1px solid rgba(255,255,255,.08);
        }

        #adminSidebar .sidebar-footer a {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #b0bec5;
            text-decoration: none;
            font-size: .88rem;
            transition: color .2s;
        }

        #adminSidebar .sidebar-footer a:hover { color: #fff; }

        /* ── Main ── */
        #adminMain {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        #adminTopbar {
            background: #fff;
            border-bottom: 1px solid #e2e6ea;
            padding: 14px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 900;
        }

        #adminTopbar .page-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #1a1f2e;
        }

        #adminTopbar .user-info {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: .9rem;
            color: #555;
        }

        #adminTopbar .user-info .avatar {
            width: 34px; height: 34px;
            background: var(--accent);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: .85rem;
        }

        #adminContent {
            flex: 1;
            padding: 30px 32px;
        }

        /* ── Cards ── */
        .admin-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
            padding: 24px;
        }

        /* ── Table ── */
        .admin-table thead th {
            background: #f8f9fb;
            font-weight: 600;
            font-size: .82rem;
            text-transform: uppercase;
            letter-spacing: .5px;
            color: #6c757d;
            border-bottom: 2px solid #e9ecef;
        }

        .admin-table tbody tr:hover { background: #fafbff; }

        .admin-table td { vertical-align: middle; font-size: .92rem; }

        /* ── Role badges ── */
        .badge-admin   { background: #fff3cd; color: #856404; }
        .badge-member  { background: #d1ecf1; color: #0c5460; }
        .badge-superadmin { background: #f8d7da; color: #721c24; }

        /* ── Tabs ── */
        .nav-pills .nav-link { color: #555; border-radius: 8px; }
        .nav-pills .nav-link.active { background: var(--accent); color: #fff; }

        @@media (max-width: 768px) {
            #adminSidebar { width: 60px; }
            #adminSidebar .brand span, #adminSidebar nav a span, #adminSidebar .sidebar-footer a span { display: none; }
            #adminMain { margin-left: 60px; }
            #adminContent { padding: 18px 14px; }
        }
    </style>
</head>
<body>

<!-- ── Sidebar ── -->
<aside id="adminSidebar">
    <div class="brand"><i class="fa-solid fa-anchor me-2"></i><span>Admin<span> Panel</span></span></div>

    <nav>
        <a asp-controller="Home" asp-action="Index">
            <i class="fa-solid fa-house"></i><span>Ana Səhifə</span>
        </a>
        @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
        {
            <a asp-controller="Account" asp-action="UserList"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "UserList" || ViewContext.RouteData.Values["action"]?.ToString() == "AssignRole" ? "active" : "")">
                <i class="fa-solid fa-users"></i><span>İstifadəçilər</span>
            </a>
        }
        <a asp-controller="Workers" asp-action="Index">
            <i class="fa-solid fa-user-tie"></i><span>İşçilər</span>
        </a>
    </nav>

    <div class="sidebar-footer">
        <a asp-controller="Account" asp-action="Logout">
            <i class="fa-solid fa-right-from-bracket"></i><span>Çıxış</span>
        </a>
    </div>
</aside>

<!-- ── Main ── -->
<div id="adminMain">
    <header id="adminTopbar">
        <span class="page-title">@ViewData["Title"]</span>
        <div class="user-info">
            @{
                var adminProfileImage = Context.Session.GetString("ProfileImage");
            }
            @if (!string.IsNullOrWhiteSpace(adminProfileImage))
            {
                <img src="@adminProfileImage" alt="Profile" style="width:34px;height:34px;border-radius:50%;object-fit:cover;border:2px solid var(--accent);" />
            }
            else
            {
                <div class="avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "A")</div>
            }
            <span>@User.Identity?.Name</span>
        </div>
    </header>

    <main id="adminContent">
        @RenderBody()
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

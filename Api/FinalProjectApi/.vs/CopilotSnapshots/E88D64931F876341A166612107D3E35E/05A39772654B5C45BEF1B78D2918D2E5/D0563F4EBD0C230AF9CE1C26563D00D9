@model FinalProjectMVC.ViewModels.Account.UpdateProfileVM

@{
    ViewData["Title"] = "Edit Profile";
}

<style>
    .ep-page {
        padding: 140px 20px 100px;
        min-height: 100vh;
        background-image: url('https://seafarer.qodeinteractive.com/wp-content/uploads/2021/07/home-1-parallax-1.jpg');

    }

    .ep-container {
        max-width: 680px;
        margin: 0 auto;
    }

    /* ── Header ── */
    .ep-header {
        text-align: center;
        margin-bottom: 48px;
    }

    .ep-header__label {
        display: inline-block;
        color: #bfa888;
        font-size: 11px;
        letter-spacing: 4px;
        text-transform: uppercase;
        margin-bottom: 14px;
    }

    .ep-header__title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 52px;
        font-weight: 600;
        color: #fff;
        line-height: 1.1;
        margin: 0 0 12px;
    }

    .ep-header__sub {
        color: rgba(255,255,255,0.5);
        font-size: 14px;
        letter-spacing: 0.5px;
    }

    /* ── Card ── */
    .ep-card {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(191,168,136,0.25);
        backdrop-filter: blur(8px);
        padding: 48px 44px;
    }

    /* ── Alerts ── */
    .ep-alert {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 14px 18px;
        margin-bottom: 28px;
        font-size: 14px;
        border-left: 3px solid;
    }

    .ep-alert--success {
        background: rgba(80,200,120,0.08);
        border-color: #50c878;
        color: #50c878;
    }

    .ep-alert--error {
        background: rgba(220,53,69,0.08);
        border-color: #ff6b6b;
        color: #ff6b6b;
    }

    /* ── Form ── */
    .ep-section-label {
        color: #bfa888;
        font-size: 11px;
        letter-spacing: 3px;
        text-transform: uppercase;
        margin-bottom: 24px;
        padding-bottom: 12px;
        border-bottom: 1px solid rgba(191,168,136,0.2);
    }

    .ep-form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .ep-form-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
        margin-bottom: 22px;
    }

    .ep-form-group label {
        color: rgba(255,255,255,0.7);
        font-size: 12px;
        letter-spacing: 1px;
        text-transform: uppercase;
        font-weight: 500;
    }

    .ep-input {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(191,168,136,0.25);
        color: #fff;
        padding: 14px 16px;
        font-size: 14px;
        outline: none;
        transition: border-color 0.25s, background 0.25s;
        width: 100%;
        box-sizing: border-box;
        font-family: 'Roboto', sans-serif;
    }

    .ep-input:focus {
        border-color: #bfa888;
        background: rgba(191,168,136,0.06);
    }

    .ep-input::placeholder {
        color: rgba(255,255,255,0.25);
    }

    .ep-validation {
        color: #ff6b6b;
        font-size: 12px;
    }

    /* ── Divider ── */
    .ep-divider {
        margin: 32px 0 28px;
        border: none;
        border-top: 1px solid rgba(191,168,136,0.18);
        position: relative;
    }

    /* ── Submit ── */
    .ep-submit {
        margin-top: 36px;
    }

    .ep-btn {
        display: inline-block;
        width: 100%;
        padding: 16px;
        background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
        color: #021527;
        font-family: 'Roboto', sans-serif;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        border: none;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        text-align: center;
    }

    .ep-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 28px rgba(191,168,136,0.3);
    }

    @@media (max-width: 640px) {
        .ep-card { padding: 32px 22px; }
        .ep-header__title { font-size: 38px; }
        .ep-form-row { grid-template-columns: 1fr; }
    }
</style>

<section class="ep-page">
    <div class="ep-container">

        <div class="ep-header">
            <span class="ep-header__label">Account Settings</span>
            <h1 class="ep-header__title">Edit Profile</h1>
            <p class="ep-header__sub">Update your personal information and password</p>
        </div>

        <div class="ep-card">

            @if (TempData["Success"] != null)
            {
                <div class="ep-alert ep-alert--success">
                    <i class="fa-solid fa-circle-check"></i>
                    @TempData["Success"]
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="ep-alert ep-alert--error">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    <div asp-validation-summary="All"></div>
                </div>
            }

            <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <p class="ep-section-label">Profile Photo</p>

                <div class="ep-form-group" style="align-items:center;">
                    <div style="display:flex;gap:24px;align-items:center;flex-wrap:wrap;">
                        <div id="ep-avatar-preview" style="width:90px;height:90px;border-radius:50%;overflow:hidden;border:2px solid rgba(191,168,136,0.4);background:rgba(191,168,136,0.1);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                            {
                                <img id="ep-avatar-img" src="@Model.ProfileImageUrl" alt="Profile" style="width:100%;height:100%;object-fit:cover;" />
                            }
                            else
                            {
                                <i id="ep-avatar-icon" class="fa-solid fa-user" style="font-size:32px;color:#bfa888;"></i>
                            }
                        </div>
                        <div>
                            <label for="ProfileImage" class="admin-btn" style="cursor:pointer;padding:10px 20px;">
                                <i class="fa-solid fa-camera" style="margin-right:6px;"></i>Choose Photo
                            </label>
                            <input type="file" id="ProfileImage" name="ProfileImage" accept="image/*" style="display:none;" onchange="previewAvatar(this)" />
                            <p style="color:rgba(255,255,255,0.35);font-size:12px;margin-top:8px;">JPG, PNG or WEBP · max 5 MB</p>
                        </div>
                    </div>
                </div>

                <hr class="ep-divider" />

                <p class="ep-section-label">Personal Information</p>

                <div class="ep-form-row">
                    <div class="ep-form-group">
                        <label asp-for="FullName">Full Name</label>
                        <input asp-for="FullName" class="ep-input" placeholder="Your full name" />
                        <span asp-validation-for="FullName" class="ep-validation"></span>
                    </div>

                    <div class="ep-form-group">
                        <label asp-for="UserName">Username</label>
                        <input asp-for="UserName" class="ep-input" placeholder="Your username" />
                        <span asp-validation-for="UserName" class="ep-validation"></span>
                    </div>
                </div>

                <hr class="ep-divider" />

                <p class="ep-section-label">Change Password</p>
                <p style="color:rgba(255,255,255,0.4); font-size:13px; margin-bottom:20px; margin-top:-14px;">Leave blank to keep current password</p>

                <div class="ep-form-group">
                    <label asp-for="CurrentPassword">Current Password</label>
                    <input asp-for="CurrentPassword" type="password" class="ep-input" placeholder="Enter current password" />
                    <span asp-validation-for="CurrentPassword" class="ep-validation"></span>
                </div>

                <div class="ep-form-group">
                    <label asp-for="NewPassword">New Password</label>
                    <input asp-for="NewPassword" type="password" class="ep-input" placeholder="Enter new password" />
                    <span asp-validation-for="NewPassword" class="ep-validation"></span>
                </div>

                <div class="ep-submit">
                    <button type="submit" class="ep-btn">Save Changes</button>
                </div>
            </form>

        </div>
    </div>
</section>

        public async Task<UpdateProfileVM> GetProfileAsync(string token)
        {
            _httpClient.DefaultRequestHeaders.Authorization = null;

            if (!string.IsNullOrWhiteSpace(token))
            {
                _httpClient.DefaultRequestHeaders.Authorization =
                    new AuthenticationHeaderValue("Bearer", token);
            }

            var response = await _httpClient.GetAsync("api/account/get-profile");

            if (!response.IsSuccessStatusCode)
            {
                return new UpdateProfileVM();
            }

            var result = await response.Content.ReadFromJsonAsync<UpdateProfileVM>(new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });

            return result ?? new UpdateProfileVM();
        }

        public async Task<(bool success, string message, string? profileImageUrl)> UploadProfileImageAsync(IFormFile file, string token)
        {
            _httpClient.DefaultRequestHeaders.Authorization = null;

            if (!string.IsNullOrWhiteSpace(token))
                _httpClient.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream();
            var fileContent = new StreamContent(stream);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(fileContent, "file", file.FileName);

            var response = await _httpClient.PostAsync("api/account/upload-profile-image", content);
            var body = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                try
                {
                    using var doc = JsonDocument.Parse(body);
                    string? imageUrl = null;
                    if (doc.RootElement.TryGetProperty("profileImage", out var imgProp))
                        imageUrl = imgProp.GetString();
                    return (true, "Profil sekli yenilendi", imageUrl);
                }
                catch
                {
                    return (true, "Profil sekli yenilendi", null);
                }
            }

            try
            {
                using var doc = JsonDocument.Parse(body);
                if (doc.RootElement.TryGetProperty("message", out var msg))
                    return (false, msg.GetString() ?? "Xeta bas verdi", null);
            }
            catch { }

            return (false, "Xeta bas verdi", null);
        }


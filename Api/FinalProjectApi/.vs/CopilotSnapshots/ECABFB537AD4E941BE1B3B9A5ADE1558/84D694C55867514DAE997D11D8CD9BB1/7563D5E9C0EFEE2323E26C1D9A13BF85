@using FinalProjectMVC.ViewModels.Account
@model PaginatedResult<UserListVM>

@{
    ViewData["Title"] = "Users";
    string callerRole = ViewBag.CallerRole ?? "Admin";
    bool isSuperAdmin = callerRole == "SuperAdmin";
}

<div class="admin-content__header">
            <div>
                <p class="admin-content__subtitle">USER MANAGEMENT</p>
                <h1>Users List</h1>
            </div>
        </div>

        @if (TempData["UserError"] is string errorMsg)
        {
            <div class="admin-alert admin-alert--error">
                <span>?</span> @errorMsg
            </div>
        }

        @if (TempData["UserSuccess"] is string successMsg)
        {
            <div class="admin-alert admin-alert--success">
                <span>?</span> @successMsg
            </div>
        }

        <div class="admin-topbar">
            <div class="admin-search">
                <input type="text" id="emailSearchInput" class="admin-search__input" placeholder="Search by full name..." autocomplete="off" />
            </div>
            <span class="admin-stat">Total: <strong id="totalUsersCount">@Model.TotalCount</strong></span>
        </div>

        <div class="admin-table-container">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Username</th>
                        <th>Email</th>
                        <th>Role</th>
                        @if (isSuperAdmin)
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        int i = 1;
                        foreach (var item in Model.Items)
                        {
                            <tr class="user-row">
                                <td>@(i++)</td>
                                <td>@item.FullName</td>
                                <td>@item.UserName</td>
                                <td>@item.Email</td>
                                <td>
                                    <span class="admin-badge admin-badge--@(item.Role.ToLower())">
                                        @item.Role
                                    </span>
                                </td>
                                @if (isSuperAdmin)
                                {
                                    <td>
                                        <div class="admin-actions">
                                            @if (item.CanChangeRole)
                                            {
                                                <button type="button"
                                                        class="admin-btn admin-btn--sm open-role-modal"
                                                        data-id="@item.Id"
                                                        data-name="@item.FullName"
                                                        data-role="@item.Role">
                                                    Change Role
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="admin-text-muted">—</span>
                                            }
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else
                    {
                        <tr id="noUsersRow">
                            <td colspan="6" class="admin-table__empty">No users found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="admin-pagination" id="paginationContainer">
            <button class="admin-pagination__btn" id="prevPageBtn" data-page="@(Model.Page - 1)" @(Model.Page <= 1 ? "disabled" : "")>← Previous</button>
            <div class="admin-pagination__numbers" id="paginationNumbers">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <button class="admin-pagination__number @(i == Model.Page ? "active" : "")"
                            data-page="@i">@i</button>
                }
            </div>
            <button class="admin-pagination__btn" id="nextPageBtn" data-page="@(Model.Page + 1)" @(Model.Page >= Model.TotalPages ? "disabled" : "")>Next →</button>
        </div>

@if (isSuperAdmin)
{
    <div class="admin-modal" id="roleModal">
        <div class="admin-modal__overlay" id="roleModalOverlay"></div>
        <div class="admin-modal__box">
            <div class="admin-modal__header">
                <h3 class="admin-modal__title">Change User Role</h3>
                <button type="button" class="admin-modal__close" id="roleModalClose">×</button>
            </div>

            <div class="admin-modal__body">
                <div class="admin-modal__info">
                    <p><strong>User:</strong> <span id="modalUserName"></span></p>
                    <p><strong>Current Role:</strong> <span id="modalCurrentRole" class="admin-badge"></span></p>
                </div>

                <form asp-area="Admin" asp-controller="Users" asp-action="AssignRole" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="UserId" id="modalUserId" />
                    <input type="hidden" name="UserName" id="modalUserNameInput" />

                    <div class="admin-form-group">
                        <label class="admin-label">New Role</label>
                        <select name="Role" id="modalRoleSelect" class="admin-select">
                            <option value="Admin">Admin</option>
                            <option value="Member">Member</option>
                        </select>
                    </div>

                    <div class="admin-modal__actions">
                        <button type="submit" class="admin-btn admin-btn--primary">Save Changes</button>
                        <button type="button" class="admin-btn admin-btn--secondary admin-modal-cancel">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .admin-content__header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 24px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .admin-content__subtitle {
        color: #bfa888;
        letter-spacing: 2px;
        font-size: 12px;
        margin-bottom: 8px;
    }

    .admin-content h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 40px;
        margin: 0;
    }

    .admin-topbar {
        margin-bottom: 18px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
    }

    .admin-search {
        position: relative;
        display: flex;
        align-items: center;
    }

    .admin-search__input {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(191, 168, 136, 0.35);
        color: #fff;
        padding: 8px 14px;
        font-size: 13px;
        outline: none;
        width: 240px;
        transition: border-color 0.3s;
    }

    .admin-search__input::placeholder {
        color: rgba(255, 255, 255, 0.4);
    }

    .admin-search__input:focus {
        border-color: #bfa888;
    }

    .admin-content__stats {
        display: flex;
        gap: 20px;
    }

    .admin-stat {
        font-size: 14px;
        color: #fff;
        padding: 8px 16px;
        background: rgba(191, 168, 136, 0.1);
        border: 1px solid rgba(191, 168, 136, 0.25);
    }

        .admin-stat strong {
            color: #bfa888;
            margin-left: 6px;
        }

    .admin-alert {
        padding: 12px 16px;
        margin-bottom: 20px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .admin-alert span {
            font-size: 16px;
        }

    .admin-alert--error {
        background: rgba(220, 53, 69, 0.15);
        border: 1px solid rgba(220, 53, 69, 0.4);
        color: #ff6b6b;
    }

    .admin-alert--success {
        background: rgba(40, 167, 69, 0.15);
        border: 1px solid rgba(40, 167, 69, 0.4);
        color: #51cf66;
    }

    .admin-table-container {
        overflow-x: auto;
        margin-bottom: 24px;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table thead tr {
            border-bottom: 2px solid rgba(191, 168, 136, 0.3);
        }

        .admin-table th {
            text-align: left;
            padding: 14px 12px;
            font-size: 12px;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: #bfa888;
            font-weight: 600;
        }

        .admin-table td {
            padding: 14px 12px;
            border-bottom: 1px solid rgba(191, 168, 136, 0.15);
            font-size: 14px;
        }

        .admin-table tbody tr {
            transition: background 0.2s ease;
        }

            .admin-table tbody tr:hover {
                background: rgba(191, 168, 136, 0.05);
            }

    .admin-table__empty {
        text-align: center;
        color: #bfa888;
        padding: 40px 12px !important;
        font-style: italic;
    }

    .admin-badge {
        display: inline-block;
        padding: 4px 12px;
        font-size: 11px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        border-radius: 12px;
        font-weight: 600;
    }

    .admin-badge--admin {
        background: rgba(191, 168, 136, 0.2);
        color: #bfa888;
        border: 1px solid rgba(191, 168, 136, 0.4);
    }

    .admin-badge--member {
        background: rgba(52, 152, 219, 0.2);
        color: #5dade2;
        border: 1px solid rgba(52, 152, 219, 0.4);
    }

    .admin-badge--superadmin {
        background: rgba(231, 76, 60, 0.2);
        color: #ec7063;
        border: 1px solid rgba(231, 76, 60, 0.4);
    }

    .admin-actions {
        display: flex;
        gap: 8px;
    }

    .admin-text-muted {
        color: rgba(255, 255, 255, 0.3);
    }

    .admin-btn {
        display: inline-block;
        text-decoration: none;
        background: transparent;
        color: #fff;
        border: 1px solid rgba(191, 168, 136, 0.5);
        padding: 10px 16px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .admin-btn:hover {
            background: rgba(191, 168, 136, 0.1);
            border-color: #bfa888;
        }

        .admin-btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

    .admin-btn--sm {
        padding: 6px 12px;
        font-size: 11px;
    }

    .admin-btn--primary {
        background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
        color: #021527;
        border-color: transparent;
        font-weight: 600;
    }

        .admin-btn--primary:hover {
            color: #021527;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(191, 168, 136, 0.35);
        }

    .admin-btn--secondary {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(191, 168, 136, 0.3);
    }

        .admin-btn--secondary:hover {
            background: rgba(255, 255, 255, 0.1);
        }

    .admin-pagination {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 24px;
    }

    .admin-pagination__btn {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(191, 168, 136, 0.3);
        padding: 8px 16px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .admin-pagination__btn:hover:not(:disabled) {
            background: rgba(191, 168, 136, 0.1);
            border-color: #bfa888;
            color: #bfa888;
        }

        .admin-pagination__btn:disabled {
            opacity: 0.3;
            cursor: not-allowed;
        }

    .admin-pagination__numbers {
        display: flex;
        gap: 4px;
    }

    .admin-pagination__number {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(191, 168, 136, 0.25);
        padding: 8px 12px;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        min-width: 36px;
    }

        .admin-pagination__number:hover {
            background: rgba(191, 168, 136, 0.1);
            border-color: #bfa888;
        }

        .admin-pagination__number.active {
            background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
            color: #021527;
            border-color: transparent;
            font-weight: 600;
        }

    .admin-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;
    }

        .admin-modal.active {
            display: flex;
        }

    .admin-modal__overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(5px);
    }

    .admin-modal__box {
        position: relative;
        background: rgba(2, 21, 39, 0.95);
        border: 1px solid rgba(191, 168, 136, 0.4);
        backdrop-filter: blur(10px);
        width: 90%;
        max-width: 500px;
        padding: 0;
        z-index: 1001;
    }

    .admin-modal__header {
        padding: 20px 24px;
        border-bottom: 1px solid rgba(191, 168, 136, 0.2);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .admin-modal__title {
        font-family: 'Cormorant Garamond', serif;
        font-size: 28px;
        margin: 0;
        color: #bfa888;
    }

    .admin-modal__close {
        background: transparent;
        border: none;
        color: #bfa888;
        font-size: 32px;
        cursor: pointer;
        line-height: 1;
        padding: 0;
        width: 32px;
        height: 32px;
        transition: all 0.3s ease;
    }

        .admin-modal__close:hover {
            color: #fff;
            transform: rotate(90deg);
        }

    .admin-modal__body {
        padding: 24px;
        color: #fff;
    }

    .admin-modal__info {
        background: rgba(191, 168, 136, 0.08);
        border: 1px solid rgba(191, 168, 136, 0.2);
        padding: 16px;
        margin-bottom: 24px;
    }

        .admin-modal__info p {
            margin: 8px 0;
            font-size: 14px;
        }

        .admin-modal__info strong {
            color: #bfa888;
            margin-right: 8px;
        }

    .admin-form-group {
        margin-bottom: 24px;
    }

    .admin-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        font-size: 12px;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #bfa888;
    }

    .admin-select {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(191, 168, 136, 0.3);
        color: #fff;
        padding: 12px;
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .admin-select:focus {
            outline: none;
            border-color: #bfa888;
            background: rgba(255, 255, 255, 0.08);
        }

        .admin-select option {
            background: #021527;
            color: #fff;
        }

    .admin-modal__actions {
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    @@media (max-width: 900px) {
        .admin-content__header {
            flex-direction: column;
        }

        .admin-table {
            font-size: 12px;
        }

            .admin-table th,
            .admin-table td {
                padding: 10px 8px;
            }

        .admin-pagination {
            flex-wrap: wrap;
        }
    }
</style>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        const tableBody = document.getElementById("usersTableBody");
        const paginationNumbers = document.getElementById("paginationNumbers");
        const prevPageBtn = document.getElementById("prevPageBtn");
        const nextPageBtn = document.getElementById("nextPageBtn");
        const paginationContainer = document.getElementById("paginationContainer");
        const isSuperAdmin = "@callerRole" === "SuperAdmin";

        const pageSize = @Model.PageSize;
        let currentPage = @Model.Page;

        // ROLE MODAL
        const roleModal = document.getElementById("roleModal");
        const roleModalOverlay = document.getElementById("roleModalOverlay");
        const roleModalClose = document.getElementById("roleModalClose");

        function openRoleModal(btn) {
            document.getElementById("modalUserId").value = btn.dataset.id;
            document.getElementById("modalUserNameInput").value = btn.dataset.name;
            document.getElementById("modalUserName").textContent = btn.dataset.name;
            document.getElementById("modalCurrentRole").textContent = btn.dataset.role;
            const select = document.getElementById("modalRoleSelect");
            Array.from(select.options).forEach(opt => { opt.selected = opt.value === btn.dataset.role; });
            roleModal.classList.add("active");
        }

        function closeRoleModal() { roleModal?.classList.remove("active"); }

        function bindRoleModalButtons() {
            document.querySelectorAll(".open-role-modal").forEach(btn => {
                btn.removeEventListener("click", btn._roleHandler);
                btn._roleHandler = function () { openRoleModal(this); };
                btn.addEventListener("click", btn._roleHandler);
            });
        }

        if (roleModal) {
            bindRoleModalButtons();
            roleModalClose?.addEventListener("click", closeRoleModal);
            roleModalOverlay?.addEventListener("click", closeRoleModal);
            document.querySelectorAll(".admin-modal-cancel").forEach(btn => {
                btn.addEventListener("click", closeRoleModal);
            });
        }

        function buildRows(items, pageOffset) {
            if (items.length === 0) {
                tableBody.innerHTML = `<tr id="noUsersRow"><td colspan="6" class="admin-table__empty">No users found</td></tr>`;
                document.getElementById("totalUsersCount").textContent = "0";
                return;
            }

            tableBody.innerHTML = "";
            items.forEach(function (item, index) {
                const badgeClass = item.role ? `admin-badge--${item.role.toLowerCase()}` : "";
                const changeRoleBtn = (isSuperAdmin && item.canChangeRole)
                    ? `<button type="button" class="admin-btn admin-btn--sm open-role-modal"
                            data-id="${item.id}" data-name="${item.fullName}" data-role="${item.role}">
                            Change Role
                       </button>`
                    : (isSuperAdmin ? `<span class="admin-text-muted">—</span>` : "");

                const actionsTd = isSuperAdmin
                    ? `<td><div class="admin-actions">${changeRoleBtn}</div></td>`
                    : "";

                tableBody.innerHTML += `
                    <tr class="user-row">
                        <td>${pageOffset + index + 1}</td>
                        <td>${item.fullName ?? ""}</td>
                        <td>${item.userName ?? ""}</td>
                        <td>${item.email ?? ""}</td>
                        <td><span class="admin-badge ${badgeClass}">${item.role ?? ""}</span></td>
                        ${actionsTd}
                    </tr>`;
            });

            bindRoleModalButtons();
        }

        // PAGINATION
        async function loadPage(page) {
            try {
                const response = await fetch(`/Admin/Users/GetPage?page=${page}&pageSize=${pageSize}`);
                if (!response.ok) return;
                const result = await response.json();
                const items = result.items ?? [];

                buildRows(items, (page - 1) * pageSize);
                document.getElementById("totalUsersCount").textContent = result.totalCount ?? 0;

                currentPage = result.page;
                const totalPages = result.totalPages;

                prevPageBtn.disabled = currentPage <= 1;
                prevPageBtn.dataset.page = currentPage - 1;
                nextPageBtn.disabled = currentPage >= totalPages;
                nextPageBtn.dataset.page = currentPage + 1;

                paginationNumbers.innerHTML = "";
                for (let i = 1; i <= totalPages; i++) {
                    const btn = document.createElement("button");
                    btn.className = "admin-pagination__number" + (i === currentPage ? " active" : "");
                    btn.textContent = i;
                    btn.dataset.page = i;
                    btn.addEventListener("click", () => loadPage(i));
                    paginationNumbers.appendChild(btn);
                }

                paginationContainer.style.display = totalPages > 1 ? "flex" : "none";
            } catch (e) {
                console.error("Pagination error:", e);
            }
        }

        prevPageBtn?.addEventListener("click", function () {
            if (!this.disabled) loadPage(parseInt(this.dataset.page));
        });
        nextPageBtn?.addEventListener("click", function () {
            if (!this.disabled) loadPage(parseInt(this.dataset.page));
        });
        document.querySelectorAll("#paginationNumbers .admin-pagination__number").forEach(btn => {
            btn.addEventListener("click", function () { loadPage(parseInt(this.dataset.page)); });
        });

        // SEARCH
        const emailSearchInput = document.getElementById("emailSearchInput");
        let searchTimeout = null;
        emailSearchInput?.addEventListener("input", function () {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(async function () {
                const email = emailSearchInput.value.trim();

                if (!email) {
                    paginationContainer.style.display = "";
                    loadPage(currentPage);
                    return;
                }

                paginationContainer.style.display = "none";

                try {
                    const response = await fetch(`/Admin/Users/SearchJson?fullName=${encodeURIComponent(email)}`);
                    if (!response.ok) return;
                    const users = await response.json();

                    buildRows(users, 0);
                    document.getElementById("totalUsersCount").textContent = users.length;
                } catch (e) {
                    console.error("Search error:", e);
                }
            }, 350);
        });
    });
</script>


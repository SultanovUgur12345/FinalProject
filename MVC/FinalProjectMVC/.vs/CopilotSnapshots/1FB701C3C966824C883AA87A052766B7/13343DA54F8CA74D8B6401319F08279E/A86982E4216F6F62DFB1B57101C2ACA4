@model List<WorkerVM>

@{
    ViewData["Title"] = "Admin Workers";
}

<section class="admin-workers">
    <div class="admin-workers__container">

        <div class="admin-workers__head">
            <div>
                <p class="admin-workers__subtitle">ADMIN PANEL</p>
                <h1>Workers Management</h1>
            </div>

            <button type="button"
                    class="admin-btn admin-btn--primary"
                    onclick="openWorkerForm('create')">
                + Create Worker
            </button>
        </div>

        <div class="admin-workers__table-wrap">
            <table class="admin-workers__table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Full Name</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>

                                <td>
                                    <img class="admin-avatar" src="@item.Image" />
                                </td>

                                <td>@item.FullName</td>

                                <td>@item.Position</td>

                                <td>
                                    <div class="admin-actions">

                                        <button type="button"
                                                class="admin-btn"
                                                onclick="openViewModal('@item.FullName','@item.Position','@item.Image')">
                                            View
                                        </button>

                                        <button type="button"
                                                class="admin-btn"
                                                onclick="openWorkerForm('edit',@item.Id,'@item.FullName','@item.Position','@item.Image')">
                                            Edit
                                        </button>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" style="text-align:center; color:#bfa888;">
                                No workers found
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>

    </div>
</section>

<!-- CREATE / EDIT MODAL -->
<div id="workerFormOverlay" class="admin-overlay" onclick="closeOverlay(event, 'workerFormOverlay')">
    <div class="admin-modal">

        <h3 id="workerFormTitle">Create Worker</h3>

        <form method="post" asp-action="Create">

            <input id="workerId" name="Id" type="hidden" />

            <div class="admin-form-group">
                <label>Full Name</label>
                <input id="workerName" name="FullName" type="text" />
            </div>

            <div class="admin-form-group">
                <label>Role</label>
                <input id="workerRole" name="Position" type="text" />
            </div>

            <div class="admin-form-group">
                <label>Image Url</label>
                <input id="workerImage" name="Image" type="text" />
            </div>

            <div class="admin-actions">
                <button type="button"
                        class="admin-btn"
                        onclick="closeById('workerFormOverlay')">
                    Cancel
                </button>

                <button type="submit"
                        class="admin-btn admin-btn--primary">
                    Save
                </button>
            </div>

        </form>
    </div>
</div>

<!-- VIEW MODAL -->
<div id="workerViewOverlay" class="admin-overlay" onclick="closeOverlay(event, 'workerViewOverlay')">
    <div class="admin-modal admin-modal--view">

        <img id="viewImage" src="" />
        <h3 id="viewName"></h3>
        <p id="viewRole"></p>

        <button type="button"
                class="admin-btn admin-btn--primary"
                onclick="closeById('workerViewOverlay')">
            Close
        </button>

    </div>
</div>

<style>
    .admin-workers {
        width: 80%;
        margin: 150px auto 70px;
        color: #fff;
    }

    .admin-workers__container {
        background: rgba(2, 21, 39, 0.86);
        border: 1px solid rgba(191, 168, 136, 0.3);
        padding: 30px;
        backdrop-filter: blur(10px);
    }

    .admin-workers__head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        margin-bottom: 25px;
    }

    .admin-workers__subtitle {
        color: #bfa888;
        letter-spacing: 2px;
        font-size: 12px;
        margin-bottom: 6px;
    }

    .admin-workers__head h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 38px;
        margin: 0;
    }

    .admin-workers__table-wrap {
        overflow-x: auto;
    }

    .admin-workers__table {
        width: 100%;
        border-collapse: collapse;
    }

    .admin-workers__table th,
    .admin-workers__table td {
        border-bottom: 1px solid rgba(191, 168, 136, 0.2);
        padding: 14px 10px;
        text-align: left;
        vertical-align: middle;
    }

    .admin-workers__table th {
        font-size: 12px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #bfa888;
    }

    .admin-avatar {
        width: 56px;
        height: 56px;
        object-fit: cover;
        border: 1px solid rgba(191, 168, 136, 0.5);
    }

    .admin-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .admin-btn {
        background: transparent;
        color: #fff;
        border: 1px solid rgba(191, 168, 136, 0.5);
        padding: 10px 16px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .admin-btn:hover {
        color: #bfa888;
        border-color: #bfa888;
    }

    .admin-btn--primary {
        background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
        color: #021527;
        border-color: transparent;
        font-weight: 600;
    }

    .admin-btn--primary:hover {
        color: #021527;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(191, 168, 136, 0.35);
    }

    .admin-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 20px;
        z-index: 2000;
    }

    .admin-modal {
        width: 100%;
        max-width: 560px;
        background: #021527;
        border: 1px solid rgba(191, 168, 136, 0.5);
        padding: 25px;
    }

    .admin-modal h3 {
        margin: 0 0 20px;
        color: #bfa888;
        letter-spacing: 1px;
    }

    .admin-form-group {
        margin-bottom: 15px;
    }

    .admin-form-group label {
        display: block;
        margin-bottom: 7px;
        font-size: 12px;
        color: #bfa888;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .admin-form-group input {
        width: 100%;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.16);
        color: #fff;
        padding: 12px;
        outline: none;
    }

    .admin-form-group input:focus {
        border-color: #bfa888;
    }

    .admin-modal--view {
        max-width: 420px;
        text-align: center;
    }

    .admin-modal--view img {
        width: 100%;
        max-height: 300px;
        object-fit: cover;
        border: 1px solid rgba(191, 168, 136, 0.45);
        margin-bottom: 18px;
    }

    .admin-modal--view h3 {
        margin-bottom: 6px;
        color: #fff;
        font-size: 28px;
        font-family: 'Cormorant Garamond', serif;
    }

    .admin-modal--view p {
        color: #bfa888;
        margin-bottom: 20px;
    }

    @@media (max-width: 768px) {
        .admin-workers {
            width: 92%;
            margin-top: 165px;
        }

        .admin-workers__head {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

<script>
    function openWorkerForm(mode, id, name, role, imageUrl) {
        const overlay = document.getElementById('workerFormOverlay');
        const title = document.getElementById('workerFormTitle');

        document.getElementById('workerId').value = id || '';
        document.getElementById('workerName').value = name || '';
        document.getElementById('workerRole').value = role || '';
        document.getElementById('workerImage').value = imageUrl || '';

        title.innerText = mode === 'edit' ? 'Edit Worker' : 'Create Worker';

        overlay.style.display = 'flex';
    }

    function openViewModal(name, role, imageUrl) {
        document.getElementById('viewName').innerText = name;
        document.getElementById('viewRole').innerText = role;
        document.getElementById('viewImage').src = imageUrl;

        document.getElementById('workerViewOverlay').style.display = 'flex';
    }

    function closeById(id) {
        document.getElementById(id).style.display = 'none';
    }

    function closeOverlay(event, id) {
        if (event.target.id === id) {
            closeById(id);
        }
    }
</script>
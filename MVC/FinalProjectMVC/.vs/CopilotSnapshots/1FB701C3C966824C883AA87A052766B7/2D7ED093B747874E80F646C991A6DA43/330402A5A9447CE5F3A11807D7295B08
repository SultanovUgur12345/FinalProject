using System.Net.Http.Json;
using FinalProjectMVC.ViewModels;
using Microsoft.AspNetCore.Mvc;

namespace FinalProjectMVC.Areas.Admin.Controllers
{
    [Area("Admin")]
    public class WorkersController : Controller
    {
        private readonly IHttpClientFactory _httpClientFactory;

        public WorkersController(IHttpClientFactory httpClientFactory)
        {
            _httpClientFactory = httpClientFactory;
        }

        [HttpGet]
        public async Task<IActionResult> Index()
        {
            var client = _httpClientFactory.CreateClient("WorkerApi");
            var response = await client.GetAsync("api/worker");

            if (!response.IsSuccessStatusCode)
            {
                ModelState.AddModelError(string.Empty, "Workers could not be loaded from API.");
                return View(Enumerable.Empty<WorkerVM>());
            }

            var workers = await response.Content.ReadFromJsonAsync<List<WorkerVM>>() ?? new List<WorkerVM>();
            return View(workers);
        }

        [HttpGet]
        public IActionResult Create()
        {
            return View(new WorkerVM());
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Create(WorkerVM model)
        {
            if (!ModelState.IsValid)
            {
                return View(model);
            }

            var client = _httpClientFactory.CreateClient("WorkerApi");
            var response = await client.PostAsJsonAsync("api/worker", model);

            if (!response.IsSuccessStatusCode)
            {
                ModelState.AddModelError(string.Empty, "Worker create request failed.");
                return View(model);
            }

            return RedirectToAction(nameof(Index));
        }

        [HttpGet]
        public async Task<IActionResult> Edit(int id)
        {
            var client = _httpClientFactory.CreateClient("WorkerApi");
            var response = await client.GetAsync($"api/worker/{id}");

            if (!response.IsSuccessStatusCode)
            {
                return NotFound();
            }

            var worker = await response.Content.ReadFromJsonAsync<WorkerVM>();
            if (worker is null)
            {
                return NotFound();
            }

            return View(worker);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> Edit(WorkerVM model)
        {
            if (!ModelState.IsValid)
            {
                return View(model);
            }

            var client = _httpClientFactory.CreateClient("WorkerApi");
            var response = await client.PutAsJsonAsync($"api/worker/{model.Id}", model);

            if (!response.IsSuccessStatusCode)
            {
                ModelState.AddModelError(string.Empty, "Worker update request failed.");
                return View(model);
            }

            return RedirectToAction(nameof(Index));
        }
    }
}

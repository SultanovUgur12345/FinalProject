* {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Roboto', sans-serif;
            min-height: 100vh;
            color: #fff;
            position: relative;
            display: flex;
            flex-direction: column;
        }

        :root {
            --header-offset: 150px;
        }

        /* Arxa plan ÅŸÉ™kli */
        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: url('https://images.pexels.com/photos/12749728/pexels-photo-12749728.jpeg?auto=compress&cs=tinysrgb&w=1600');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            z-index: -2;
        }

        /* Overlay - qaranlÄ±q effekt */
        body::after {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(2, 21, 39, 0.85) 0%, rgba(10, 26, 42, 0.9) 100%);
            z-index: -1;
        }

         /* ========== FIXED HEADER WRAPPER ========== */
        #qodef-fixed-header-wrapper {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1100;
        }

        /* ========== TOP AREA ========== */
        #qodef-top-area {
            background-color: transparent;
            border-bottom: none;
            font-size: 13px;
            transition: all 0.3s ease;
        }

        #qodef-top-area-inner {
            width: 80%;
            margin: 0 auto;
            padding: 10px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .qodef-widget-holder {
            display: flex;
            align-items: center;
            gap: 30px;
        }

        .qodef-widget-holder a {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
        }

        .qodef-widget-holder a:hover {
            color: #bfa888;
        }

        .qodef-widget-holder p {
            color: rgba(255, 255, 255, 0.8);
            font-size: 13px;
            margin: 0;
        }

        /* ========== MAIN HEADER ========== */
        #qodef-page-header {
            position: relative;
            background-color: transparent;
            backdrop-filter: none;
            box-shadow: none;
            transition: all 0.4s cubic-bezier(0.2, 0.95, 0.4, 1);
            z-index: 1000;
        }

        /* Sticky Header */
        #qodef-page-header.qodef-header--sticky {
            background-color: rgba(2, 21, 39, 0.96);
            backdrop-filter: blur(10px);
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
            animation: slideDown 0.4s ease;
        }

        @keyframes slideDown {
            from {
                transform: translateY(-100%);
            }

            to {
                transform: translateY(0);
            }
        }

        #qodef-page-header-inner {
            width: 80%;
            margin: 0 auto;
            padding: 15px 30px;
            display: grid;
            grid-template-columns: 240px minmax(0, 1fr) 240px;
            align-items: center;
            gap: 20px;
        }

        .qodef-header-tools-left,
        .qodef-header-tools-right {
            display: flex;
            align-items: center;
            min-width: 240px;
        }

        .qodef-header-tools-left {
            justify-content: flex-start;
        }

        .qodef-header-tools-right {
            justify-content: flex-end;
            gap: 14px;
        }

        .qodef-header-user {
            position: relative;
            z-index: 20;
        }

        .qodef-user-opener {
            width: 36px;
            height: 36px;
            border: 1px solid rgba(191, 168, 136, 0.45);
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .qodef-user-opener:hover {
            color: #bfa888;
            border-color: #bfa888;
            background: rgba(191, 168, 136, 0.08);
        }

        .qodef-header-user.active .qodef-user-opener {
            color: #bfa888;
            border-color: #bfa888;
            background: rgba(191, 168, 136, 0.08);
        }

        .qodef-user-dropdown {
            position: absolute;
            top: calc(100% + 12px);
            right: 0;
            min-width: 145px;
            background: #fff;
            border-radius: 4px;
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
            padding: 8px 0;
            opacity: 0;
            visibility: hidden;
            transform: translateY(8px);
            transition: all 0.25s ease;
        }

        .qodef-user-dropdown a {
            display: block;
            padding: 10px 16px;
            color: #2c3a47;
            font-size: 13px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .qodef-user-dropdown a:hover {
            background: #f7f7f7;
            color: #bfa888;
            padding-left: 20px;
        }

        .qodef-user-dropdown a.active {
            background: #f7f7f7;
            color: #bfa888;
            padding-left: 20px;
        }

        .qodef-header-user:hover .qodef-user-dropdown,
        .qodef-header-user:focus-within .qodef-user-dropdown {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .qodef-header-center-wrap {
            width: 100%;
            display: flex;
            justify-content: center;
            min-width: 0;
        }

        .qodef-header-center-wrap .qodef-header-navigation>ul {
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
        }

        .qodef-header-menu-logo {
            margin: 0 8px;
        }

        .qodef-header-menu-logo .qodef-header-logo-link {
            display: inline-flex;
            align-items: center;
            padding: 0 8px;
        }

        .qodef-header-menu-logo .qodef-header-logo-link img {
            max-height: 62px;
        }

        /* ========== LOGO ========== */
        .qodef-header-logo-link {
            display: inline-block;
            flex-shrink: 0;
            transition: opacity 0.3s ease;
        }

        .qodef-header-logo-link:hover {
            opacity: 0.85;
        }

        .qodef-header-logo-link img {
            max-height: 70px;
            width: auto;
            transition: all 0.3s ease;
        }

        .qodef-header--sticky .qodef-header-logo-link img {
            max-height: 55px;
        }

        /* ========== SEARCH FORM ========== */
        .qodef-search-form {
            position: relative;
        }

        .qodef-search-form-inner {
            display: flex;
            align-items: center;
            border-bottom: 1px solid transparent;
            transition: all 0.3s ease;
        }

        .qodef-search-form-inner:hover,
        .qodef-search-form-inner:focus-within {
            border-bottom-color: #bfa888;
        }

        .qodef-search-form-field {
            background: transparent;
            border: none;
            padding: 8px 0;
            font-size: 14px;
            font-weight: 400;
            color: #fff;
            outline: none;
            width: 0;
            opacity: 0;
            pointer-events: none;
            transition: width 0.35s ease, opacity 0.2s ease;
        }

        .qodef-search-form-field::-webkit-search-cancel-button,
        .qodef-search-form-field::-webkit-search-decoration,
        .qodef-search-form-field::-webkit-search-results-button,
        .qodef-search-form-field::-webkit-search-results-decoration {
            -webkit-appearance: none;
            appearance: none;
            display: none;
        }

        .qodef-search-form.is-open .qodef-search-form-field,
        .qodef-search-form:focus-within .qodef-search-form-field {
            width: 220px;
            opacity: 1;
            pointer-events: auto;
        }

        .qodef-search-form-field::placeholder {
            color: rgba(255, 255, 255, 0.6);
            font-size: 13px;
            font-weight: 300;
        }

        .qodef-search-form-button {
            background: transparent;
            border: none;
            cursor: pointer;
            padding: 5px 0 5px 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.3s ease;
        }

        .qodef-search-form-button:hover {
            opacity: 0.7;
        }

        .qodef-search-form-button svg {
            fill: #fff;
            width: 18px;
            height: 18px;
            transition: fill 0.3s ease;
        }

        .qodef-search-form-inner:hover .qodef-search-form-button svg {
            fill: #bfa888;
        }

        /* ========== NAVIGATION ========== */
        .qodef-header-navigation ul {
            list-style: none;
            display: flex;
            margin: 0;
            padding: 0;
        }

        .qodef-header-navigation>ul>li {
            position: relative;
        }

        .qodef-header-navigation>ul>li>a {
            display: flex;
            align-items: center;
            gap: 5px;
            position: relative;
            padding: 10px 18px;
            font-size: 14px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #fff;
            text-decoration: none;
            transition: all 0.3s ease;
        }

        .qodef-header-navigation>ul>li>a::before,
        .qodef-header-navigation>ul>li>a::after {
            content: '';
            position: absolute;
            left: 18px;
            bottom: 4px;
            height: 2px;
            width: calc(100% - 36px);
            pointer-events: none;
        }

        .qodef-header-navigation>ul>li>a::before {
            background: rgba(191, 168, 136, 0.22);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.28s ease;
        }

        .qodef-header-navigation>ul>li>a::after {
            background: #bfa888;
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.35s ease;
        }

        .qodef-header-navigation>ul>li>a:hover {
            color: #bfa888;
        }

        .qodef-header-navigation>ul>li.active>a {
            color: #d6c09b;
        }

        .qodef-header-navigation>ul>li.active>a::before,
        .qodef-header-navigation>ul>li.active>a::after {
            transform: scaleX(1);
        }

        .qodef-header-navigation>ul>li.active>a::after {
            background: #d6c09b;
        }

        .qodef-header-navigation>ul>li:hover>a::before,
        .qodef-header-navigation>ul>li:hover>a::after,
        .qodef-header-navigation>ul>li>a:hover::before,
        .qodef-header-navigation>ul>li>a:hover::after,
        .qodef-header-navigation>ul>li>a:focus-visible::before,
        .qodef-header-navigation>ul>li>a:focus-visible::after {
            transform: scaleX(1);
        }

        .qodef-menu-item-arrow {
            width: 10px;
            height: auto;
            fill: currentColor;
            transition: transform 0.3s ease;
        }

        .qodef-header-navigation .qodef-book-btn>a {
            background: #d6c09b;
            color: #021527;
            border-radius: 999px;
            padding: 10px 24px;
            font-weight: 700;
            box-shadow: 0 8px 18px rgba(214, 192, 155, 0.3);
            transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .qodef-header-navigation .qodef-book-btn>a::before,
        .qodef-header-navigation .qodef-book-btn>a::after {
            display: none !important;
        }

        .qodef-header-navigation .qodef-book-btn>a:hover,
        .qodef-header-navigation .qodef-book-btn>a:focus-visible {
            background: #c4a86f;
            color: #021527;
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 12px 24px rgba(214, 192, 155, 0.45);
        }

        .qodef-header-navigation>ul>li:hover>a .qodef-menu-item-arrow {
            transform: rotate(180deg);
        }

        .qodef-drop-down-second {
            position: absolute;
            top: 100%;
            left: 0;
            width: 240px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s ease;
            z-index: 1000;
        }

        .qodef-header-navigation li:hover>.qodef-drop-down-second {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        .qodef-drop-down-second-inner {
            background: #fff;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
            border-radius: 4px;
            padding: 15px 0;
        }

        .sub-menu {
            flex-direction: column !important;
        }

        .sub-menu li a {
            display: block;
            padding: 8px 25px;
            color: #333;
            text-decoration: none;
            font-size: 13px;
            font-weight: 400;
            letter-spacing: 0.3px;
            transition: all 0.3s ease;
        }

        .sub-menu li a:hover {
            color: #bfa888;
            background-color: #f8f8f8;
            padding-left: 30px;
        }

        /* ========== SIDE AREA OPENER ========== */
        .qodef-side-area-opener {
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.3s ease;
        }

        .qodef-side-area-opener:hover {
            opacity: 0.7;
        }

        .qodef-m-lines {
            display: flex;
            flex-direction: column;
            gap: 5px;
            width: 26px;
        }

        .qodef-m-line {
            height: 2px;
            width: 100%;
            background-color: #fff;
            transition: all 0.3s ease;
            border-radius: 2px;
        }

        .qodef-side-area-opener:hover .qodef-m-line:nth-child(1) {
            width: 70%;
        }

        .qodef-side-area-opener:hover .qodef-m-line:nth-child(3) {
            width: 70%;
        }

        /* ========== RESPONSIVE HEADER ========== */
        @media (max-width: 1100px) {
            #qodef-page-header-inner {
                padding: 15px 20px;
                grid-template-columns: 200px minmax(0, 1fr) 200px;
                gap: 20px;
            }

            .qodef-header-tools-left,
            .qodef-header-tools-right {
                min-width: 200px;
            }

            .qodef-header-navigation>ul>li>a {
                padding: 8px 12px;
                font-size: 12px;
            }
        }

        @media (max-width: 900px) {
            #qodef-page-header-inner {
                grid-template-columns: 1fr;
                padding: 15px 20px;
            }

            .qodef-header-tools-left,
            .qodef-header-tools-right {
                justify-content: center;
            }

            .qodef-header-menu-logo .qodef-header-logo-link img {
                max-height: 50px;
            }

            .qodef-header-navigation>ul {
                flex-wrap: wrap;
                justify-content: center;
            }
        }

        @media (max-width: 768px) {
            #qodef-top-area-inner {
                flex-direction: column;
                text-align: center;
                padding: 10px 15px;
            }

            .qodef-widget-holder {
                justify-content: center;
                flex-wrap: wrap;
                gap: 15px;
            }

            .qodef-header-navigation>ul>li>a {
                padding: 6px 10px;
                font-size: 11px;
            }

            .qodef-drop-down-second {
                position: static;
                width: 100%;
                opacity: 0;
                transform: none;
                display: none;
            }

            .qodef-header-navigation li:hover>.qodef-drop-down-second {
                display: block;
                opacity: 1;
            }

            .sub-menu {
                background: rgba(0, 0, 0, 0.1);
                padding-left: 20px;
            }

            .sub-menu li a {
                color: #fff;
            }
        }

        @media (max-width: 480px) {
            .qodef-header-logo-link img {
                max-height: 50px;
            }

            .qodef-search-form-field {
                width: 120px;
                font-size: 12px;
            }

            .qodef-search-form-field:focus {
                width: 150px;
            }
        }

        /* Account Container */
        .account-container {
            flex: 1;
            min-height: calc(100vh - var(--header-offset) - 90px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: calc(var(--header-offset) + 28px) 20px 60px;
        }

        .account-card {
            background: rgba(2, 21, 39, 0.75);
            backdrop-filter: blur(12px);
            border-radius: 0px;
            width: 100%;
            max-width: 500px;
            padding: 45px 50px;
            border: 1px solid rgba(191, 168, 136, 0.3);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            transition: all 0.4s ease;
        }

        .account-card:hover {
            border-color: rgba(191, 168, 136, 0.6);
            background: rgba(2, 21, 39, 0.85);
        }

        /* Tabs */
        .account-tabs {
            display: flex;
            gap: 30px;
            margin-bottom: 35px;
            border-bottom: 1px solid rgba(191, 168, 136, 0.3);
            padding-bottom: 15px;
        }

        .tab-btn {
            background: none;
            border: none;
            color: #aaa;
            font-size: 18px;
            font-weight: 600;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s;
            padding: 5px 0;
            position: relative;
        }

        .tab-btn.active {
            color: #bfa888;
        }

        .tab-btn.active::after {
            content: '';
            position: absolute;
            bottom: -16px;
            left: 0;
            width: 100%;
            height: 2px;
            background: #bfa888;
        }

        .tab-btn:hover {
            color: #bfa888;
        }

        /* Form Styles - height eyni olmasÄ± Ã¼Ã§Ã¼n */
        .account-form {
            visibility: hidden;
            opacity: 0;
            height: 0;
            overflow: hidden;
            transition: visibility 0.3s, opacity 0.3s;
        }

        .account-form.active {
            visibility: visible;
            opacity: 1;
            height: auto;
        }

        .form-group {
            margin-bottom: 25px;
        }

        .form-label {
            display: block;
            font-size: 11px;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            color: #bfa888;
            margin-bottom: 10px;
            font-weight: 500;
        }

        .form-input {
            width: 100%;
            padding: 16px 20px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 0px;
            color: #fff;
            font-size: 15px;
            transition: all 0.3s;
        }

        .form-input:focus {
            outline: none;
            border-color: #bfa888;
            background: rgba(255, 255, 255, 0.12);
        }

        .form-input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        /* Password wrapper */
        .password-wrapper {
            position: relative;
        }

        .password-toggle {
            position: absolute;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #bfa888;
            transition: all 0.3s;
        }

        .password-toggle:hover {
            color: #fff;
        }

        /* Submit Button */
        .submit-btn {
            background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
            border: none;
            padding: 16px 35px;
            border-radius: 0px;
            color: #021527;
            font-weight: 700;
            font-size: 13px;
            letter-spacing: 2px;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 15px;
        }

        .submit-btn:hover {
            transform: translateY(-3px);
            background: linear-gradient(135deg, #d4b898 0%, #bfa888 100%);
            box-shadow: 0 12px 30px rgba(191, 168, 136, 0.35);
        }

        /* Forgot password */
        .forgot-link {
            text-align: right;
            margin-top: 15px;
        }

        .forgot-link a {
            color: #aaa;
            font-size: 12px;
            text-decoration: none;
            transition: all 0.3s;
        }

        .forgot-link a:hover {
            color: #bfa888;
        }

        /* Message */
        .form-message {
            margin-top: 20px;
            padding: 12px;
            text-align: center;
            font-size: 13px;
            border-radius: 0px;
            display: none;
        }

        .form-message.success {
            background: rgba(40, 167, 69, 0.2);
            border: 1px solid #28a745;
            color: #28a745;
            display: block;
        }

        .form-message.error {
            background: rgba(220, 53, 69, 0.2);
            border: 1px solid #dc3545;
            color: #dc3545;
            display: block;
        }

         /* ========== FOOTER ========== */
        .footer {
            background: #021527;
            color: #fff;
            padding: 60px 40px 30px;
        }

        .footer-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            width: 80%;
            margin: 0 auto;
            gap: 40px;
            margin-bottom: 40px;
        }

        .footer-col h5 {
            font-size: 18px;
            margin-bottom: 20px;
        }

        .footer-col p,
        .footer-col a {
            color: #ccc;
            text-decoration: none;
            line-height: 28px;
            font-size: 14px;
        }

        .footer-col a:hover {
            color: #bfa888;
        }

        .social-icons {
            display: flex;
            gap: 20px;
            margin-top: 20px;
        }

        .social-icons a {
            color: #ccc;
            font-size: 14px;
        }

        .social-icons a:hover {
            color: #bfa888;
        }

        .footer-bottom {
            text-align: center;
            padding-top: 30px;
            border-top: 1px solid #334;
            font-size: 14px;
            color: #888;
        }

        @media (max-width: 1024px) {
            .footer-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media (max-width: 768px) {
            .footer-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Responsive */
        @media (max-width: 768px) {
            :root {
                --header-offset: 190px;
            }

            .header {
                padding: 15px 20px;
                flex-wrap: wrap;
                gap: 15px;
            }
            .nav-menu ul {
                flex-wrap: wrap;
                gap: 15px;
            }
            .account-card {
                padding: 30px 25px;
                margin: 0 15px;
            }
            .account-tabs {
                gap: 20px;
            }
            .tab-btn {
                font-size: 16px;
            }
        }

        @media (max-width: 480px) {
            :root {
                --header-offset: 210px;
            }
        }

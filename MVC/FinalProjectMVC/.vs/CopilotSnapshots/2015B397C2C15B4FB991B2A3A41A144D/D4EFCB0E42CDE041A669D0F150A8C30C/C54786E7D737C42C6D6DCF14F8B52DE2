using FinalProjectMVC.ViewModels.Worker;
using System.Net;
using System.Net.Http.Json;
using static IWorkerService;

public class WorkerApiService : IWorkerApiService
{
    private readonly HttpClient _httpClient;

    public WorkerApiService(HttpClient httpClient)
    {
        _httpClient = httpClient;
    }

    public async Task<List<WorkerCreateVM>> GetAllAsync()
    {
        return await _httpClient.GetFromJsonAsync<List<WorkerCreateVM>>("api/Worker/GetAll");
    }

    public async Task<WorkerCreateVM> GetByIdAsync(int id)
    {
        return await _httpClient.GetFromJsonAsync<WorkerCreateVM>($"api/Worker/Get/{id}");
    }

    public async Task CreateAsync(WorkerCreateVM dto)
    {
        var response = await _httpClient.PostAsJsonAsync("api/Worker/Create", dto);
        if (!response.IsSuccessStatusCode)
        {
            var body = await response.Content.ReadAsStringAsync();
            throw new HttpRequestException(
                $"Create failed. Status: {(int)response.StatusCode} {response.StatusCode}. Response: {body}",
                null,
                response.StatusCode);
        }
    }

    public async Task UpdateAsync(int id, WorkerCreateVM dto)
    {
        await _httpClient.PutAsJsonAsync($"api/Worker/Update/{id}", dto);
    }

    public async Task DeleteAsync(int id)
    {
        await _httpClient.DeleteAsync($"api/Worker/Delete/{id}");
    }
}
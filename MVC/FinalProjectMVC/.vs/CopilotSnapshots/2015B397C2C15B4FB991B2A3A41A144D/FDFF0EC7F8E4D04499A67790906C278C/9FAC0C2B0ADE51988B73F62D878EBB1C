@using FinalProjectMVC.ViewModels.Worker
@inject IConfiguration Configuration
@model IEnumerable<WorkerGetVM>

@{
    ViewData["Title"] = "Workers - GetAll";
    string apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<section class="admin-workers">
    <div class="admin-workers__container">
        <div class="admin-workers__head">
            <div>
                <p class="admin-workers__subtitle">ADMIN PANEL</p>
                <h1>Workers List</h1>
            </div>

            <a asp-area="Admin" asp-controller="Workers" asp-action="Create" class="admin-btn admin-btn--primary">+ Create Worker</a>
        </div>

        @if (TempData["WorkerError"] is string errorMessage)
        {
            <div class="admin-error">@errorMessage</div>
        }

        <div class="admin-workers__table-wrap">
            <table class="admin-workers__table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Image</th>
                        <th>Full Name</th>
                        <th>Role</th>
                        <th>Experience</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>
                                    <img class="admin-avatar"
                                         src="@(string.IsNullOrWhiteSpace(item.Image) ? "" : $"{apiBaseUrl}{item.Image}")"
                                         alt="@item.FullName" />
                                </td>
                                <td>@item.FullName</td>
                                <td>@item.Position</td>
                                <td>@item.ExperienceYears year</td>
                                <td>
                                    <div class="admin-actions">
                                        <a asp-area="Admin"
                                           asp-controller="Workers"
                                           asp-action="Detail"
                                           asp-route-id="@item.Id"
                                           class="admin-btn">Get</a>

                                        <a asp-area="Admin"
                                           asp-controller="Workers"
                                           asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="admin-btn">Edit</a>

                                        <button type="button"
                                                class="admin-btn admin-btn--danger open-delete-modal"
                                                data-id="@item.Id"
                                                data-name="@item.FullName"
                                                data-position="@item.Position"
                                                data-experience="@item.ExperienceYears"
                                                data-image="@(string.IsNullOrWhiteSpace(item.Image) ? "" : $"{apiBaseUrl}{item.Image}")">
                                            Delete
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" style="text-align:center; color:#bfa888;">No workers found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<div class="delete-modal" id="deleteModal">
    <div class="delete-modal__overlay" id="deleteModalOverlay"></div>

    <div class="delete-modal__content">
        <button type="button" class="delete-modal__close" id="deleteModalClose">&times;</button>

        <div class="delete-modal__top">
            <p class="delete-modal__subtitle">DELETE CONFIRMATION</p>
            <h2>Are you sure?</h2>
            <p class="delete-modal__text">
                This worker will be permanently deleted.
            </p>
        </div>

        <div class="delete-modal__worker">
            <img id="deleteWorkerImage" src="" alt="Worker Image" class="delete-modal__image" />

            <div class="delete-modal__info">
                <h3 id="deleteWorkerName"></h3>
                <p><strong>Position:</strong> <span id="deleteWorkerPosition"></span></p>
                <p><strong>Experience:</strong> <span id="deleteWorkerExperience"></span> year</p>
            </div>
        </div>

        <form method="post"
              asp-area="Admin"
              asp-controller="Workers"
              asp-action="Delete"
              id="deleteForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteWorkerId" />

            <div class="delete-modal__actions">
                <button type="button" class="admin-btn" id="cancelDelete">Cancel</button>
                <button type="submit" class="admin-btn admin-btn--danger-fill">Yes, Delete</button>
            </div>
        </form>
    </div>
</div>

<style>
    .admin-workers {
        width: 80%;
        margin: 150px auto 70px;
        color: #fff;
    }

    .admin-workers__container {
        background: rgba(2, 21, 39, 0.86);
        border: 1px solid rgba(191, 168, 136, 0.3);
        padding: 30px;
        backdrop-filter: blur(10px);
    }

    .admin-workers__head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        margin-bottom: 25px;
    }

    .admin-workers__subtitle {
        color: #bfa888;
        letter-spacing: 2px;
        font-size: 12px;
        margin-bottom: 6px;
    }

    .admin-workers__head h1 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 38px;
        margin: 0;
    }

    .admin-error {
        margin: 0 0 16px;
        padding: 10px 12px;
        border: 1px solid rgba(220, 53, 69, 0.7);
        background: rgba(220, 53, 69, 0.15);
        color: #ffb3bd;
        font-size: 13px;
    }

    .admin-workers__table-wrap {
        overflow-x: auto;
    }

    .admin-workers__table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-workers__table th,
        .admin-workers__table td {
            border-bottom: 1px solid rgba(191, 168, 136, 0.2);
            padding: 14px 10px;
            text-align: left;
            vertical-align: middle;
        }

        .admin-workers__table th {
            font-size: 12px;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: #bfa888;
        }

    .admin-avatar {
        width: 56px;
        height: 56px;
        object-fit: cover;
        border: 1px solid rgba(191, 168, 136, 0.5);
        border-radius: 6px;
        background: rgba(255,255,255,0.04);
    }

    .admin-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .admin-btn {
        display: inline-block;
        text-decoration: none;
        background: transparent;
        color: #fff;
        border: 1px solid rgba(191, 168, 136, 0.5);
        padding: 10px 16px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .admin-btn:hover {
            color: #bfa888;
            border-color: #bfa888;
        }

    .admin-btn--primary {
        background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
        color: #021527;
        border-color: transparent;
        font-weight: 600;
    }

        .admin-btn--primary:hover {
            color: #021527;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(191, 168, 136, 0.35);
        }

    .admin-btn--danger {
        border-color: rgba(220, 53, 69, 0.6);
        color: #ffb3bd;
    }

        .admin-btn--danger:hover {
            border-color: #dc3545;
            color: #fff;
            background: rgba(220, 53, 69, 0.18);
        }

    .admin-btn--danger-fill {
        background: linear-gradient(135deg, #dc3545 0%, #b02a37 100%);
        color: #fff;
        border-color: transparent;
        font-weight: 600;
    }

        .admin-btn--danger-fill:hover {
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(220, 53, 69, 0.35);
        }

    .delete-modal {
        position: fixed;
        inset: 0;
        display: none;
        z-index: 9999;
    }

        .delete-modal.show {
            display: block;
        }

    .delete-modal__overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.7);
    }

    .delete-modal__content {
        position: relative;
        width: min(92%, 560px);
        margin: 80px auto;
        background: rgba(2, 21, 39, 0.96);
        border: 1px solid rgba(191, 168, 136, 0.3);
        padding: 28px;
        color: #fff;
        z-index: 2;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    }

    .delete-modal__close {
        position: absolute;
        top: 10px;
        right: 14px;
        background: transparent;
        border: none;
        color: #fff;
        font-size: 28px;
        cursor: pointer;
    }

    .delete-modal__subtitle {
        color: #bfa888;
        letter-spacing: 2px;
        font-size: 12px;
        margin-bottom: 6px;
    }

    .delete-modal__top h2 {
        margin: 0 0 10px;
        font-family: 'Cormorant Garamond', serif;
        font-size: 34px;
    }

    .delete-modal__text {
        color: rgba(255,255,255,0.75);
        margin-bottom: 20px;
    }

    .delete-modal__worker {
        display: flex;
        gap: 18px;
        align-items: center;
        padding: 16px;
        border: 1px solid rgba(191, 168, 136, 0.2);
        background: rgba(255, 255, 255, 0.04);
        margin-bottom: 22px;
    }

    .delete-modal__image {
        width: 90px;
        height: 90px;
        object-fit: cover;
        border: 1px solid rgba(191, 168, 136, 0.4);
        background: rgba(255,255,255,0.04);
    }

    .delete-modal__info h3 {
        margin: 0 0 10px;
        font-size: 22px;
    }

    .delete-modal__info p {
        margin: 6px 0;
        color: rgba(255,255,255,0.82);
    }

    .delete-modal__actions {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
    }

    @@media (max-width: 768px) {
        .admin-workers {
            width: 92%;
            margin-top: 165px;
        }

        .admin-workers__head {
            flex-direction: column;
            align-items: flex-start;
        }
    }

    @@media (max-width: 576px) {
        .delete-modal__content {
            margin: 40px auto;
            padding: 22px;
        }

        .delete-modal__worker {
            flex-direction: column;
            align-items: flex-start;
        }

        .delete-modal__image {
            width: 100%;
            height: 180px;
        }

        .delete-modal__actions {
            flex-direction: column;
        }
    }
</style>

@section Scripts {
    <script>
        const deleteModal = document.getElementById("deleteModal");
        const deleteModalOverlay = document.getElementById("deleteModalOverlay");
        const deleteModalClose = document.getElementById("deleteModalClose");
        const cancelDelete = document.getElementById("cancelDelete");

        const deleteWorkerId = document.getElementById("deleteWorkerId");
        const deleteWorkerName = document.getElementById("deleteWorkerName");
        const deleteWorkerPosition = document.getElementById("deleteWorkerPosition");
        const deleteWorkerExperience = document.getElementById("deleteWorkerExperience");
        const deleteWorkerImage = document.getElementById("deleteWorkerImage");

        const deleteButtons = document.querySelectorAll(".open-delete-modal");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function () {
                const id = this.getAttribute("data-id");
                const name = this.getAttribute("data-name");
                const position = this.getAttribute("data-position");
                const experience = this.getAttribute("data-experience");
                const image = this.getAttribute("data-image");

                deleteWorkerId.value = id;
                deleteWorkerName.textContent = name;
                deleteWorkerPosition.textContent = position;
                deleteWorkerExperience.textContent = experience;
                deleteWorkerImage.src = image || "";
                deleteWorkerImage.style.display = image ? "block" : "none";

                deleteModal.classList.add("show");
                document.body.style.overflow = "hidden";
            });
        });

        function closeDeleteModal() {
            deleteModal.classList.remove("show");
            document.body.style.overflow = "";
        }

        deleteModalClose.addEventListener("click", closeDeleteModal);
        cancelDelete.addEventListener("click", closeDeleteModal);
        deleteModalOverlay.addEventListener("click", closeDeleteModal);
    </script>
}
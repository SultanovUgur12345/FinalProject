@model FaqEditVM

@{
    ViewData["Title"] = "FAQ - Edit";
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">FAQ MANAGEMENT</p>
        <h1>Edit FAQ</h1>
    </div>
    <a asp-area="Admin" asp-controller="Faq" asp-action="Index" class="admin-btn">&#8592; Back to List</a>
</div>

<form method="post"
      asp-area="Admin"
      asp-controller="Faq"
      asp-action="Edit"
      asp-route-id="@Model.Id"
      class="admin-form">

    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="admin-validation"></div>

    <div class="admin-form-group admin-form-group--full">
        <label asp-for="Question">Question</label>
        <input asp-for="Question" class="admin-input" />
        <span asp-validation-for="Question" class="admin-validation"></span>
    </div>

    <div class="admin-form-group admin-form-group--full">
        <label asp-for="Answer">Answer</label>
        <textarea asp-for="Answer" class="admin-input admin-input--area"></textarea>
        <span asp-validation-for="Answer" class="admin-validation"></span>
    </div>

    <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">Update FAQ</button>
    </div>
</form>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/faq-edit.css" />
}
@model FeatureCreateVM

@{
    ViewData["Title"] = "Feature - Create";
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">FEATURE MANAGEMENT</p>
        <h1>Create Feature</h1>
    </div>
    <a asp-area="Admin" asp-controller="Feature" asp-action="Index" class="admin-btn">&#8592; Back to List</a>
</div>

<form method="post"
      enctype="multipart/form-data"
      asp-area="Admin"
      asp-controller="Feature"
      asp-action="Create"
      class="admin-form">

    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="admin-validation"></div>

    <div class="admin-form-group">
        <label asp-for="Title">Title</label>
        <input asp-for="Title" class="admin-input" placeholder="e.g. Professional Crew" />
        <span asp-validation-for="Title" class="admin-validation"></span>
    </div>

    <div class="admin-form-group">
        <label asp-for="Image">Image</label>
        <input asp-for="Image" class="admin-input admin-input--file" type="file" accept="image/*" />
        <span asp-validation-for="Image" class="admin-validation"></span>
    </div>

    <div class="admin-form-group admin-form-group--full">
        <label asp-for="Description">Description</label>
        <textarea asp-for="Description" class="admin-input admin-input--area" placeholder="Enter feature description..."></textarea>
        <span asp-validation-for="Description" class="admin-validation"></span>
    </div>

    <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">Save Feature</button>
    </div>
</form>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/feature-create.css" />
}
@inject IConfiguration Configuration
@model FeatureGetVM

@{
    ViewData["Title"] = "Feature - Detail";
    string apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<section class="admin-workers">
    <div class="admin-workers__container admin-workers__container--form">
        <div class="admin-workers__head">
            <div>
                <p class="admin-workers__subtitle">FEATURE MANAGEMENT</p>
                <h1>Feature Detail</h1>
            </div>
            <a asp-area="Admin" asp-controller="Feature" asp-action="Index" class="admin-btn">Back to List</a>
        </div>

        <div class="worker-detail-grid">
            <div class="worker-detail-image">
                <img src="@(string.IsNullOrWhiteSpace(Model.Image) ? "" : $"{apiBaseUrl}{Model.Image}")"
                     alt="@Model.Title" />
            </div>

            <div class="worker-detail-content">
                <h2>@Model.Title</h2>
                <p>@Model.Description</p>

                <div class="worker-meta">
                    <p><strong>ID:</strong> @Model.Id</p>
                </div>

                <div class="admin-actions">
                    <a asp-area="Admin" asp-controller="Feature" asp-action="Edit" asp-route-id="@Model.Id" class="admin-btn admin-btn--primary">Edit Feature</a>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/feature-detail.css" />
}
@using FinalProjectMVC.ViewModels.Feature
@inject IConfiguration Configuration
@model FeatureEditVM

@{
    ViewData["Title"] = "Feature - Edit";
    string apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">FEATURE MANAGEMENT</p>
        <h1>Edit Feature</h1>
    </div>
    <a asp-area="Admin" asp-controller="Feature" asp-action="Index" class="admin-btn">&#8592; Back to List</a>
</div>

<form method="post"
      asp-area="Admin"
      asp-controller="Feature"
      asp-action="Edit"
      asp-route-id="@Model.Id"
      class="admin-form"
      enctype="multipart/form-data">

    @Html.AntiForgeryToken()

    <input asp-for="Id" type="hidden" />
    <input asp-for="CurrentImage" type="hidden" />

    <div class="admin-form-group">
        <label asp-for="Title">Title</label>
        <input asp-for="Title" class="admin-input" />
        <span asp-validation-for="Title" class="admin-validation"></span>
    </div>

    <div class="admin-form-group admin-form-group--full">
        <label>Current Image</label>
        @if (!string.IsNullOrWhiteSpace(Model.CurrentImage))
        {
            <img src="@($"{apiBaseUrl}{Model.CurrentImage}")" alt="Feature Image" class="admin-worker-image" />
        }
    </div>

    <div class="admin-form-group admin-form-group--full">
        <label asp-for="Image">New Image</label>
        <input asp-for="Image" type="file" class="admin-input admin-input--file" accept="image/*" />
        <span asp-validation-for="Image" class="admin-validation"></span>
    </div>

    <div class="admin-form-group admin-form-group--full">
        <label asp-for="Description">Description</label>
        <textarea asp-for="Description" class="admin-input admin-input--area"></textarea>
        <span asp-validation-for="Description" class="admin-validation"></span>
    </div>

    <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">Update Feature</button>
    </div>
</form>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/feature-edit.css" />
}
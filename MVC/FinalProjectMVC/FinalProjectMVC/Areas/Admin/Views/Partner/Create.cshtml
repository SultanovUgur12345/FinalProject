@using FinalProjectMVC.ViewModels.Partner
@model PartnerCreateVM

@{
    ViewData["Title"] = "Partner - Create";
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">PARTNER MANAGEMENT</p>
        <h1>Add Partner</h1>
    </div>
    <a asp-area="Admin" asp-controller="Partner" asp-action="Index" class="admin-btn">&#8592; Back to List</a>
</div>

<form method="post"
      enctype="multipart/form-data"
      asp-area="Admin"
      asp-controller="Partner"
      asp-action="Create"
      class="admin-form">

    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="admin-validation"></div>

    <div class="admin-form-group admin-form-group--full">
        <label asp-for="Image">Partner Logo / Image</label>
        <input asp-for="Image" class="admin-input admin-input--file" type="file" accept="image/*" />
        <span asp-validation-for="Image" class="admin-validation"></span>
    </div>

    <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">Save Partner</button>
    </div>
</form>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/partner-create.css" />
}
@model PartnerEditVM

@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Partner - Edit";
    var apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">PARTNER MANAGEMENT</p>
        <h1>Edit Partner</h1>
    </div>
    <a asp-area="Admin" asp-controller="Partner" asp-action="Index" class="admin-btn">&#8592; Back to List</a>
</div>

<form method="post"
      enctype="multipart/form-data"
      asp-area="Admin"
      asp-controller="Partner"
      asp-action="Edit"
      asp-route-id="@Model.Id"
      class="admin-form">

    @Html.AntiForgeryToken()
    <input asp-for="CurrentImage" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="admin-validation"></div>

    <div class="admin-form-group admin-form-group--full">
        <label>Current Image</label>
        @if (!string.IsNullOrWhiteSpace(Model.CurrentImage))
        {
            <img src="@($"{apiBaseUrl}{Model.CurrentImage}")" alt="Partner Image" class="admin-partner-image" />
        }
    </div>

    <div class="admin-form-group admin-form-group--full">
        <label asp-for="Image">New Image</label>
        <input asp-for="Image" type="file" class="admin-input admin-input--file" accept="image/*" />
        <span asp-validation-for="Image" class="admin-validation"></span>
    </div>

    <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">Update Partner</button>
    </div>
</form>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/partner-edit.css" />
}
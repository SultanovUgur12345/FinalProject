@using FinalProjectMVC.ViewModels.Partner
@model List<PartnerGetVM>

@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Partners";
    var apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">PARTNER MANAGEMENT</p>
        <h1>Partners <span id="totalPartnersCount">@Model.Count</span></h1>
    </div>
    <a asp-area="Admin" asp-controller="Partner" asp-action="Create" class="admin-btn admin-btn--primary">+ Add Partner</a>
</div>

<div class="admin-table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Image</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>
                            <img class="admin-avatar"
                                 src="@(string.IsNullOrWhiteSpace(item.Image) ? "" : $"{apiBaseUrl}{item.Image}")"
                                 alt="Partner" />
                        </td>
                        <td>
                            <div class="admin-actions">
                                <a asp-area="Admin" asp-controller="Partner" asp-action="Edit" asp-route-id="@item.Id" class="admin-btn admin-btn--sm">Edit</a>
                                <button type="button"
                                        class="admin-btn admin-btn--sm admin-btn--danger open-delete-modal"
                                        data-id="@item.Id"
                                        data-image="@(string.IsNullOrWhiteSpace(item.Image) ? "" : $"{apiBaseUrl}{item.Image}")">
                                    Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="admin-table__empty">No partners found</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Delete Modal -->
<div class="delete-modal" id="deleteModal">
    <div class="delete-modal__overlay" id="deleteModalOverlay"></div>
    <div class="delete-modal__box">
        <div class="delete-modal__preview">
            <img id="modalPartnerImage" src="" alt="Partner" class="delete-modal__img" />
        </div>
        <div class="delete-modal__content">
            <h2 class="delete-modal__title">Delete Partner</h2>
            <p class="delete-modal__text">Are you sure you want to delete this partner?</p>
            <div class="delete-modal__actions">
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="admin-btn admin-btn--danger">Yes, Delete</button>
                </form>
                <button type="button" class="admin-btn" id="cancelDeleteBtn">Cancel</button>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-content__header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
    .admin-content__subtitle { color: #bfa888; letter-spacing: 2px; font-size: 12px; margin-bottom: 8px; }
    .admin-content h1 { font-family: 'Cormorant Garamond', serif; font-size: 40px; margin: 0; }

    .admin-table-container { overflow-x: auto; }
    .admin-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .admin-table thead tr { border-bottom: 1px solid rgba(191,168,136,0.3); }
    .admin-table th { color: #bfa888; text-transform: uppercase; font-size: 11px; letter-spacing: 1px; padding: 12px 14px; text-align: left; font-weight: 600; }
    .admin-table td { padding: 12px 14px; border-bottom: 1px solid rgba(255,255,255,0.06); color: rgba(255,255,255,0.85); vertical-align: middle; }
    .admin-table__empty { text-align: center; color: rgba(255,255,255,0.35); padding: 40px; }

    .admin-avatar { width: 52px; height: 52px; object-fit: cover; border: 1px solid rgba(191,168,136,0.3); background: rgba(255,255,255,0.04); }
    .admin-actions { display: flex; gap: 8px; flex-wrap: wrap; }

    .admin-btn { display: inline-block; text-decoration: none; background: transparent; color: #fff; border: 1px solid rgba(191,168,136,0.5); padding: 10px 18px; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; transition: all 0.3s ease; }
    .admin-btn:hover { color: #bfa888; border-color: #bfa888; }
    .admin-btn--sm { padding: 6px 12px; font-size: 11px; }
    .admin-btn--primary { background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%); color: #021527; border-color: transparent; font-weight: 600; }
    .admin-btn--primary:hover { color: #021527; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(191,168,136,0.35); }
    .admin-btn--danger { background: transparent; color: #ff6b6b; border-color: rgba(255,107,107,0.4); }
    .admin-btn--danger:hover { background: rgba(255,107,107,0.1); color: #ff6b6b; border-color: #ff6b6b; }

    .delete-modal { display: none; position: fixed; inset: 0; z-index: 1000; align-items: center; justify-content: center; }
    .delete-modal.active { display: flex; }
    .delete-modal__overlay { position: absolute; inset: 0; background: rgba(2,21,39,0.85); backdrop-filter: blur(4px); }
    .delete-modal__box { position: relative; z-index: 1; display: flex; gap: 0; max-width: 560px; width: 90%; background: #0c1e2e; border: 1px solid rgba(191,168,136,0.2); }
    .delete-modal__preview { width: 160px; min-height: 180px; flex-shrink: 0; background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .delete-modal__img { width: 100%; height: 100%; object-fit: cover; }
    .delete-modal__content { padding: 28px 24px; display: flex; flex-direction: column; justify-content: center; gap: 12px; }
    .delete-modal__title { font-family: 'Cormorant Garamond', serif; font-size: 24px; margin: 0; color: #fff; }
    .delete-modal__text { color: rgba(255,255,255,0.6); font-size: 14px; margin: 0; }
    .delete-modal__actions { display: flex; gap: 10px; margin-top: 8px; }
</style>

<script>
    document.querySelectorAll(".open-delete-modal").forEach(function (btn) {
        btn.addEventListener("click", function () {
            const id = this.dataset.id;
            const img = this.dataset.image;

            document.getElementById("modalPartnerImage").src = img || "";
            document.getElementById("deleteForm").action = `/Admin/Partner/Delete/${id}`;

            document.getElementById("deleteModal").classList.add("active");
        });
    });

    document.getElementById("cancelDeleteBtn").addEventListener("click", function () {
        document.getElementById("deleteModal").classList.remove("active");
    });

    document.getElementById("deleteModalOverlay").addEventListener("click", function () {
        document.getElementById("deleteModal").classList.remove("active");
    });
</script>

@model List<SettingGetVM>

@{
    ViewData["Title"] = "Settings";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="settings-header">
    <p class="settings-subtitle">SITE MANAGEMENT</p>
    <h1 class="settings-title">Tənzimləmələr</h1>
</div>

@if (TempData["SettingSuccess"] is string msg)
{
    <div class="settings-alert">✔ @msg</div>
}

<div class="settings-cards">
    @foreach (var item in Model?.Where(x => x.Key == "Number" || x.Key == "Email" || x.Key == "WhatsApp" || x.Key == "Instagram" || x.Key == "Twitter" || x.Key == "Youtube") ?? Enumerable.Empty<SettingGetVM>())
    {
        <div class="settings-card" id="card-@item.Id">
            <div class="settings-card__label">
                @(item.Key == "Number" ? "Phone Number" :
                  item.Key == "Email" ? "Email Address" :
                  item.Key == "WhatsApp" ? "WhatsApp" :
                  item.Key == "Instagram" ? "Instagram" :
                  item.Key == "Twitter" ? "Twitter" :
                  item.Key == "Youtube" ? "Youtube" : item.Key)
            </div>
            <div class="settings-card__body">
                <span class="settings-card__value" id="display-@item.Id">@item.Value</span>
                <input class="settings-card__input" id="input-@item.Id" value="@item.Value" style="display:none;" />
            </div>
            <div class="settings-card__actions">
                <button class="s-btn s-btn--edit" id="editBtn-@item.Id" onclick="enableEdit(@item.Id)">Edit</button>
                <button class="s-btn s-btn--save" id="saveBtn-@item.Id" onclick="saveEdit(@item.Id)" style="display:none;">Save</button>
                <button class="s-btn s-btn--cancel" id="cancelBtn-@item.Id" onclick="cancelEdit(@item.Id, '@item.Value')" style="display:none;">Cancel</button>
            </div>
        </div>
    }
</div>

@Html.AntiForgeryToken()

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/setting-index.css" />
}

@section Scripts {
    <script src="~/admin/assets/js/setting-index.js"></script>
}
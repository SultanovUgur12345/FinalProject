@using FinalProjectMVC.ViewModels.ShipHeroVideo
@inject IConfiguration Configuration
@model ShipHeroVideoEditVM

@{
    ViewData["Title"] = "ShipHeroVideo - Edit";
    string apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">SHIP HERO VIDEO MANAGEMENT</p>
        <h1>Edit Hero Video</h1>
    </div>
    <a asp-area="Admin" asp-controller="ShipHeroVideo" asp-action="Index" class="admin-btn">â† Back to List</a>
</div>

<form method="post"
      asp-area="Admin"
      asp-controller="ShipHeroVideo"
      asp-action="Edit"
      asp-route-id="@Model.Id"
      class="admin-form"
      enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <input asp-for="Id" type="hidden" />
    <input asp-for="CurrentVideo" type="hidden" />

    <div class="admin-form-group">
        <label asp-for="Title">Title</label>
        <input asp-for="Title" class="admin-input" />
        <span asp-validation-for="Title" class="admin-validation"></span>
    </div>

    <div class="admin-form-group">
        <label asp-for="SubTitle">Sub Title</label>
        <input asp-for="SubTitle" class="admin-input" />
        <span asp-validation-for="SubTitle" class="admin-validation"></span>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.CurrentVideo))
    {
        <div class="admin-form-group admin-form-group--full">
            <label>Current Video</label>
            <video class="admin-current-video" src="@($"{apiBaseUrl}{Model.CurrentVideo}")" controls></video>
        </div>
    }

    <div class="admin-form-group admin-form-group--full">
        <label asp-for="Video">New Video (leave empty to keep current)</label>
        <input asp-for="Video" type="file" class="admin-input admin-input--file" accept="video/*" />
        <span asp-validation-for="Video" class="admin-validation"></span>
    </div>

    <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">Update Video</button>
    </div>
</form>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/ship-hero-video-edit.css" />
}
@using FinalProjectMVC.ViewModels.ShipHeroVideo
@inject IConfiguration Configuration
@model List<ShipHeroVideoGetVM>

@{
    ViewData["Title"] = "ShipHeroVideo - GetAll";
    string apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<div class="admin-content__header">
    <div>
        <p class="admin-content__subtitle">SHIP HERO VIDEO MANAGEMENT</p>
        <h1>Hero Videos List</h1>
    </div>
    <a asp-area="Admin" asp-controller="ShipHeroVideo" asp-action="Create" class="admin-btn admin-btn--primary">+ Create Video</a>
</div>

<div class="admin-table-container">
    <table class="admin-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Title</th>
                <th>SubTitle</th>
                <th>Video</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Title</td>
                        <td>@item.SubTitle</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.Video))
                            {
                                <video class="admin-video-thumb" src="@($"{apiBaseUrl}{item.Video}")" muted preload="metadata"></video>
                            }
                            else
                            {
                                <span>—</span>
                            }
                        </td>
                        <td>
                            <div class="admin-actions">
                                <a asp-area="Admin" asp-controller="ShipHeroVideo" asp-action="Detail" asp-route-id="@item.Id" class="admin-btn admin-btn--sm">Get</a>
                                <a asp-area="Admin" asp-controller="ShipHeroVideo" asp-action="Edit" asp-route-id="@item.Id" class="admin-btn admin-btn--sm">Edit</a>
                                <button type="button"
                                        class="admin-btn admin-btn--sm admin-btn--danger open-delete-modal"
                                        data-id="@item.Id"
                                        data-title="@item.Title">
                                    Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="admin-table__empty">No videos found</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="delete-modal" id="deleteModal">
    <div class="delete-modal__overlay" id="deleteModalOverlay"></div>
    <div class="delete-modal__content">
        <button type="button" class="delete-modal__close" id="deleteModalClose">&times;</button>
        <div class="delete-modal__top">
            <p class="delete-modal__subtitle">DELETE CONFIRMATION</p>
            <h2>Are you sure?</h2>
            <p class="delete-modal__text">This video will be permanently deleted.</p>
        </div>
        <div class="delete-modal__info" style="margin:20px 0;">
            <h3 id="deleteVideoTitle"></h3>
        </div>
        <form method="post" id="deleteForm" asp-area="Admin" asp-controller="ShipHeroVideo" asp-action="Delete">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteVideoId" />
            <div class="delete-modal__actions">
                <button type="button" class="admin-btn" id="cancelDeleteBtn">Cancel</button>
                <button type="submit" class="admin-btn admin-btn--danger">Delete</button>
            </div>
        </form>
    </div>
</div>

<style>
    .admin-content__header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 28px; flex-wrap: wrap; gap: 16px; }
    .admin-content__subtitle { color: #bfa888; letter-spacing: 2px; font-size: 12px; margin-bottom: 8px; }
    .admin-content h1 { font-family: 'Cormorant Garamond', serif; font-size: 40px; margin: 0; }
    .admin-table-container { overflow-x: auto; }
    .admin-table { width: 100%; border-collapse: collapse; color: #fff; }
    .admin-table th { background: rgba(191,168,136,0.15); color: #bfa888; padding: 12px 16px; text-align: left; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; }
    .admin-table td { padding: 14px 16px; border-bottom: 1px solid rgba(255,255,255,0.07); font-size: 14px; vertical-align: middle; }
    .admin-table__empty { text-align: center; color: rgba(255,255,255,0.4); padding: 40px 0; }
    .admin-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .admin-btn { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; background: rgba(191,168,136,0.15); color: #bfa888; border: 1px solid rgba(191,168,136,0.3); cursor: pointer; font-size: 13px; font-weight: 600; text-decoration: none; transition: 0.3s; }
    .admin-btn:hover { background: rgba(191,168,136,0.28); color: #fff; }
    .admin-btn--primary { background: linear-gradient(135deg,#bfa888 0%,#a68b6a 100%); color: #021527; border-color: transparent; }
    .admin-btn--primary:hover { opacity: 0.88; color: #021527; }
    .admin-btn--sm { padding: 6px 14px; font-size: 12px; }
    .admin-btn--danger { background: rgba(220,53,69,0.15); color: #e06c75; border-color: rgba(220,53,69,0.3); }
    .admin-btn--danger:hover { background: rgba(220,53,69,0.3); color: #fff; }
    .admin-video-thumb { width: 100px; height: 60px; object-fit: cover; border: 1px solid rgba(191,168,136,0.3); }
    .delete-modal { display: none; position: fixed; inset: 0; z-index: 9999; }
    .delete-modal.active { display: block; }
    .delete-modal__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(4px); }
    .delete-modal__content { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); background: #021527; border: 1px solid rgba(191,168,136,0.3); padding: 36px; min-width: 360px; max-width: 90vw; }
    .delete-modal__close { position: absolute; top: 14px; right: 18px; background: none; border: none; color: #bfa888; font-size: 22px; cursor: pointer; }
    .delete-modal__subtitle { color: #bfa888; letter-spacing: 2px; font-size: 12px; margin-bottom: 8px; }
    .delete-modal__text { color: rgba(255,255,255,0.6); font-size: 14px; }
    .delete-modal__actions { display: flex; gap: 12px; margin-top: 24px; }
</style>

<script>
    document.querySelectorAll('.open-delete-modal').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById('deleteVideoId').value = btn.dataset.id;
            document.getElementById('deleteVideoTitle').textContent = btn.dataset.title;
            document.getElementById('deleteModal').classList.add('active');
        });
    });
    document.getElementById('deleteModalClose').addEventListener('click', () => document.getElementById('deleteModal').classList.remove('active'));
    document.getElementById('deleteModalOverlay').addEventListener('click', () => document.getElementById('deleteModal').classList.remove('active'));
    document.getElementById('cancelDeleteBtn').addEventListener('click', () => document.getElementById('deleteModal').classList.remove('active'));
</script>

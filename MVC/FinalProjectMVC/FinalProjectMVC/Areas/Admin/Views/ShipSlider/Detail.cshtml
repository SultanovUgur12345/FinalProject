@using FinalProjectMVC.ViewModels.ShipSlider
@inject IConfiguration Configuration
@model ShipSliderGetVM

@{
    ViewData["Title"] = "ShipSlider - Detail";
    string apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<section class="admin-workers">
    <div class="admin-workers__container admin-workers__container--form">
        <div class="admin-workers__head">
            <div>
                <p class="admin-workers__subtitle">SHIP SLIDER MANAGEMENT</p>
                <h1>Slide Detail</h1>
            </div>
            <div class="admin-actions">
                <a asp-area="Admin" asp-controller="ShipSlider" asp-action="Edit" asp-route-id="@Model.Id" class="admin-btn admin-btn--primary">Edit Slide</a>
                <a asp-area="Admin" asp-controller="ShipSlider" asp-action="Index" class="admin-btn">&#8592; Back to List</a>
            </div>
        </div>

        <div class="slide-detail-grid">
            <div class="slide-detail-image">
                @if (!string.IsNullOrWhiteSpace(Model.Image))
                {
                    <img src="@($"{apiBaseUrl}{Model.Image}")" alt="@Model.Title" />
                }
            </div>

            <div class="slide-detail-content">
                <p class="slide-pretitle">@Model.PreTitle</p>
                <h2>@Model.Title</h2>
                <p class="slide-description">@Model.Description</p>

                <div class="slide-meta">
                    <div class="slide-meta__item">
                        <span class="slide-meta__label">ID</span>
                        <span class="slide-meta__value">@Model.Id</span>
                    </div>
                    <div class="slide-meta__item">
                        <span class="slide-meta__label">Pre Title</span>
                        <span class="slide-meta__value">@Model.PreTitle</span>
                    </div>
                    <div class="slide-meta__item">
                        <span class="slide-meta__label">Title</span>
                        <span class="slide-meta__value">@Model.Title</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/ship-slider-detail.css" />
}
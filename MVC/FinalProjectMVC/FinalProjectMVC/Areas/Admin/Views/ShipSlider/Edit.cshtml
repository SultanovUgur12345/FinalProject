@using FinalProjectMVC.ViewModels.ShipSlider
@inject IConfiguration Configuration
@model ShipSliderEditVM

@{
    ViewData["Title"] = "ShipSlider - Edit";
    string apiBaseUrl = (Configuration["ApiSettings:BaseUrl"] ?? "http://localhost:5147/").TrimEnd('/');
}

<section class="admin-workers">
    <div class="admin-workers__container admin-workers__container--form">
        <div class="admin-workers__head">
            <div>
                <p class="admin-workers__subtitle">SHIP SLIDER MANAGEMENT</p>
                <h1>Edit Ship Slider</h1>
            </div>
            <a asp-area="Admin" asp-controller="ShipSlider" asp-action="Index" class="admin-btn">&#8592; Back to List</a>
        </div>

        <form method="post"
              asp-area="Admin"
              asp-controller="ShipSlider"
              asp-action="Edit"
              asp-route-id="@Model.Id"
              class="admin-form"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />
            <input asp-for="CurrentImage" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="admin-validation"></div>

            <div class="admin-form-group">
                <label asp-for="PreTitle">Pre Title</label>
                <input asp-for="PreTitle" class="admin-input" />
                <span asp-validation-for="PreTitle" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Title">Title</label>
                <input asp-for="Title" class="admin-input" />
                <span asp-validation-for="Title" class="admin-validation"></span>
            </div>

            <div class="admin-form-group admin-form-group--full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="admin-input admin-input--area"></textarea>
                <span asp-validation-for="Description" class="admin-validation"></span>
            </div>

            <div class="admin-form-group admin-form-group--full">
                <label>Current Image</label>
                @if (!string.IsNullOrWhiteSpace(Model.CurrentImage))
                {
                    <img src="@($"{apiBaseUrl}{Model.CurrentImage}")" alt="Slider Image" class="admin-current-image" />
                }
            </div>

            <div class="admin-form-group admin-form-group--full">
                <label asp-for="Image">New Image <span class="admin-form-group__hint">(leave empty to keep current)</span></label>
                <input asp-for="Image" type="file" class="admin-input admin-input--file" />
                <span asp-validation-for="Image" class="admin-validation"></span>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--primary">Save Changes</button>
                <a asp-area="Admin" asp-controller="ShipSlider" asp-action="Index" class="admin-btn">Cancel</a>
            </div>
        </form>
    </div>
</section>

<style>
    .admin-workers { width: 100%; color: #fff; }

    .admin-workers__container {
        background: rgba(2, 21, 39, 0.86);
        border: 1px solid rgba(191, 168, 136, 0.3);
        padding: 30px;
        backdrop-filter: blur(10px);
        border-radius: 12px;
    }

    .admin-workers__container--form { max-width: 980px; margin: 0 auto; }

    .admin-workers__head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
        margin-bottom: 28px;
        flex-wrap: wrap;
    }

    .admin-workers__subtitle { color: #bfa888; letter-spacing: 2px; font-size: 12px; margin-bottom: 6px; }
    .admin-workers__head h1 { font-family: "Cormorant Garamond", serif; font-size: 38px; margin: 0; }

    .admin-form {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
    }

    .admin-form-group { display: flex; flex-direction: column; gap: 8px; }
    .admin-form-group--full { grid-column: 1 / -1; }

    .admin-form-group label {
        color: #bfa888;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
    }

    .admin-form-group__hint {
        color: rgba(255,255,255,0.4);
        font-size: 11px;
        text-transform: none;
        letter-spacing: 0;
        font-weight: 400;
    }

    .admin-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(191, 168, 136, 0.25);
        color: #fff;
        padding: 12px 14px;
        outline: none;
        transition: 0.3s ease;
        font-size: 14px;
        box-sizing: border-box;
    }

    .admin-input:focus { border-color: #bfa888; background: rgba(255, 255, 255, 0.09); }
    .admin-input::placeholder { color: rgba(255, 255, 255, 0.35); }
    .admin-input--area { min-height: 120px; resize: vertical; }
    .admin-input--file { padding: 10px; cursor: pointer; }

    .admin-input--file::file-selector-button {
        background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
        color: #021527;
        border: none;
        padding: 8px 14px;
        margin-right: 12px;
        cursor: pointer;
        font-weight: 600;
    }

    .admin-current-image {
        width: 100%;
        max-height: 280px;
        object-fit: cover;
        border: 1px solid rgba(191, 168, 136, 0.5);
        border-radius: 8px;
    }

    .admin-validation { color: #ff6b6b; font-size: 13px; }

    .admin-form-actions {
        grid-column: 1 / -1;
        display: flex;
        gap: 10px;
        margin-top: 8px;
    }

    .admin-btn {
        display: inline-block;
        text-decoration: none;
        background: transparent;
        color: #fff;
        border: 1px solid rgba(191, 168, 136, 0.5);
        padding: 10px 18px;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .admin-btn:hover { color: #bfa888; border-color: #bfa888; }

    .admin-btn--primary {
        background: linear-gradient(135deg, #bfa888 0%, #a68b6a 100%);
        color: #021527;
        border-color: transparent;
        font-weight: 600;
    }

    .admin-btn--primary:hover { color: #021527; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(191,168,136,0.35); }

    @@media (max-width: 900px) {
        .admin-form { grid-template-columns: 1fr; }
        .admin-form-group--full, .admin-form-actions { grid-column: 1; }
        .admin-workers__head { flex-direction: column; align-items: flex-start; }
    }
</style>

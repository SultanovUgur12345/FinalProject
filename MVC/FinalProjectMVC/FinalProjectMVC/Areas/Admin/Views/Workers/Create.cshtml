@model WorkerCreateVM

@{
    ViewData["Title"] = "Workers - Create";
}

<div class="admin-content__header">
            <div>
                <p class="admin-content__subtitle">WORKER MANAGEMENT</p>
                <h1>Create Worker</h1>
            </div>
            <a asp-area="Admin" asp-controller="Workers" asp-action="Index" class="admin-btn">â† Back to List</a>
        </div>

        <form method="post"
              enctype="multipart/form-data"
              asp-area="Admin"
              asp-controller="Workers"
              asp-action="Create"
              class="admin-form">

            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="admin-validation"></div>

            <div class="admin-form-group">
                <label asp-for="FullName">Full Name</label>
                <input asp-for="FullName" class="admin-input" />
                <span asp-validation-for="FullName" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Position">Role</label>
                <input asp-for="Position" class="admin-input" />
                <span asp-validation-for="Position" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="ExperienceYears">Experience Years</label>
                <input asp-for="ExperienceYears" class="admin-input" type="number" step="0.1" />
                <span asp-validation-for="ExperienceYears" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Image">Worker Image</label>
                <input asp-for="Image" class="admin-input admin-input--file" type="file" />
                <span asp-validation-for="Image" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Languages">Languages</label>
                <input asp-for="Languages" class="admin-input" placeholder="English, Russian, Turkish" />
                <span asp-validation-for="Languages" class="admin-validation"></span>
            </div>

            <div class="admin-form-group">
                <label asp-for="Certificates">Certificates</label>
                <input asp-for="Certificates" class="admin-input" placeholder="AWS, IELTS, PMP" />
                <span asp-validation-for="Certificates" class="admin-validation"></span>
            </div>

            <div class="admin-form-group admin-form-group--full">
                <label asp-for="Description">Description</label>
                <textarea asp-for="Description" class="admin-input admin-input--area"></textarea>
                <span asp-validation-for="Description" class="admin-validation"></span>
            </div>

            <div class="admin-form-actions">
                <button type="submit" class="admin-btn admin-btn--primary">Save Worker</button>
            </div>
        </form>

@section Styles {
    <link rel="stylesheet" href="~/admin/assets/style/workers-create.css" />
}
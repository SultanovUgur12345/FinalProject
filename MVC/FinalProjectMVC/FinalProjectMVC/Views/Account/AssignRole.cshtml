@model FinalProjectMVC.ViewModels.Account.AssignRoleVM

@{
    ViewData["Title"] = "Rol Dəyiş";
}

<h2 class="mb-4">Rol Dəyiş</h2>

<div class="card" style="max-width:480px;">
    <div class="card-body">
        <p><strong>İstifadəçi:</strong> @Model.UserName</p>
        <p><strong>Email:</strong> @Model.Email</p>

        <form asp-action="AssignRole" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="UserName" />
            <input type="hidden" asp-for="Email" />

            <div class="mb-3">
                <label asp-for="Role" class="form-label">Yeni Rol</label>
                <select asp-for="Role" class="form-select">
                    <option value="Admin">Admin</option>
                    <option value="Member">Member</option>
                </select>
                <span asp-validation-for="Role" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Yadda Saxla</button>
            <a asp-action="UserList" class="btn btn-secondary ms-2">Geri</a>
        </form>
    </div>
</div>

@model List<FinalProjectMVC.ViewModels.Account.UserListVM>

@{
    ViewData["Title"] = "İstifadəçilər";
}

<h2 class="mb-4">İstifadəçilər</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Ad Soyad</th>
            <th>İstifadəçi adı</th>
            <th>Email</th>
            <th>Rol</th>
            <th>Əməliyyat</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@user.Role</td>
                <td>
                    @if (user.CanChangeRole)
                    {
                        <a asp-action="AssignRole"
                           asp-route-userId="@user.Id"
                           asp-route-userName="@user.UserName"
                           asp-route-email="@user.Email"
                           asp-route-currentRole="@user.Role"
                           class="btn btn-sm btn-warning">Rol dəyiş</a>
                    }
                    else
                    {
                        <span class="text-muted">-</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

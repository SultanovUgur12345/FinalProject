@using FinalProjectMVC.ViewModels.AboutUs
@model List<AboutUsGetVM>

@if (Model != null && Model.Any())
{
    <section id="aboutSection">
        @{ int aboutIndex = 0; }
        @foreach (var item in Model)
        {
            bool isEven = (aboutIndex % 2 == 0);
            aboutIndex++;

            <div class="about-block alt">
                <div class="container split-grid @(isEven ? "" : "split-grid--reverse")">

                    @if (isEven)
                    {
                        <div class="split-content">
                            <div class="split-content-top">
                                <span class="about-kicker">@item.SubTitle</span>
                                @if (!string.IsNullOrWhiteSpace(item.VideoUrl))
                                {
                                    <button class="split-video-btn js-open-video"
                                            data-video="@item.VideoUrl"
                                            aria-label="Play section video">
                                        <i class="fas fa-play"></i>
                                    </button>
                                }
                            </div>
                            <h2>@item.Title</h2>
                            <p>@item.Description</p>
                            @if (item.Achievements.Any())
                            {
                                <div class="achievements-list">
                                    @foreach (var ach in item.Achievements)
                                    {
                                        <div class="achievement-item">
                                            <span class="anim-border-top"></span>
                                            <span class="anim-border-bottom"></span>
                                            <h4>@ach.Title</h4>
                                            <p>@ach.Description</p>
                                        </div>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.BottomText))
                            {
                                <p style="margin-top: 18px;">@item.BottomText</p>
                            }
                        </div>
                        <div class="split-media">
                            @if (!string.IsNullOrWhiteSpace(item.Image))
                            {
                                <img src="@("http://localhost:5147/" + item.Image)" alt="@item.Title" />
                            }
                            else
                            {
                                <img src="https://images.unsplash.com/photo-1506929562872-bb421503ef21?auto=format&fit=crop&w=1200&q=80" alt="@item.Title" />
                            }
                        </div>
                    }
                    else
                    {
                        <div class="split-media">
                            @if (!string.IsNullOrWhiteSpace(item.Image))
                            {
                                <img src="@("http://localhost:5147/" + item.Image)" alt="@item.Title" />
                            }
                            else
                            {
                                <img src="https://images.unsplash.com/photo-1540946485063-a40da27545f8?auto=format&fit=crop&w=1200&q=80" alt="@item.Title" />
                            }
                        </div>
                        <div class="split-content">
                            <div class="split-content-top">
                                <span class="about-kicker">@item.SubTitle</span>
                                @if (!string.IsNullOrWhiteSpace(item.VideoUrl))
                                {
                                    <button class="split-video-btn js-open-video"
                                            data-video="@item.VideoUrl"
                                            aria-label="Play section video">
                                        <i class="fas fa-play"></i>
                                    </button>
                                }
                            </div>
                            <h2>@item.Title</h2>
                            <p>@item.Description</p>
                            @if (item.Achievements.Any())
                            {
                                <div class="achievements-list">
                                    @foreach (var ach in item.Achievements)
                                    {
                                        <div class="achievement-item">
                                            <span class="anim-border-top"></span>
                                            <span class="anim-border-bottom"></span>
                                            <h4>@ach.Title</h4>
                                            <p>@ach.Description</p>
                                        </div>
                                    }
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(item.BottomText))
                            {
                                <p style="margin-top: 18px;">@item.BottomText</p>
                            }
                        </div>
                    }

                </div>
            </div>
        }
    </section>
}

<section id="videoPopupSection" aria-hidden="true">
    <div class="video-dialog" role="dialog" aria-modal="true" aria-label="Seafarer video popup">
        <button class="video-close" id="videoPopupClose" aria-label="Close video"><i class="fas fa-times"></i></button>
        <iframe id="videoFrame" src="" title="Seafarer video" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
    </div>
</section>

<script>
    (function () {
        const popup   = document.getElementById("videoPopupSection");
        const frame   = document.getElementById("videoFrame");
        const closeBtn = document.getElementById("videoPopupClose");

        if (!popup || !frame || !closeBtn) return;

        // YouTube linki embed formatına çevirir
        function convertToEmbed(url) {
            if (!url) return "";

            // watch?v=
            if (url.includes("watch?v=")) {
                let videoId = url.split("watch?v=")[1];

                if (videoId.includes("&"))
                    videoId = videoId.split("&")[0];

                return "https://www.youtube.com/embed/" + videoId;
            }

            // youtu.be/
            if (url.includes("youtu.be/")) {
                let videoId = url.split("youtu.be/")[1];

                if (videoId.includes("?"))
                    videoId = videoId.split("?")[0];

                return "https://www.youtube.com/embed/" + videoId;
            }

            return url;
        }

        function openPopup(videoUrl) {
            const embedUrl = convertToEmbed(videoUrl);

            frame.src = embedUrl;
            popup.classList.add("open");
            popup.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
        }

        function closePopup() {
            popup.classList.remove("open");
            popup.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
            frame.src = "";
        }

        document.querySelectorAll(".js-open-video").forEach(function (btn) {
            btn.addEventListener("click", function () {
                var url = btn.getAttribute("data-video");
                if (url) openPopup(url);
            });
        });

        closeBtn.addEventListener("click", closePopup);

        popup.addEventListener("click", function (e) {
            if (e.target === popup) closePopup();
        });

        document.addEventListener("keydown", function (e) {
            if (e.key === "Escape") closePopup();
        });
    })();
</script>

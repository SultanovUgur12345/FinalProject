@using Microsoft.AspNetCore.Http

@{
    var userName = Context.Session.GetString("UserName");
}

<header>
    <div id="qodef-fixed-header-wrapper">

        <!-- TOP AREA -->
        <div id="qodef-top-area">
            <div id="qodef-top-area-inner">

                <div class="qodef-widget-holder qodef--left">
                    <div class="widget">
                        <p>Designed for modern yachting &amp; cruising businesses</p>
                    </div>
                </div>

                <div class="qodef-widget-holder qodef--right">
                    <div class="widget">
                        <a href="tel:+1234567890000">+(123) 456-7890-000</a>
                    </div>

                    <div class="widget">
                        <a href="mailto:info@seafarer.com">info@seafarer.com</a>
                    </div>
                </div>

            </div>
        </div>

        <!-- MAIN HEADER -->
        <div id="qodef-page-header" role="banner">
            <div id="qodef-page-header-inner" class="qodef-skin--light">

                <!-- LEFT SEARCH -->
                <div class="qodef-header-tools-left">
                    <form role="search"
                          method="get"
                          class="qodef-search-form"
                          action="#">

                        <div class="qodef-search-form-inner">
                            <input type="search"
                                   class="qodef-search-form-field"
                                   name="s"
                                   placeholder="Search..."
                                   required />

                            <button type="button"
                                    class="qodef-search-form-button"
                                    aria-label="Search">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     width="18"
                                     height="18"
                                     viewBox="0 0 20 20">
                                    <path d="M18.869 19.162l-5.943-6.484c1.339-1.401 2.075-3.233 2.075-5.178 0-2.003-0.78-3.887-2.197-5.303s-3.3-2.197-5.303-2.197-3.887 0.78-5.303 2.197-2.197 3.3-2.197 5.303 0.78 3.887 2.197 5.303 3.3 2.197 5.303 2.197c1.726 0 3.362-0.579 4.688-1.645l5.943 6.483c0.099 0.108 0.233 0.162 0.369 0.162 0.121 0 0.242-0.043 0.338-0.131 0.204-0.187 0.217-0.503 0.031-0.706zM1 7.5c0-3.584 2.916-6.5 6.5-6.5s6.5 2.916 6.5 6.5-2.916 6.5-6.5 6.5-6.5-2.916-6.5-6.5z" />
                                </svg>
                            </button>
                        </div>
                    </form>
                </div>

                <!-- CENTER MENU -->
                <div class="qodef-header-center-wrap">
                    <nav class="qodef-header-navigation" role="navigation">
                        <ul class="menu-main-center">

                            <li class="menu-item active">
                                <a asp-controller="Home" asp-action="Index">Home</a>
                            </li>

                            <li class="menu-item">
                                <a href="about.html">About</a>
                            </li>

                            <li class="menu-item">
                                <a asp-controller="Contact" asp-action="Index">Contact</a>
                            </li>

                            <li class="menu-item qodef-header-menu-logo">
                                <a class="qodef-header-logo-link" href="home.html" rel="home">
                                    <img src="https://seafarer.qodeinteractive.com/wp-content/uploads/2021/10/Logo-light.png"
                                         alt="Seafarer Logo" />
                                </a>
                            </li>

                            <li class="menu-item">
                                <a asp-controller="Workers" asp-action="Index">Workers</a>
                            </li>

                            <li class="menu-item">
                                <a href="#">Blog</a>
                            </li>

                            <li class="menu-item qodef-book-btn">
                                <a href="#">Book</a>
                            </li>

                        </ul>
                    </nav>
                </div>

                <!-- RIGHT USER -->
                <div class="qodef-header-tools-right">
                    <div class="qodef-header-user">

                        <a href="javascript:void(0)"
                               class="qodef-user-opener"
                               aria-label="User menu">
                            <i class="far fa-user"></i>
                        </a>

                        <div class="qodef-user-dropdown">
                            @if (!string.IsNullOrEmpty(userName))
                            {
                                <a href="javascript:void(0)"
                                       style="font-weight:600; pointer-events:none;">
                                    @userName
                                </a>

                                <a asp-controller="Account" asp-action="EditProfile">
                                    Edit Profile
                                </a>

                                <a asp-controller="Account" asp-action="Logout">
                                    Logout
                                </a>
                            }
                            else
                            {
                                <a asp-controller="Account" asp-action="Login">
                                    Login
                                </a>

                                <a asp-controller="Account" asp-action="Register">
                                    Register
                                </a>
                            }
                        </div>

                    </div>
                </div>

            </div>
        </div>

    </div>
</header>